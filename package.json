{
  "name": "Reckons.AI",
  "version": "0.1.0",
  "private": true,
  "description": "A local-first personal knowledge graph that turns documents, web pages, and notes into a reviewable graph of facts, stored as a standard Turtle (.ttl) file on your device.",
  "homepage": "https://reckons.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Data-Insight-Solutions/Reckons.AI.git"
  },
  "bugs": {
    "url": "https://github.com/Data-Insight-Solutions/Reckons.AI/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "bench:agentic": "npx tsx tests/bench/run-agentic-bench.ts",
    "bench:agentic:save": "npx tsx tests/bench/run-agentic-bench.ts --save",
    "bench:coding": "npx tsx tests/bench/run-coding-bench.ts",
    "bench:coding:save": "npx tsx tests/bench/run-coding-bench.ts --save",
    "bench:compression": "npx tsx tests/bench/run-compression-bench.ts --save",
    "bench:cost": "npx tsx tests/bench/run-cost-bench.ts",
    "bench:cost:run": "npx tsx tests/bench/run-cost-bench.ts --run --save",
    "bench:docs": "npx tsx tests/bench/run-docs-bench.ts",
    "bench:docs:save": "npx tsx tests/bench/run-docs-bench.ts --save",
    "bench:embed": "npx tsx tests/visual/run-embed-bench.ts",
    "bench:embed:hf": "npx tsx tests/visual/run-embed-bench.ts --hf --save",
    "bench:embed:list": "npx tsx tests/visual/run-embed-bench.ts --list",
    "bench:hf-query": "npx tsx tests/visual/hf-model-query.ts",
    "bench:landing": "npx tsx tests/bench/run-landing-page-bench.ts --save",
    "bench:landing:e2e": "npx tsx tests/bench/run-landing-page-e2e.ts --save",
    "bench:llm": "npx tsx tests/bench/run-bench.ts",
    "bench:llm:hf": "npx tsx tests/bench/run-bench.ts --hf --save",
    "bench:llm:list": "npx tsx tests/bench/run-bench.ts --list",
    "bench:ollama": "npx tsx tests/bench/run-ollama-bench.ts",
    "bench:ollama:list": "npx tsx tests/bench/run-ollama-bench.ts --list",
    "bench:ollama:save": "npx tsx tests/bench/run-ollama-bench.ts --save",
    "bench:stt": "npx tsx tests/bench/run-stt-bench.ts",
    "bench:stt:save": "npx tsx tests/bench/run-stt-bench.ts --save",
    "bench:tts": "npx tsx tests/bench/run-tts-bench.ts",
    "bench:tts:save": "npx tsx tests/bench/run-tts-bench.ts --save",
    "bench:visual": "npx tsx tests/visual/run-visual-bench.ts",
    "bench:visual:api": "npx tsx tests/visual/run-visual-bench.ts --api --save",
    "bench:visual:list": "npx tsx tests/visual/run-visual-bench.ts --list",
    "bench:vlm": "npx tsx tests/visual/run-vlm-gate-bench.ts",
    "bench:vlm:save": "npx tsx tests/visual/run-vlm-gate-bench.ts --save",
    "branch-align": "npx tsx scripts/branch-align.ts",
    "build": "vite build",
    "build-storybook": "storybook build",
    "build:extension": "vite build --config vite.extension.config.ts",
    "build:test": "VITE_PREFERRED_BACKEND=mock VITE_INGEST_BACKEND=mock VITE_CHAT_BACKEND=mock vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "coverage": "vitest run --coverage",
    "dev": "vite dev",
    "dev:extension": "vite build --config vite.extension.config.ts --watch",
    "dev:test": "VITE_PREFERRED_BACKEND=mock VITE_INGEST_BACKEND=mock VITE_CHAT_BACKEND=mock vite dev --port 5174",
    "docs:pages": "npx tsx scripts/docs-pages.ts",
    "kb:align": "npx tsx scripts/kb-align.ts",
    "kb:align:dry": "npx tsx scripts/kb-align.ts --dry-run",
    "kb:align:quick": "npx tsx scripts/kb-align.ts --skip-e2e",
    "kb:reckon": "npx tsx tests/bench/run-kb-workflow.ts reckon --save",
    "kb:review": "npx tsx tests/bench/run-kb-workflow.ts review --save",
    "kb:search": "npx tsx tests/bench/run-kb-workflow.ts search",
    "kb:setup": "bash scripts/setup-reckons-workspace.sh",
    "kb:stats": "npx tsx tests/bench/run-kb-workflow.ts stats",
    "md-align": "npx tsx scripts/md-align.ts",
    "offline:sweep": "bash scripts/offline/alignment-sweep.sh",
    "offline:visual-diff": "npx tsx scripts/offline/visual-diff.ts",
    "preview": "vite preview",
    "storybook": "storybook dev --port 6006",
    "test": "vitest",
    "test:e2e": "playwright test --project=desktop-chrome",
    "test:e2e:devices": "playwright test",
    "test:e2e:headed": "playwright test --headed --project=desktop-chrome",
    "test:e2e:mobile": "playwright test --project=mobile-android --project=mobile-ios --project=tablet",
    "test:e2e:smoke": "npm run build:test && playwright test --config=playwright.smoke.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:local": "bash tests/bench/run-local-suite.sh",
    "test:local:bench": "bash tests/bench/run-local-suite.sh --bench-only --save",
    "test:local:quick": "bash tests/bench/run-local-suite.sh --quick",
    "test:run": "vitest run",
    "test:stories": "playwright test --config=playwright.visual.config.ts --project=user-stories",
    "test:visual": "playwright test --config=playwright.visual.config.ts --project=chromium",
    "test:visual:all": "playwright test --config=playwright.visual.config.ts",
    "visual:graph": "npx tsx scripts/visual-graph.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@internationalized/date": "^3.12.2",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/svelte-vite": "^8.6.18",
    "@storybook/sveltekit": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/chrome": "^0.0.325",
    "@types/qrcode": "^1.5.6",
    "@types/three": "^0.185.0",
    "@vite-pwa/sveltekit": "^1.1.0",
    "@vitest/coverage-v8": "^4.1.7",
    "clsx": "^2.1.1",
    "jsdom": "^29.1.1",
    "mdsvex": "^0.12.7",
    "shadcn-svelte": "^1.3.0",
    "sharp": "^0.34.5",
    "storybook": "^8.6.18",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.0",
    "vite": "^8.1.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@threlte/core": "^8.5.16",
    "@threlte/extras": "^9.21.0",
    "bits-ui": "^2.18.1",
    "dexie": "^4.4.4",
    "fflate": "^0.8.3",
    "hume": "^0.16.0",
    "kokoro-js": "^1.2.1",
    "n3": "^2.1.1",
    "qrcode": "^1.5.4",
    "three": "^0.185.1",
    "uuid": "^14.0.1"
  }
}
