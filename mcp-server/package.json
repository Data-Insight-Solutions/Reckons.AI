{
  "name": "reckons-ai-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing a Reckons.AI knowledge base to AI agents",
  "type": "module",
  "bin": {
    "reckons-mcp": "./dist/index.js"
  },
  "scripts": {
