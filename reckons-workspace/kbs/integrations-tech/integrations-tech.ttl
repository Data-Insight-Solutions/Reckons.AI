<urn:reckons:integration/N8nCloudSync>
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:integration/Integrations> ;
    rdfs:label "n8n Cloud Sync" ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:integration/Integrations> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Private, self-hosted cloud sync via n8n workflow automation. Two workflows: KB Sync Hub (upload/download/status/pending via webhooks with content-hash deduplication) and Source Monitor (watches URLs every 6 hours, detects content changes, queues pending notes). No SaaS dependency — your n8n VPS is the cloud backend." ;
    rdf:type <urn:kbase:type/Concept> ;
    rdfs:label "n8n Cloud Sync" ;
    <http://www.w3.org/2004/02/skos/core#definition> "Private, self-hosted cloud sync via n8n workflow automation. Two workflows: KB Sync Hub (upload/download/status/pending via webhooks with content-hash deduplication) and Source Monitor (watches URLs every 6 hours, detects content changes, queues pending notes). No SaaS dependency — your n8n VPS is the cloud backend." ;
    rdf:type <urn:kbase:type/Concept> .

