<urn:reckons:integration/N8nSyncHub>
    rdfs:label "KB Sync Hub (n8n)" ;
    rdf:type <urn:kbase:type/Concept> ;
    <http://www.w3.org/2004/02/skos/core#definition> "n8n workflow with 4 webhook endpoints: POST upload (SHA-256 dedup), GET download (serves text/turtle), GET status (JSON summary of all KBs), GET pending (pending notes from source monitors). Data stored in n8n Data Tables." ;
    rdfs:label "KB Sync Hub (n8n)" ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:integration/N8nCloudSync> ;
