<urn:reckons:tech/TransformersJS>
    rdf:type <urn:kbase:type/Tool> ;
    rdf:type <urn:kbase:type/Tool> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Runs ML models in the browser via ONNX Runtime WebAssembly. Powers local LLM inference (SmolLM2-360M, q4 quantized), text embeddings (MiniLM-L6-v2, q8), speech-to-text (Whisper Tiny), and text-to-speech (Kokoro 82M)." ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:tech/Architecture> ;
    rdfs:label "@huggingface/transformers v3" ;
    rdfs:label "@huggingface/transformers v3" ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:tech/Architecture> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Runs ML models in the browser via ONNX Runtime WebAssembly. Powers local LLM inference (SmolLM2-360M, q4 quantized), text embeddings (MiniLM-L6-v2, q8), speech-to-text (Whisper Tiny), and text-to-speech (Kokoro 82M)." .

<urn:reckons:integration/ModelCache>
    <http://www.w3.org/2004/02/skos/core#definition> "Inspect, sideload, and purge locally cached WASM models via Cache API. Manifests track SmolLM2-360M (370MB), MiniLM-L6-v2 (22MB), Kokoro 82M (88MB), Whisper Tiny (42MB). Service worker caches HuggingFace downloads with CacheFirst strategy." ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:integration/Integrations> ;
    rdfs:label "Model Cache Management" ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:integration/Integrations> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Inspect, sideload, and purge locally cached WASM models via Cache API. Manifests track SmolLM2-360M (370MB), MiniLM-L6-v2 (22MB), Kokoro 82M (88MB), Whisper Tiny (42MB). Service worker caches HuggingFace downloads with CacheFirst strategy." ;
    rdf:type <urn:kbase:type/Concept> ;
    rdfs:label "Model Cache Management" ;
    rdf:type <urn:kbase:type/Concept> .

