## =============================================================================
## Reckons.AI Codebase KB
## =============================================================================
## A structural map of the tripleNotes repository. Each module, directory, and
## key file is represented as an entity. kpred:has-file links modules to source
## files, kpred:tested-by links to test files, and skos:broader links files to
## their parent module. KB Leap nodes connect to Production and Features KBs.
##
## All file paths are repo-relative (matching `git ls-files` output).
## =============================================================================

@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix ktype:  <urn:kbase:type/> .
@prefix kpred:  <urn:kbase:predicate/> .
@prefix code:   <urn:reckons:code/> .

## KB Identity
<urn:reckons:kb> <urn:reckons:meta/kbStableId> "a1b2c3d4-e5f6-4a0a-b00a-000000000010" .

## =============================================================================
## Repository Root
## =============================================================================

code:repo  rdf:type     ktype:Concept ;
           rdfs:label   "tripleNotes Repository" ;
           skos:definition "Root of the Reckons.AI monorepo. 721 git-tracked files." ;
           kpred:has-file "package.json" ;
           kpred:has-file "vite.config.ts" ;
           kpred:has-file "svelte.config.js" ;
           kpred:has-file "tsconfig.json" ;
           kpred:has-file "vitest.config.ts" ;
           kpred:has-file "CLAUDE.md" ;
           kpred:has-file "README.md" ;
           kpred:has-file "CONTRIBUTING.md" ;
           kpred:has-file ".gitignore" ;
           kpred:has-file ".env.example" ;
           kpred:has-file "LICENSE" ;
           kpred:has-file "src/app.html" .

