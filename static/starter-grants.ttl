## ---------------------------------------------------------------------------
## Reckons.AI — "Grant discovery" starter graph (F73)
## ---------------------------------------------------------------------------
## Two real nonprofits, two grant use-cases. The graph holds each org's
## GRANT-SEEKER PROFILE — what it is and what it's eligible for. A scheduled n8n
## scrape (kb:grant-discovery-currents) reads the profile, searches for matching
## grant CALLS, and posts each match back as a PENDING fact for review; n8n emails
## you (kb:n8n-review-notifications) so you only open the graph when there's
## something to decide.
##
## The key idea — a GROWING FILTER SET. A profile starts sparse. When a scraped
## call raises a requirement the profile can't yet answer ("annual operating
## budget?", "is equipment new or used?"), that requirement lands as a partial
## fact: object "?" with a question. Answering it (in Review) both unblocks that
## call AND permanently sharpens every future search. The filter grows one
## real-world requirement at a time — see the p:… "?" facts below.
## ---------------------------------------------------------------------------

@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix ktype: <urn:kbase:type/> .
@prefix kb:    <urn:kbase:concept/> .
@prefix p:     <urn:kbase:predicate/> .

## == Custom entity types =====================================================
ktype:Organization
    rdf:type   ktype:EntityType ; rdfs:label "Organization" ;
    p:icon "octahedron" ; p:color "#4f9bd9" .
ktype:GrantProgram
    rdf:type   ktype:EntityType ; rdfs:label "Grant Program" ;
    p:icon "cone" ; p:color "#3a9d5c" .
ktype:GrantSeekerProfile
    rdf:type   ktype:EntityType ; rdfs:label "Grant-Seeker Profile" ;
    p:icon "torus" ; p:color "#e0a13c" .
ktype:GrantCall
    rdf:type   ktype:EntityType ; rdfs:label "Grant Call" ;
    p:icon "tetrahedron" ; p:color "#c86fd9" .

## == Org 1: Ava Lions Club — "Food Tokens" ===================================
kb:ava-lions-club
    rdf:type       ktype:Organization ;
    rdfs:label     "Ava Lions Club" ;
    rdfs:comment   "Local Lions Club chapter in Ava. Runs community service programs; piloting a Food Tokens system for food-insecure residents." ;
    p:location     "Ava" ;
    p:org-type     "Lions Club chapter (likely 501(c)(4)/affiliated 501(c)(3))" ;
    p:runs         kb:food-tokens .

kb:food-tokens
    rdf:type       ktype:GrantProgram ;
    rdfs:label     "Food Tokens" ;
    rdfs:comment   "A designed-and-piloted system: eligible residents receive tokens redeemable for food (redeemable at the Ava Growers Project Saturday market and partner vendors). Seeking grant funding to move from pilot to sustained operation." ;
    p:stage        "piloted — seeking funding to sustain/scale" ;
    p:seeks        kb:lions-profile ;
    p:designed-by  "the graph operator" .

kb:lions-profile
    rdf:type       ktype:GrantSeekerProfile ;
    rdfs:label     "Food Tokens — grant-seeker profile" ;
    rdfs:comment   "What the Food Tokens program is eligible for and seeking. The scheduled scrape targets calls that match these dimensions." ;
    p:focus-area   "food insecurity / hunger relief" ;
    p:focus-area   "community health" ;
    p:population   "food-insecure residents" ;
    p:geography    "Ava and surrounding county" ;
    p:funding-need "program operations + token redemption float" ;
    ## Growing filter — surfaced by real call requirements, still unanswered:
    p:annual-budget          "?" ;   ## many funders ask for it — answer once, filters forever
    p:501c3-status           "?" ;   ## some calls require a registered 501(c)(3) or fiscal sponsor
    p:residents-served-count "?" .   ## pilot reach; funders want a number

## == Org 2: Ava Growers Project — "Farm Equipment" ===========================
kb:ava-growers-project
    rdf:type       ktype:Organization ;
    rdfs:label     "Ava Growers Project" ;
    rdfs:comment   "Runs the Saturday-morning farmers market at the Ava town square. Seeking grants for farm equipment to raise local produce production capacity." ;
    p:location     "Ava town square (Saturday market)" ;
    p:org-type     "community growers project" ;
    p:runs         kb:farm-equipment .

kb:farm-equipment
    rdf:type       ktype:GrantProgram ;
    rdfs:label     "Farm Equipment" ;
    rdfs:comment   "Grant-funded farm equipment for members' farms — the President's, Vice President's, or members' land — to increase local produce production capacity that feeds the Saturday market (and, potentially, Food Token redemption)." ;
    p:stage        "seeking equipment funding" ;
    p:beneficiary  "President, Vice President, and member farms" ;
    p:goal         "increase local produce production capacity" ;
    p:seeks        kb:growers-profile .

kb:growers-profile
    rdf:type       ktype:GrantSeekerProfile ;
    rdfs:label     "Farm Equipment — grant-seeker profile" ;
    p:focus-area   "local food systems / agriculture" ;
    p:focus-area   "small-farm capacity building" ;
    p:population   "local growers and market shoppers" ;
    p:geography    "Ava and surrounding county" ;
    p:funding-need "farm equipment (capital)" ;
    ## Growing filter — surfaced by real call requirements, still unanswered:
    p:equipment-list         "?" ;   ## which equipment, and cost per item?
    p:equipment-condition    "?" ;   ## new vs. used — some ag grants restrict this
    p:beneficiary-eligibility "?" ;  ## can grant funds buy equipment used on private member farms?
    p:acreage-served         "?" .

## == Example scraped grant CALLS (what the scheduled scrape posts for review) ==
## In production these arrive as PENDING facts from n8n; a couple shown here so the
## match/requirement/growing-filter loop is visible on first load.
kb:usda-lfpp-2026
    rdf:type       ktype:GrantCall ;
    rdfs:label     "USDA Local Food Promotion Program (example)" ;
    rdfs:comment   "Example call surfaced for BOTH orgs — supports local food systems (markets, aggregation, capacity). Illustrative, not a live listing." ;
    p:matches      kb:growers-profile ;
    p:matches      kb:lions-profile ;
    p:requires     "applicant org type / 501(c)(3) or fiscal sponsor" ;
    p:requires     "project budget and match" ;
    p:link         "https://www.grants.gov/search-grants" .

kb:foundation-hunger-mini
    rdf:type       ktype:GrantCall ;
    rdfs:label     "Community Foundation hunger mini-grant (example)" ;
    rdfs:comment   "Example small mini-grant matching the Food Tokens focus. Illustrative." ;
    p:matches      kb:lions-profile ;
    p:requires     "residents-served number" ;
    p:requires     "annual operating budget" ;
    p:link         "https://www.grants.gov/search-grants" .
