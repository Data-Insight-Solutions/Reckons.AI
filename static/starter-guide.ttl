## =============================================================================
## Summary entities (referenced by the story — kept inline for story highlights)
## =============================================================================

arch:TripleArchitecture
    rdf:type            ktype:Concept ;
    rdfs:label          "The Semantic Triple" ;
    skos:definition     "The fundamental unit of knowledge in RDF: subject - predicate - object. Any fact can be expressed as a triple. Triples connect to form a graph." ;
    skos:related        guide:WhatIsReckonsAI ;
    skos:related        leap:TriplesAndRDF .

arch:SubjectPredicateObject
    rdf:type            ktype:Concept ;
    rdfs:label          "Subject - Predicate - Object" ;
    skos:definition     "Subject: the entity. Predicate: the relationship. Object: the value. Example: 'Alice worksAt AcmeCorp'." ;
    skos:broader        arch:TripleArchitecture .

arch:PlainTextPortability
    rdf:type            ktype:Concept ;
    rdfs:label          "Plain Text Portability" ;
    skos:definition     "Your KB exports as a .ttl file -- plain text, human-readable. Open it in any text editor, diff it with git. When apps die, your .ttl still works." ;
    skos:broader        arch:TripleArchitecture .

arch:ReviewWorkflow
    rdf:type            ktype:Document ;
    rdfs:label          "The Review Workflow" ;
    skos:definition     "Ingest -> Review -> Explore -> Ask Shelly -> Share. Human review at every step." ;
    skos:broader        arch:TripleArchitecture .

llm:WhatLLMsAre
    rdf:type            ktype:Concept ;
    rdfs:label          "What Language Models Actually Are" ;
    skos:definition     "Trained statistical models built with human knowledge. They predict text, not truth. Powerful tools, but tools -- not thinkers." ;
    skos:related        leap:LanguageModels .

llm:KBGroundedAccuracy
    rdf:type            ktype:Concept ;
    rdfs:label          "KB-Grounded Accuracy" ;
    skos:definition     "When an LLM retrieves YOUR confirmed facts instead of guessing, accuracy skyrockets. Your curated KB is the best retrieval source possible." ;
    skos:broader        llm:WhatLLMsAre .

use:PersonalEmpowerment
    rdf:type            ktype:Concept ;
    rdfs:label          "Power to the Individual" ;
    skos:definition     "Build a KB of your rights, evidence, and correspondence. Communicate with the authority of an institution -- it is just you and your knowledge." ;
    skos:related        leap:UseCases .

feat:Shelly
    rdf:type            ktype:Person ;
    rdfs:label          "Shelly (AI Assistant)" ;
    skos:definition     "The turtle-shaped AI assistant. Grounded in your KB, not generic training data." ;
    skos:broader        guide:WhatIsReckonsAI ;
    skos:related        leap:Features .

feat:ReviewSystem
    rdf:type            ktype:Concept ;
    rdfs:label          "Review System" ;
    skos:definition     "Confirm, reject, or refine every extracted triple. Nothing enters your KB without your approval." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:Ingest
    rdf:type            ktype:Concept ;
    rdfs:label          "Ingest" ;
    skos:definition     "Add knowledge from text, URLs, documents, calendars, or Turtle files." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:LLMBackends
    rdf:type            ktype:Concept ;
    rdfs:label          "LLM Backends" ;
    skos:definition     "Claude, OpenAI, Gemini, Ollama (local), OpenRouter, WASM (offline), Chrome AI." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:Graph3D
    rdf:type            ktype:Concept ;
    rdfs:label          "3D Knowledge Graph" ;
    skos:definition     "Interactive force-directed graph in WebGL. Click, drag, filter, explore." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:TTLExport
    rdf:type            ktype:Concept ;
    rdfs:label          "Turtle Export" ;
    skos:definition     "Export your KB as .ttl with full metadata. Roundtrip-safe. Share with anyone." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:Reckoning
    rdf:type            ktype:Concept ;
    rdfs:label          "A Reckoning (STP)" ;
    skos:definition     "Situation-Target-Proposal: structured reasoning over your verified facts." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:TrustSystem
    rdf:type            ktype:Concept ;
    rdfs:label          "Source Trust System" ;
    skos:definition     "Sources earn trust through consistent accuracy. Trusted sources auto-confirm." ;
    skos:broader        guide:WhatIsReckonsAI .

tech:Architecture
    rdf:type            ktype:Concept ;
    rdfs:label          "Technology Stack" ;
    skos:definition     "SvelteKit + Threlte/Three.js + N3.js + transformers.js + Dexie. No server." ;
    skos:broader        guide:WhatIsReckonsAI ;
    skos:related        leap:IntegrationsTech .

tip:StartSmall
    rdf:type            ktype:Concept ;
    rdfs:label          "Start Small" ;
    skos:definition     "Begin with one document you care about. Connections emerge as you add sources." ;
    skos:related        leap:TipsSecurity .


## =============================================================================
## Getting Started Steps
## =============================================================================

guide:GettingStarted
    rdf:type            ktype:Document ;
    rdf:type            skos:Concept ;
    rdfs:label          "Getting Started" ;
    skos:definition     "A step-by-step guide to building your first knowledge graph." ;
    skos:broader        guide:WhatIsReckonsAI .

guide:Step1
    rdf:type            ktype:Document ;
    rdfs:label          "Step 1: Choose an LLM Backend" ;
    skos:definition     "Go to Settings and configure at least one LLM provider. Ollama (free, local) or OpenRouter (free tier) are good starting points." ;
    skos:broader        guide:GettingStarted ;
    skos:related        feat:LLMBackends .

guide:Step2
    rdf:type            ktype:Document ;
    rdfs:label          "Step 2: Ingest Your First Content" ;
    skos:definition     "Go to Ingest and paste text, a URL, or upload a document. The LLM will extract semantic triples automatically." ;
    skos:broader        guide:GettingStarted ;
    skos:related        feat:Ingest .

guide:Step3
    rdf:type            ktype:Document ;
    rdfs:label          "Step 3: Review Pending Statements" ;
    skos:definition     "Go to Review to see extracted triples. Confirm accurate ones, reject incorrect ones, refine those that need adjustment." ;
    skos:broader        guide:GettingStarted ;
    skos:related        feat:ReviewSystem .

guide:Step4
    rdf:type            ktype:Document ;
    rdfs:label          "Step 4: Explore the Graph" ;
    skos:definition     "Go to Graph to see your knowledge in 3D. Click nodes to select them, use the RadialMenu for actions, and use filters to focus." ;
    skos:broader        guide:GettingStarted ;
    skos:related        feat:Graph3D .

guide:Step5
    rdf:type            ktype:Document ;
    rdfs:label          "Step 5: Ask Shelly" ;
    skos:definition     "Click the turtle icon in the search bar to chat with Shelly. Ask questions about your KB, play the story walkthrough, or request a Reckoning." ;
    skos:broader        guide:GettingStarted ;
    skos:related        feat:Shelly .

guide:Step6
    rdf:type            ktype:Document ;
    rdfs:label          "Step 6: Export and Share" ;
    skos:definition     "Go to Settings -> Backup and Export to download your KB as Turtle. Share the .ttl file or set up workspace sync for MCP integration." ;
    skos:broader        guide:GettingStarted ;
    skos:related        feat:TTLExport .


## =============================================================================
## Quick-Start Example
## =============================================================================

guide:QuickStartExample
    rdf:type            ktype:Document ;
    rdfs:label          "Quick-Start Example KB" ;
    skos:definition     "A practical knowledge graph with people, projects, research notes, decisions, and metrics. Import it from the Info page to see how real-world data maps to triples. 15 entities, 90 triples." ;
    skos:broader        guide:GettingStarted ;
    dc:source           "/starter-quickstart.ttl" .


## =============================================================================
## The Reckons.AI Story (guided walkthrough)
## =============================================================================

@prefix story: <urn:reckons:story/> .

story:ReckonsPhilosophy
    rdf:type            story:Story ;
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "The Reckons.AI Story" ;
    story:description   "A guided walkthrough of why Reckons.AI exists, how it works, and what it means for you." ;
    story:autoplay      "false" ;
    story:pace          "40" .

story:Intro
    rdf:type            story:Step ;
    story:partOf        story:ReckonsPhilosophy ;
    story:order         "1" ;
    story:title         "Your Knowledge, Your Power" ;
    story:content       "Every day you accumulate knowledge: conversations, documents, decisions, research, correspondence. But that knowledge is scattered across emails, notes, PDFs, and your memory. Reckons.AI gives you a single, structured, portable place to capture it all -- and tools to USE it when it matters." ;
    story:highlight     guide:WhatIsReckonsAI ;
    story:prompt        "Explain why scattered knowledge is a problem and how structured knowledge helps." ;
    story:question      "Have you ever wished you could instantly recall every detail from an important document?" .

story:TriplesPower
    rdf:type            story:Step ;
    story:partOf        story:ReckonsPhilosophy ;
    story:order         "2" ;
    story:title         "Everything Is a Triple" ;
    story:content       "The secret is the **semantic triple**: subject - predicate - object. 'Alice worksAt AcmeCorp'. 'Policy covers water-damage'. 'Contract expires July-1st'. Every fact breaks down into this atomic form. Triples connect to form a graph -- and graphs reveal relationships that documents hide." ;
    story:highlight     arch:SubjectPredicateObject ;
    story:prompt        "Give more examples of real-world facts expressed as triples. Show how they connect." ;
    story:question      "Can you think of a fact from your own life that would be useful as a triple?" .

story:PlainText
    rdf:type            story:Step ;
    story:partOf        story:ReckonsPhilosophy ;
    story:order         "3" ;
    story:title         "Plain Text Outlasts Everything" ;
    story:content       "Your knowledge base exports as a **.ttl file** -- plain text, human-readable, no proprietary format. You can open it in any text editor, diff it with git, email it, or print it. When apps shut down and formats die, your .ttl file will still work. It is the most durable way to store knowledge." ;
    story:highlight     arch:PlainTextPortability ;
    story:prompt        "Compare .ttl portability to proprietary note-taking apps. Explain why plain text survives." .

story:WhatLLMsReally
    rdf:type            story:Step ;
    story:partOf        story:ReckonsPhilosophy ;
    story:order         "4" ;
    story:title         "What 'AI' Actually Is" ;
    story:content       "The language models people call 'AI' are **trained statistical models** built with human knowledge at every level. Humans wrote the training data, designed the architecture, and aligned the outputs. These models are powerful tools, but they are tools -- not thinkers. They predict likely text based on patterns. They can hallucinate confidently. That is why YOUR review matters." ;
    story:highlight     llm:WhatLLMsAre ;
    story:prompt        "Explain honestly what LLMs can and cannot do. Be specific about hallucination." ;
    story:question      "Does knowing this change how you think about using AI tools?" .

story:KBAccuracy
    rdf:type            story:Step ;
    story:partOf        story:ReckonsPhilosophy ;
    story:order         "5" ;
    story:title         "Your KB Makes AI Accurate" ;
    story:content       "Here is the game-changer: when an LLM has access to YOUR reviewed knowledge base, its outputs become dramatically more accurate. Instead of guessing from training data, it retrieves YOUR confirmed facts. This is called **retrieval-augmented generation** -- and the quality of the retrieval source is everything. Your curated KB is the best source possible." ;
    story:highlight     llm:KBGroundedAccuracy ;
    story:prompt        "Explain RAG and why a curated personal KB is better than generic training data." .

story:StandingUp
    rdf:type            story:Step ;
    story:partOf        story:ReckonsPhilosophy ;
    story:order         "6" ;
    story:title         "Level the Playing Field" ;
    story:content       "Insurance companies have teams of analysts. Corporations have legal departments. Landlords have property managers. You have... your memory and a stack of papers? Not anymore. Build a KB of your policy terms, correspondence, rights, and evidence. Ask Shelly to draft a precise response citing YOUR documented facts. You communicate with the authority of an institution, but it is just you and your knowledge." ;
    story:highlight     use:PersonalEmpowerment ;
    story:prompt        "Give specific examples of using a KB for insurance claims, legal disputes, or corporate pushback." ;
    story:question      "Is there a situation in your life where having organized, citable evidence would help?" .

story:HowItWorks
    rdf:type            story:Step ;
    story:partOf        story:ReckonsPhilosophy ;
    story:order         "7" ;
    story:title         "The Workflow" ;
    story:content       "1. **Ingest** -- paste text, upload documents, import calendars\n2. **Review** -- the LLM extracts triples, you confirm or reject each one\n3. **Explore** -- navigate your 3D knowledge graph, find connections\n4. **Ask Shelly** -- get answers grounded in your confirmed facts\n5. **Share** -- export your .ttl and share your knowledge" ;
    story:highlight     arch:ReviewWorkflow ;
    story:prompt        "Walk through each step in more detail. Explain the human-in-the-loop review." .

story:GetStarted
    rdf:type            story:Step ;
    story:partOf        story:ReckonsPhilosophy ;
    story:order         "8" ;
    story:title         "Start Building" ;
    story:content       "Your knowledge graph starts with one fact. Ingest a document you care about. Review the triples. Confirm the accurate ones. That is it -- your KB grows with every source you add. Over time, connections emerge that you never would have seen reading documents linearly. Your knowledge becomes a living, queryable, shareable graph." ;
    story:highlight     tip:StartSmall ;
    story:prompt        "Suggest concrete first steps. What should someone ingest first?" ;
    story:question      "Ready to add your first piece of knowledge?" .


## =============================================================================
## Persona: documentation guide
## =============================================================================

shelly:persona
    shelly:name             "Shelly" ;
    shelly:greeting         "Hey! I'm Shelly, and this is the Reckons.AI documentation hub. The nodes with amber rings are **leap points** -- each links to a deeper sub-graph you can import. Try the **stories** tab for a guided walkthrough!" ;
    shelly:personality      "knowledgeable, empowering, direct" ;
    shelly:responseStyle    "conversational" ;
    shelly:systemPrompt     "You are helping someone learn Reckons.AI. This is the documentation HUB -- a compact overview. Nodes labeled 'LEAP:' link to deeper sub-graphs (separate .ttl files). Emphasize practical uses, individual empowerment, and the accuracy advantage of KB-grounded LLM responses. Be honest about what LLMs can and cannot do. Encourage the user to build their own knowledge and never blindly trust any model output." .
