<urn:reckons:story/prod-step-5>
    rdf:type <urn:reckons:story/Step> ;
    <urn:reckons:story/highlight> kb:repo-ingest ;
    <urn:reckons:story/order> "5"^^xsd:integer ;
    <urn:reckons:story/title> "Ingest & Source Refresh" ;
    <urn:reckons:story/content> "The ingest pipeline supports 10 source types including the new GitHub repo ingest. URL, repository, and calendar sources can be refreshed to pull in updates. Auto-refresh can be configured to run on graph open or on a schedule. The repo ingest uses the GitHub REST API for tree walking and delta comparison." ;
    <urn:reckons:story/highlight> kb:ingest-pipeline ;
    <urn:reckons:story/partOf> <urn:reckons:story/production-tour> ;
    <urn:reckons:story/highlight> kb:source-refresh .

