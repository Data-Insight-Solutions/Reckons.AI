kb:graph-alignment-setup
    pred:description "How to run the Reckons.AI Graph Alignment Check locally or wire it in CI. The workflow builds the MCP server, sets up the self-dogfooding workspace, then runs the alignment script." ;
    pred:ci-variable "APP_URL_MAIN — production app URL for the review deep link (default https://reckons.ai)" ;
    pred:ci-variable "APP_URL_DEV — dev app URL (default https://dev.reckons-ai.pages.dev)" ;
    pred:prerequisite "Repo checked out with git history (CI uses fetch-depth: 20 for diff scoring)" ;
    rdfs:label "Graph Alignment — Setup" ;
    pred:setup-step "1. Install deps: npm ci" ;
    pred:npm-script "kb:setup — bash scripts/setup-reckons-workspace.sh" ;
    pred:npm-script "kb:align:quick — npx tsx scripts/kb-align.ts --skip-e2e" ;
    pred:ci-variable "APP_URL_STAGING — staging app URL (default https://staging.reckons-ai.pages.dev)" ;
    pred:setup-step "3. Set up the workspace symlinks: bash scripts/setup-reckons-workspace.sh" ;
    pred:setup-step "4. Run the check: npx tsx scripts/kb-align.ts --skip-e2e --dry-run --ref HEAD~5" ;
    pred:prerequisite "Node.js 24+ and npm" ;
    pred:note "The PR-comment step needs `permissions: pull-requests: write` (already set in kb-watch.yml)." ;
    pred:setup-step "5. (Optional) Snapshot for before/after: npx tsx scripts/kb-snapshot.ts --output snapshot.json" ;
    pred:setup-step "2. Build the MCP server (kb-align imports from it): cd mcp-server && npm ci && npm run build" ;
    rdf:type <urn:kbase:type/Concept> .

