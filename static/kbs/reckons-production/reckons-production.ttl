    <urn:reckons:story/partOf> <urn:reckons:story/production-tour> ;
    <urn:reckons:story/order> "4"^^xsd:integer ;
    <urn:reckons:story/content> "The MCP server exposes 20 tools over JSON-RPC stdio. Claude Code and other AI agents can search the graph, get entity details, extract subgraphs, add notes, list sources, request refreshes, run git-aware alignment checks, and — opt-in via OLLAMA_BASE_URL — offload extraction, summarization, and page drafting to a local Ollama model. The server supports multi-Graph workspaces." ;
    <urn:reckons:story/highlight> kb:mcp-server ;
    <urn:reckons:story/title> "MCP Server" ;
    rdf:type <urn:reckons:story/Step> ;
    <urn:reckons:story/question> "Should I verify the MCP server tools are responding?" .

