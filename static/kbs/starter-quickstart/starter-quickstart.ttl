kb:ContentBasedFiltering
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    pred:strength "no cold-start for new items" ;
    <http://www.w3.org/2004/02/skos/core#broader> kb:RecommendationSystems ;
    pred:weakness "limited serendipity — only finds similar items" ;
    rdfs:label "Content-Based Filtering" ;
    <http://www.w3.org/2004/02/skos/core#definition> "Recommendations based on item attributes and user profile matching. No cold-start for items, but requires good feature engineering." .

kb:CollaborativeFiltering
    rdfs:label "Collaborative Filtering" ;
    <http://www.w3.org/2004/02/skos/core#broader> kb:RecommendationSystems ;
    <http://www.w3.org/2004/02/skos/core#definition> "Recommendation approach using user-item interaction patterns. Effective when interaction data is abundant." ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    pred:strength "works well with sparse item features" ;
    pred:weakness "cold-start problem for new users/items" .

