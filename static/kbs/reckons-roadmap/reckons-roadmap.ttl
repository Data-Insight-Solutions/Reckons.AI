<urn:reckons:story/rm-step-5>
    <urn:reckons:story/highlight> kb:collaborative-kb ;
    <urn:reckons:story/highlight> kb:read-only-guest ;
    rdf:type <urn:reckons:story/Step> ;
    <urn:reckons:story/highlight> kb:kb-publication ;
    <urn:reckons:story/order> "5"^^xsd:integer ;
    <urn:reckons:story/partOf> <urn:reckons:story/roadmap-tour> ;
    <urn:reckons:story/content> "The sharing roadmap progresses through three stages: F2 publishes graphs to GitHub Gist as static TTL files. F3 adds read-only guest views with a Fork button. F4 enables collaborative graphs where guests can propose statements. TTL is the protocol -- no accounts required." ;
    <urn:reckons:story/title> "Sharing & Collaboration (Planned)" .

<urn:reckons:story/rm-step-8>
    <urn:reckons:story/order> "8"^^xsd:integer ;
    <urn:reckons:story/title> "Private Cloud Sync" ;
    <urn:reckons:story/question> "Interested in how n8n connects to the enterprise roadmap?" ;
    <urn:reckons:story/content> "n8n provides self-hosted cloud sync with zero SaaS dependency. The Sync Hub stores graph snapshots via webhooks with content-hash deduplication. The Source Monitor watches URLs every 6 hours and queues pending notes when content changes. Private. Personalized. Perfection." ;
    rdf:type <urn:reckons:story/Step> ;
    <urn:reckons:story/highlight> kb:n8n-sync-hub ;
    <urn:reckons:story/highlight> kb:n8n-cloud-sync ;
    <urn:reckons:story/highlight> kb:n8n-source-monitor ;
    <urn:reckons:story/partOf> <urn:reckons:story/roadmap-tour> .

