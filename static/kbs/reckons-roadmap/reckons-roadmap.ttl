kb:n8n-currents-monitor
    rdfs:label "Currents Monitor" ;
    rdf:type <urn:kbase:type/Concept> ;
    pred:workflow-id "qb9uPZ8GScAmuUOX" ;
    pred:has-endpoint "/webhook/reckons-currents-items" ;
    pred:description "n8n workflow (extends the Source Monitor pattern) that fetches enabled Currents on a 30-minute schedule, respecting each current's own cadenceMinutes via a lastFetchedAt due-check. RSS/Atom currents use the RSS Read node; url-kind currents fetch-and-hash like Source Monitor, keyed by a content-hash-suffixed URL so a changed page produces a new item row. Dedupes items by (url, graphStableId) via the data table rowNotExists operation before insert, so re-running the sweep never creates duplicates. Exposes a register webhook (upsert current definitions) and an items webhook (pull new rows for a graph, optionally since a timestamp) for the Reckons.AI app." ;
    pred:relates-to kb:currents ;
    pred:has-endpoint "/webhook/reckons-currents-register" ;
    pred:relates-to kb:n8n-source-monitor ;
