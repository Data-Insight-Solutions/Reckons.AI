<urn:reckons:guide/Step5>
    rdf:type <urn:kbase:type/Document> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Click the turtle icon in the search bar to chat with Shelly. Ask questions about your graph, play the story walkthrough, or request a Reckoning." ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:guide/GettingStarted> ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:feature/Shelly> ;
    rdfs:label "Step 5: Ask Shelly" .

<urn:reckons:guide/Step4>
    <http://www.w3.org/2004/02/skos/core#definition> "Go to view (the home tab) to see your knowledge in 3D. Click nodes to select them, use the RadialMenu for actions, and use filters to focus. The graph tab manages your graphs: create, switch, rename, currents, and publishing." ;
    rdfs:label "Step 4: Explore the Graph" ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:guide/GettingStarted> ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:feature/Graph3D> ;
    rdf:type <urn:kbase:type/Document> .

<urn:reckons:creator/MatthewRoe>
    pred:role "Founder & Developer" ;
    pred:worksAt <urn:reckons:creator/DataInsightSolutions> ;
    rdf:type <urn:kbase:type/Person> ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:guide/ReckonsAI> ;
    rdfs:label "Matthew Roe" ;
    <http://www.w3.org/2004/02/skos/core#definition> "Owner-operator of Data Insight Solutions LLC and creator of Reckons.AI. Designed the local-first architecture, the human-in-the-loop review workflow, and the graph Leap cross-referencing system." .

<urn:reckons:story/HowItWorks>
    <urn:reckons:story/content> "Ingest a document. The LLM extracts facts as triples. You review and confirm them. Explore connections in your graph. Ask Shelly questions grounded in your knowledge. Export and share your .ttl file." ;
    <urn:reckons:story/order> "7" ;
    <urn:reckons:story/prompt> "Walk through each workflow step in detail." ;
    <urn:reckons:story/highlight> <urn:reckons:arch/ReviewWorkflow> ;
    <urn:reckons:story/partOf> <urn:reckons:story/ReckonsPhilosophy> ;
    rdf:type <urn:reckons:story/Step> ;
    <urn:reckons:story/title> "The Workflow" .

<urn:reckons:use/PersonalEmpowerment>
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:docs/leap/UseCases> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Build a graph of your rights, evidence, and correspondence. Communicate with the authority of an institution -- it is just you and your knowledge." ;
    rdfs:label "Power to the Individual" ;
    rdf:type <urn:kbase:type/Concept> .

<urn:reckons:story/StandingUp>
    <urn:reckons:story/title> "Level the Playing Field" ;
    <urn:reckons:story/question> "Is there a situation where having organized, citable evidence would help?" ;
    <urn:reckons:story/prompt> "Give examples of using a graph for insurance claims, disputes, or corporate pushback." ;
    <urn:reckons:story/order> "6" ;
    <urn:reckons:story/content> "Corporations have analysts and legal teams. You have your memory and a stack of papers. Not anymore. Build a graph of your policy terms, correspondence, and evidence. Ask Shelly to draft a response citing your documented facts. You communicate with the authority of an institution -- using your own knowledge." ;
    <urn:reckons:story/highlight> <urn:reckons:use/PersonalEmpowerment> ;
    rdf:type <urn:reckons:story/Step> ;
    <urn:reckons:story/partOf> <urn:reckons:story/ReckonsPhilosophy> .

<urn:reckons:feature/TrustSystem>
    <http://www.w3.org/2004/02/skos/core#definition> "Sources earn trust through consistent accuracy. Trusted sources auto-confirm." ;
    rdf:type <urn:kbase:type/Concept> ;
    rdfs:label "Source Trust System" ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:guide/WhatIsReckonsAI> .

<urn:reckons:arch/TripleArchitecture>
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:docs/leap/TriplesAndRDF> ;
    <http://www.w3.org/2004/02/skos/core#definition> "The fundamental unit of knowledge in RDF: subject - predicate - object. Any fact can be expressed as a triple. Triples connect to form a graph." ;
    rdfs:label "The Semantic Triple" ;
    rdf:type <urn:kbase:type/Concept> ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:guide/WhatIsReckonsAI> .

<urn:reckons:docs/leap/TriplesAndRDF>
    <urn:reckons:leap> "a1b2c3d4-e5f6-4a01-b001-000000000001" ;
    <urn:reckons:leap/label> "Triples, Turtle & RDF Standards" ;
    <urn:reckons:nav/next> <urn:reckons:docs/leap/LanguageModels> ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:guide/WhatIsReckonsAI> ;
    <urn:reckons:nav/order> "1"^^xsd:integer ;
    rdf:type <urn:kbase:type/KnowledgeBase> ;
    <urn:reckons:nav/layer> "1"^^xsd:integer ;
    <http://www.w3.org/2004/02/skos/core#definition> "Click to explore the semantic triple architecture, Turtle syntax, RDF standards (RDFS, SKOS, SPARQL, JSON-LD, PROV-O), and knowledge graph fundamentals." ;
    rdfs:label "LEAP: Triples & RDF Deep Dive" .

<urn:reckons:guide/WhatIsReckonsAI>
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:guide/WhyItMatters> ;
    <urn:reckons:nav/layer> "2"^^xsd:integer ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:arch/TripleArchitecture> ;
    rdfs:label "What Is Reckons.AI" ;
    <http://www.w3.org/2004/02/skos/core#definition> "Reckons.AI is a personal knowledge graph that runs entirely in your browser. No server, no account, no cloud dependency. Your data stays on your device in IndexedDB, and you control every piece of knowledge that enters your graph through a human review process." ;
    rdf:type <urn:kbase:type/Concept> .

<urn:reckons:creator/DataInsightSolutions>
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:creator/MatthewRoe> ;
    pred:operates <urn:reckons:guide/ReckonsAI> ;
    <http://www.w3.org/2004/02/skos/core#definition> "The company behind Reckons.AI. A software consultancy focused on knowledge management, data engineering, and AI-augmented tooling." ;
    rdfs:label "Data Insight Solutions LLC" ;
    rdf:type <urn:kbase:type/Organization> .

<urn:reckons:guide/WhyItMatters>
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:use/PersonalEmpowerment> ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:guide/WhatIsReckonsAI> ;
    rdf:type <urn:kbase:type/Concept> ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    <http://www.w3.org/2004/02/skos/core#definition> "In an era of information overload, Reckons.AI gives individuals a structured way to capture, verify, connect, and retrieve knowledge. It bridges the gap between human understanding and machine processing -- your knowledge becomes queryable, shareable, and portable." ;
    rdfs:label "Why Reckons.AI Matters" .

<urn:reckons:shelly/persona>
    <urn:reckons:shelly/greeting> "Hey! I'm Shelly, and this is the Reckons.AI documentation hub. The nodes with amber rings are **leap points** -- click the arrow to jump into a deeper sub-graph (auto-imports on first use). Try the **explore** tab for a guided walkthrough!" ;
    <urn:reckons:shelly/systemPrompt> "You are helping someone learn Reckons.AI. This is the documentation HUB -- a compact overview. Nodes labeled 'LEAP:' link to deeper sub-graphs (separate .ttl files). Emphasize practical uses, individual empowerment, and the accuracy advantage of graph-grounded LLM responses. Be honest about what LLMs can and cannot do. Encourage the user to build their own knowledge and never blindly trust any model output." ;
    <urn:reckons:shelly/responseStyle> "conversational" ;
    <urn:reckons:shelly/name> "Shelly" ;
    <urn:reckons:shelly/personality> "knowledgeable, empowering, direct" .

<urn:reckons:llm/WhatLLMsAre>
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:docs/leap/LanguageModels> ;
    rdfs:label "What Language Models Actually Are" ;
    <http://www.w3.org/2004/02/skos/core#definition> "Trained statistical models built with human knowledge. They predict text, not truth. Powerful tools, but tools -- not thinkers." ;
    rdf:type <urn:kbase:type/Concept> .

<urn:reckons:guide/OpenSource>
    rdf:type <urn:kbase:type/Concept> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Reckons.AI is MIT-licensed. Read the code, fork it, self-host it, run it offline forever. No proprietary lock-in, no subscription, no way to lose access to your own tool." ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:guide/WhatIsReckonsAI> ;
    rdfs:label "Open Source (MIT)" .

<urn:reckons:feature/Ingest>
    rdfs:label "Ingest" ;
    rdf:type <urn:kbase:type/Concept> ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:guide/WhatIsReckonsAI> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Add knowledge from text, URLs, documents, calendars, or Turtle files." .

<urn:reckons:arch/SubjectPredicateObject>
    rdf:type <urn:kbase:type/Concept> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Subject: the entity. Predicate: the relationship. Object: the value. Example: 'Alice worksAt AcmeCorp'." ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:arch/TripleArchitecture> ;
    rdfs:label "Subject - Predicate - Object" .

<urn:reckons:story/Intro>
    <urn:reckons:story/prompt> "Explain how the semantic diff works and why it saves time versus manual comparison." ;
    <urn:reckons:story/question> "Have you ever re-read a long document just to find what changed?" ;
    <urn:reckons:story/order> "1" ;
    <urn:reckons:story/title> "Spot What's New Instantly" ;
    rdf:type <urn:reckons:story/Step> ;
    <urn:reckons:story/content> "You receive a revised contract, an updated policy, a new report. What actually changed? Reckons.AI compares any document against your personal knowledge graph and shows you exactly what is new, what conflicts, and what you already know. No more re-reading entire documents to find the three sentences that matter." ;
    <urn:reckons:story/highlight> <urn:reckons:guide/WhatIsReckonsAI> ;
    <urn:reckons:story/partOf> <urn:reckons:story/ReckonsPhilosophy> .

<urn:reckons:llm/KBGroundedAccuracy>
    rdf:type <urn:kbase:type/Concept> ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:llm/WhatLLMsAre> ;
    <http://www.w3.org/2004/02/skos/core#definition> "When an LLM retrieves YOUR confirmed facts instead of guessing, accuracy skyrockets. Your curated graph is the best retrieval source possible." ;
    rdfs:label "Graph-Grounded Accuracy" .

<urn:reckons:kb>
    <urn:reckons:meta/kbStableId> "a1b2c3d4-e5f6-4a00-b000-000000000000" .

<urn:reckons:feature/Graph3D>
    <http://www.w3.org/2004/02/skos/core#definition> "Interactive force-directed graph in WebGL. Click, drag, filter, explore." ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:guide/WhatIsReckonsAI> ;
    rdfs:label "3D Knowledge Graph" ;
    rdf:type <urn:kbase:type/Concept> .

<urn:reckons:tip/StartSmall>
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:docs/leap/TipsSecurity> ;
    rdf:type <urn:kbase:type/Concept> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Begin with one document you care about. Connections emerge as you add sources." ;
    rdfs:label "Start Small" .

<urn:reckons:guide/Step6>
    rdf:type <urn:kbase:type/Document> ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:guide/GettingStarted> ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:feature/TTLExport> ;
    rdfs:label "Step 6: Export and Share" ;
    <http://www.w3.org/2004/02/skos/core#definition> "Go to Settings -> Backup and Export to download your graph as Turtle. Share the .ttl file or set up workspace sync for MCP integration." .

<urn:reckons:arch/ReviewWorkflow>
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:arch/TripleArchitecture> ;
    rdf:type <urn:kbase:type/Document> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Ingest -> Review -> Explore -> Ask Shelly -> Share. Human review at every step." ;
    rdfs:label "The Review Workflow" .

