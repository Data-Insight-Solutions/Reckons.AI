<urn:reckons:story/GetStarted>
    <urn:reckons:story/partOf> <urn:reckons:story/ReckonsPhilosophy> ;
    <urn:reckons:story/prompt> "Suggest concrete first steps for building a personal knowledge graph." ;
    <urn:reckons:story/order> "8" ;
    <urn:reckons:story/question> "Ready to add your first document?" ;
    <urn:reckons:story/content> "Your graph starts with one document. Ingest something you care about, review the triples, confirm the accurate ones. Every source you add reveals connections you would never see reading linearly." ;
    rdf:type <urn:reckons:story/Step> ;
    <urn:reckons:story/highlight> <urn:reckons:tip/StartSmall> ;
    <urn:reckons:story/title> "Start Building" .

<urn:reckons:story/ReckonsPhilosophy>
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    rdf:type <urn:kbase:type/Concept> ;
    <urn:reckons:story/autoplay> "false" ;
    <urn:reckons:story/pace> "40" ;
    rdfs:label "The Reckons.AI Story" ;
    <urn:reckons:story/description> "A guided walkthrough of why Reckons.AI exists, how it works, and what it means for you." ;
    rdf:type <urn:reckons:story/Story> .

<urn:reckons:story/PlainText>
    rdf:type <urn:reckons:story/Step> ;
    <urn:reckons:story/title> "Plain Text You Own" ;
    <urn:reckons:story/prompt> "Compare .ttl portability to proprietary note-taking apps." ;
    <urn:reckons:story/order> "3" ;
    <urn:reckons:story/content> "Your knowledge exports as a .ttl file -- plain text you can open in any editor, diff with git, or email. No vendor lock-in. When apps shut down, your knowledge survives." ;
    <urn:reckons:story/highlight> <urn:reckons:arch/PlainTextPortability> ;
    <urn:reckons:story/partOf> <urn:reckons:story/ReckonsPhilosophy> .

<urn:reckons:feature/LLMBackends>
    <http://www.w3.org/2004/02/skos/core#definition> "9 providers: Claude, OpenAI, Gemini, Ollama (local), OpenRouter, WASM (offline), Chrome AI, Manual paste, Mock. Per-task backend overrides available." ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:guide/WhatIsReckonsAI> ;
    rdf:type <urn:kbase:type/Concept> ;
    rdfs:label "LLM Backends" .

<urn:reckons:story/WhatLLMsReally>
    <urn:reckons:story/title> "AI Tools, Your Review" ;
    <urn:reckons:story/question> "Does knowing this change how you think about AI tools?" ;
    <urn:reckons:story/order> "4" ;
    rdf:type <urn:reckons:story/Step> ;
    <urn:reckons:story/partOf> <urn:reckons:story/ReckonsPhilosophy> ;
    <urn:reckons:story/prompt> "Explain what LLMs can and cannot do, and why human review matters." ;
    <urn:reckons:story/highlight> <urn:reckons:llm/WhatLLMsAre> ;
    <urn:reckons:story/content> "Language models extract facts from documents, but they can hallucinate. That is why every extracted triple goes through YOUR review. You confirm, reject, or refine. The model does the heavy lifting; you keep it honest." .

<urn:reckons:feature/Reckoning>
    <http://www.w3.org/2004/02/skos/core#definition> "Situation-Target-Proposal: structured reasoning over your verified facts." ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:guide/WhatIsReckonsAI> ;
    rdfs:label "A Reckoning (STP)" ;
    rdf:type <urn:kbase:type/Concept> .

<urn:reckons:guide/Step3>
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:feature/ReviewSystem> ;
    rdf:type <urn:kbase:type/Document> ;
    rdfs:label "Step 3: Review Pending Statements" ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:guide/GettingStarted> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Go to Review to see extracted triples. Confirm accurate ones, reject incorrect ones, refine those that need adjustment." .

<urn:reckons:feature/TTLExport>
    <http://www.w3.org/2004/02/skos/core#definition> "Export your graph as .ttl with full metadata. Roundtrip-safe. Share with anyone." ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:guide/WhatIsReckonsAI> ;
    rdfs:label "Turtle Export" ;
    rdf:type <urn:kbase:type/Concept> .

<urn:reckons:story/TriplesPower>
    <urn:reckons:story/highlight> <urn:reckons:arch/SubjectPredicateObject> ;
    <urn:reckons:story/partOf> <urn:reckons:story/ReckonsPhilosophy> ;
    <urn:reckons:story/title> "Your Personal Context" ;
    <urn:reckons:story/content> "Every fact you confirm becomes part of YOUR knowledge graph. 'Policy covers water-damage'. 'Contract expires July 1st'. 'Landlord agreed to repairs on March 5th'. This is your personal context -- structured, searchable, and portable. When new information arrives, it is compared against what you already know." ;
    rdf:type <urn:reckons:story/Step> ;
    <urn:reckons:story/order> "2" ;
    <urn:reckons:story/prompt> "Give examples of personal facts as triples and how they connect to reveal insights." ;
    <urn:reckons:story/question> "What facts from your own life would be most useful to have structured?" .

<urn:reckons:guide/QuickStartExample>
    rdfs:label "Quick-Start Example graph" ;
    rdf:type <urn:kbase:type/Document> ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:guide/GettingStarted> ;
    <http://www.w3.org/2004/02/skos/core#definition> "A practical knowledge graph with people, projects, research notes, decisions, and metrics. Import it from the Info page to see how real-world data maps to triples. 15 entities, 90 triples." ;
    dc:source "/starter-quickstart.ttl" .

<urn:reckons:guide/Step1>
    <http://www.w3.org/2004/02/skos/core#definition> "Go to Settings and configure at least one LLM provider. Ollama (free, local) or OpenRouter (free tier) are good starting points." ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:feature/LLMBackends> ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:guide/GettingStarted> ;
    rdfs:label "Step 1: Choose an LLM Backend" ;
    rdf:type <urn:kbase:type/Document> .

