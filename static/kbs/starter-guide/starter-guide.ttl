    rdf:type <urn:kbase:type/Person> ;
    <http://www.w3.org/2004/02/skos/core#definition> "The turtle-shaped AI assistant. Grounded in your graph, not generic training data." ;
    rdfs:label "Shelly (AI Assistant)" ;
