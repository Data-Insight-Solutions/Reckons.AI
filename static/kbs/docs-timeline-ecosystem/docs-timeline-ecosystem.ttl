<urn:reckons:timeline/SemanticWebVision>
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:timeline/OWL10> ;
    pred:date "2001-05-17"^^xsd:date ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    rdf:type <urn:kbase:type/Concept> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Tim Berners-Lee, James Hendler, and Ora Lassila published 'The Semantic Web' in Scientific American, describing a future web where machines understand meaning — not just display pages. This article launched a global research movement." ;
    rdfs:label "Semantic Web Vision (Scientific American)" ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:person/TimBernersLee> .

<urn:reckons:org/ApacheJena>
    rdf:type <urn:kbase:type/Organization> ;
    <http://www.w3.org/2004/02/skos/core#definition> "An open-source Java framework for building Semantic Web and Linked Data applications. Includes a SPARQL engine (ARQ), a triple store (TDB), and a rule-based reasoner." ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:topic/SPARQL> ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    rdfs:label "Apache Jena" .

<urn:reckons:timeline/OWL10>
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:timeline/SPARQL10> ;
    pred:date "2004-02-10"^^xsd:date ;
    pred:publishedBy <urn:reckons:org/W3C> ;
    rdf:type <urn:kbase:type/Concept> ;
    rdfs:label "OWL 1.0 (Web Ontology Language)" ;
    <http://www.w3.org/2004/02/skos/core#definition> "W3C Recommendation for expressing rich ontologies: class hierarchies, cardinality constraints, equivalences. Built on RDF. Enables automated reasoning about domain knowledge." .

<urn:reckons:timeline/KnowledgeGraphsAndLLMs>
    <http://www.w3.org/2004/02/skos/core#definition> "The convergence of structured knowledge graphs with large language models. LLMs can extract triples from text (what Reckons.AI does), query graphs in natural language, and ground their answers in verified facts. This synergy addresses both LLM hallucination and the knowledge graph population bottleneck." ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:guide/WhatIsReckonsAI> ;
    pred:date "2023-01-01"^^xsd:date ;
    rdf:type <urn:kbase:type/Concept> ;
    rdfs:label "Knowledge Graphs Meet LLMs" ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> .

<urn:reckons:timeline/LinkedDataPrinciples>
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:topic/LinkedData> ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:timeline/DBpediaLaunch> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Tim Berners-Lee's four rules: (1) Use URIs as names. (2) Use HTTP URIs so people can look them up. (3) Provide useful RDF information at those URIs. (4) Include links to other URIs for discovery. Published as a Design Issues note." ;
    pred:date "2006-07-27"^^xsd:date ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:person/TimBernersLee> ;
    rdfs:label "Linked Data Principles" ;
    rdf:type <urn:kbase:type/Concept> .

<urn:reckons:timeline/ReckonsAILaunch>
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:timeline/KnowledgeGraphsAndLLMs> ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    pred:createdBy <urn:reckons:person/MatthewRoe> ;
    rdf:type <urn:kbase:type/Concept> ;
    pred:date "2026-06-01"^^xsd:date ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:guide/WhatIsReckonsAI> ;
    rdfs:label "Reckons.AI Launch" ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:org/DataInsightSolutions> ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:timeline/MCPSpec> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Public launch of Reckons.AI -- a local-first personal knowledge graph built on RDF Turtle. Created by Matthew Roe at Data Insight Solutions LLC. Runs entirely in the browser. LLM-powered triple extraction, 3D graph visualization, browser extension for research sessions, and MCP server for AI agent integration." .

<urn:reckons:timeline/WikidataLaunch>
    rdfs:label "Wikidata Launch" ;
    <urn:reckons:leap/label> "Wikidata" ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:timeline/DBpediaLaunch> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Wikimedia's free knowledge graph. Over 100 million items, all queryable via SPARQL. The largest collaboratively edited knowledge graph in the world. Powers infoboxes across all Wikipedia language editions." ;
    pred:date "2012-10-29"^^xsd:date ;
    <urn:reckons:leap> "https://www.wikidata.org" ;
    rdf:type <urn:kbase:type/Concept> ;
    pred:publishedBy "Wikimedia Foundation" .

