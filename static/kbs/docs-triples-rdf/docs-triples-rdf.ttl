<urn:reckons:topic/TurtlePrefix>
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:topic/Turtle> ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    rdfs:label "@prefix Declaration" ;
    rdf:type <urn:kbase:type/Concept> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Declares a short alias for a namespace IRI. Example: @prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> . Prefixes make Turtle readable -- without them every IRI needs full angle-bracket notation." .

<urn:reckons:arch/IRI>
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:arch/TripleArchitecture> ;
    <http://www.w3.org/2004/02/skos/core#definition> "A globally unique identifier for a resource. IRIs are the names of things in RDF -- like URLs but for any concept, not just web pages. Example: urn:reckons:guide/WhatIsReckonsAI" ;
    rdf:type <urn:kbase:type/Concept> ;
    rdfs:label "IRI (Identifier)" ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> .

<urn:reckons:arch/ReviewWorkflow>
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:feature/Ingest> ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:arch/TripleArchitecture> ;
    <http://www.w3.org/2004/02/skos/core#definition> "1. Ingest -- paste text, upload documents, import calendars. 2. Review -- the LLM extracts triples, you confirm or reject each one. 3. Explore -- navigate your 3D knowledge graph. 4. Ask Shelly -- get answers grounded in your confirmed facts. 5. Share -- export your .ttl." ;
    rdfs:label "The Review Workflow" ;
    rdf:type <urn:kbase:type/Document> ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:feature/ReviewSystem> .

<urn:reckons:arch/SubjectPredicateObject>
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:arch/TripleArchitecture> ;
    rdfs:label "Subject - Predicate - Object" ;
    <http://www.w3.org/2004/02/skos/core#definition> "Subject: the entity being described (always an IRI). Predicate: the relationship or property (always an IRI). Object: the value or target (an IRI or a literal string/number/date). Example: 'Alice worksAt AcmeCorp'. Example: 'Policy covers water-damage'." ;
    rdf:type <urn:kbase:type/Concept> ;
    <http://www.w3.org/2004/02/skos/core#example> "In 'Earth orbits Sun', Earth=subject, orbits=predicate, Sun=object." ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> .

<urn:reckons:topic/SPARQL>
    rdfs:label "SPARQL" ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:topic/RDF> ;
    rdf:type <urn:kbase:type/Concept> ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    <http://www.w3.org/2004/02/skos/core#definition> "The query language for RDF graphs. Like SQL for relational databases, but for triple stores. Example: SELECT ?name WHERE { ?person foaf:name ?name }" .

<urn:reckons:topic/Turtle>
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    rdfs:label "Turtle (.ttl) Syntax" ;
    rdf:type <urn:kbase:type/Document> ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:arch/TripleArchitecture> ;
    <http://www.w3.org/2004/02/skos/core#definition> "A compact, human-readable syntax for writing RDF triples. File extension: .ttl. Uses prefix declarations, semicolons to share subjects, commas to share predicates, and periods to end statement groups. This file is itself written in Turtle." .

<urn:reckons:arch/KnowledgeGraph>
    <http://www.w3.org/2004/02/skos/core#definition> "A graph-structured database where entities are nodes and relationships are edges. Multiple triples form a graph. The same subject can appear in many triples, creating a web of connected knowledge." ;
    <http://www.w3.org/2004/02/skos/core#note> "Reckons.AI renders your knowledge graph as an interactive 3D force-directed graph." ;
    rdfs:label "Knowledge Graph" ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:arch/TripleArchitecture> ;
    rdf:type <urn:kbase:type/Concept> .

<urn:reckons:topic/TurtleComma>
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:topic/Turtle> ;
    <http://www.w3.org/2004/02/skos/core#definition> "In Turtle, a comma separates objects that share the same subject and predicate. Example: ex:Earth ex:hasOcean ex:Pacific , ex:Atlantic , ex:Indian ." ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    rdf:type <urn:kbase:type/Concept> ;
    rdfs:label "Comma (,) -- Same Subject and Predicate" .

<urn:reckons:arch/Provenance>
    rdf:type <urn:kbase:type/Concept> ;
    rdfs:label "Provenance" ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:arch/TripleArchitecture> ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:feature/TrustSystem> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Every triple in Reckons.AI carries its source. You always know where a fact came from, how trusted that source is, and when it was added. Metadata about metadata -- this is what makes a graph trustworthy." ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> .

<urn:reckons:arch/TripleArchitecture>
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:guide/WhatIsReckonsAI> ;
    rdfs:label "The Semantic Triple" ;
    <http://www.w3.org/2004/02/skos/core#definition> "The fundamental unit of knowledge in RDF: a three-part statement -- subject, predicate, object. Any fact expressible in human language can be expressed as a triple. Triples connect to form a graph, and graphs reveal relationships that documents hide." ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    rdf:type <urn:kbase:type/Concept> .

<urn:reckons:topic/TurtleSemicolon>
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:topic/Turtle> ;
    rdfs:label "Semicolon (;) -- Same Subject" ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    <http://www.w3.org/2004/02/skos/core#definition> "In Turtle, a semicolon separates predicate-object pairs that share the same subject. Example: ex:Earth rdf:type ex:Planet ; ex:orbits ex:Sun ." ;
    rdf:type <urn:kbase:type/Concept> .

<urn:reckons:docs/nav/BackToHub>
    rdf:type <urn:kbase:type/KnowledgeBase> ;
    <urn:reckons:leap> "a1b2c3d4-e5f6-4a00-b000-000000000000" ;
    rdfs:label "Back to Documentation Hub" ;
    <urn:reckons:leap/label> "Documentation Hub" ;
    <http://www.w3.org/2004/02/skos/core#definition> "Return to the main documentation hub with all leap nodes and the Reckons.AI story." .

<urn:reckons:arch/Literal>
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    <http://www.w3.org/2004/02/skos/core#definition> "A data value in RDF: a string, number, date, or boolean. Literals can have a language tag (@en) or a datatype IRI (^^xsd:integer). Example: '42'^^xsd:integer is a typed literal." ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:arch/TripleArchitecture> ;
    rdfs:label "Literal Values" ;
    rdf:type <urn:kbase:type/Concept> .

<urn:reckons:topic/LinkedData>
    <http://www.w3.org/2004/02/skos/core#definition> "Tim Berners-Lee's principles for publishing data on the web: use IRIs, use HTTP, provide useful RDF, and link to other datasets." ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:topic/RDF> ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    rdf:type <urn:kbase:type/Concept> ;
    rdfs:label "Linked Data" .

<urn:reckons:topic/JSONLD>
    rdfs:label "JSON-LD" ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    <http://www.w3.org/2004/02/skos/core#definition> "JSON-based serialization for RDF. Embeds linked data in standard JSON using a @context object. Popular for web APIs." ;
    rdf:type <urn:kbase:type/Concept> ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:topic/RDF> ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:topic/Turtle> .

<urn:reckons:arch/PlainTextPortability>
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:arch/TripleArchitecture> ;
    rdf:type <urn:kbase:type/Concept> ;
    rdfs:label "Plain Text Portability" ;
    <http://www.w3.org/2004/02/skos/core#definition> "Your knowledge graph exports as a .ttl file -- plain text, human-readable, no proprietary format. You can open it in any text editor, diff it with git, email it, or print it. When apps shut down and formats die, your .ttl file will still work. It is the most durable way to store knowledge." ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    <http://www.w3.org/2004/02/skos/core#note> "Any RDF tool (SPARQL endpoints, Protege, PoolParty, Neo4j, Python's rdflib) can read your .ttl file directly." .

<urn:reckons:topic/PROVO>
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:topic/RDF> ;
    <http://www.w3.org/2004/02/skos/core#definition> "A W3C vocabulary for expressing provenance: who created something, when, and from what sources. Reckons.AI uses prov:wasDerivedFrom to link statements to their source." ;
    rdf:type <urn:kbase:type/Concept> ;
    <http://www.w3.org/2004/02/skos/core#related> <urn:reckons:arch/Provenance> ;
    rdfs:label "PROV-O (Provenance Ontology)" .

<urn:reckons:topic/TurtlePeriod>
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:topic/Turtle> ;
    rdf:type <urn:kbase:type/Concept> ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    rdfs:label "Period (.) -- End of Statement Group" ;
    <http://www.w3.org/2004/02/skos/core#definition> "A period terminates a group of triples about the same subject." .

<urn:reckons:shelly/persona>
    <urn:reckons:shelly/greeting> "Welcome to the Triples and RDF documentation! I can explain semantic triples, Turtle syntax, or any RDF standard. Ask away!" ;
    <urn:reckons:shelly/name> "Shelly" ;
    <urn:reckons:shelly/systemPrompt> "You are helping someone learn about RDF, Turtle syntax, and semantic triples. Give clear examples. Use the entities in this graph as reference material." ;
    <urn:reckons:shelly/responseStyle> "concise" ;
    <urn:reckons:shelly/personality> "precise, educational, thorough" .

<urn:reckons:topic/SKOS>
    rdf:type <urn:kbase:type/Concept> ;
    rdfs:label "SKOS (Simple Knowledge Organization System)" ;
    <http://www.w3.org/2004/02/skos/core#definition> "A vocabulary for taxonomies and concept hierarchies using skos:broader, skos:narrower, skos:related. This documentation file uses SKOS to organize concepts." ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:topic/RDF> ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> .

<urn:reckons:arch/Reification>
    rdf:type <urn:kbase:type/Concept> ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:arch/TripleArchitecture> ;
    <http://www.w3.org/2004/02/skos/core#definition> "Making a statement about a statement. In RDF, reification assigns an IRI to a triple so it can be annotated with provenance, confidence, or temporal bounds. Reckons.AI uses reification in its TTL export format." ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    rdfs:label "Reification" .

<urn:reckons:topic/RDF>
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:arch/TripleArchitecture> ;
    <http://www.w3.org/2004/02/skos/core#definition> "A W3C standard for representing knowledge as a graph of linked statements. The foundation of the Semantic Web. RDF itself is abstract -- Turtle, JSON-LD, and RDF/XML are concrete serialization formats." ;
    rdfs:label "RDF (Resource Description Framework)" ;
    rdf:type <urn:kbase:type/Concept> ;
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> .

<urn:reckons:topic/RDFS>
    rdf:type <http://www.w3.org/2004/02/skos/core#Concept> ;
    rdfs:label "RDF Schema (RDFS)" ;
    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:topic/RDF> ;
    <http://www.w3.org/2004/02/skos/core#definition> "A vocabulary for describing classes and properties: rdfs:Class, rdfs:subClassOf, rdfs:domain, rdfs:range, rdfs:label, rdfs:comment. Reckons.AI uses rdfs:label for human-readable entity names." ;
    rdf:type <urn:kbase:type/Concept> .

