    <http://www.w3.org/2004/02/skos/core#broader> <urn:reckons:test/VisualTests> .

<urn:reckons:test/GraphReview-Step4>
    pred:page "/review" ;
    rdf:type <urn:reckons:story/Step> ;
    pred:icon2d "/tests/visual/screenshots/graph-review/04-review-visual-check.png" ;
    pred:assertion "pixel.isSolidFill === false" ;
    <urn:reckons:story/content> "On each screen run the offline pixel, DOM-overlap and touch-target checks — no blank/solid-fill, targets at least 44px — before any VLM scoring. Cheapest checks first, no API keys." ;
    <urn:reckons:story/order> "4"^^xsd:integer ;
    <urn:reckons:story/partOf> <urn:reckons:test/GraphReviewFlow> ;
    <urn:reckons:story/title> "Visual check, locally" .

<urn:reckons:shelly/persona>
    <urn:reckons:shelly/responseStyle> "concise" ;
    <urn:reckons:shelly/personality> "methodical, visual, precise" ;
    <urn:reckons:shelly/name> "Shelly" ;
    <urn:reckons:shelly/greeting> "This is the test documentation! I can walk you through any test story step-by-step, show you screenshots, or explain the test infrastructure. The Dev Sprint story is a great place to start!" ;
    <urn:reckons:shelly/systemPrompt> "You are helping someone understand the Reckons.AI test suite. Walk through stories in order, reference screenshots, and explain what each step verifies. The stories are ordered — follow the sequence." .

