## =============================================================================
## Core Workflow
## =============================================================================

feat:Ingest
    rdf:type            ktype:Concept ;
    rdfs:label          "Ingest" ;
    skos:definition     "Add knowledge from text, URLs, documents, calendars, iCal feeds, Indico events, or Turtle files. An LLM extracts semantic triples from unstructured input. Every extracted triple starts as pending for your review." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:ReviewSystem
    rdf:type            ktype:Concept ;
    rdfs:label          "Review System" ;
    skos:definition     "Three tabs: Incoming (new triples), Deletions (removal proposals), Merges (duplicate entity suggestions). Confirm, reject, or refine each statement. Nothing enters your KB without your approval." ;
    skos:broader        guide:WhatIsReckonsAI ;
    skos:related        feat:TrustSystem .

feat:TrustSystem
    rdf:type            ktype:Concept ;
    rdfs:label          "Source Trust System" ;
    skos:definition     "Sources accumulate trust scores based on your review decisions. Trusted sources can be auto-confirmed. A time-decay formula prevents stale trust from persisting." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:Graph3D
    rdf:type            ktype:Concept ;
    rdfs:label          "3D / 2D Knowledge Graph" ;
    skos:definition     "Interactive force-directed graph in WebGL (3D) or Canvas (2D fallback). Per-entity icons from urn:kbase:predicate/icon2d statements with emoji fallback. Label overlap prevention sorts by degree and hides collisions. Hub emphasis, layout modes (force/focus/source/type/hub), filter chips." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:Shelly
    rdf:type            ktype:Person ;
    rdfs:label          "Shelly (AI Assistant)" ;
    skos:definition     "The turtle-shaped AI assistant. Three tabs: tutorial, chat (grounded in your KB), and explore (guided story tours). Each KB can embed its own Shelly persona via the shelly: vocabulary. Supports Whisper STT voice input and Kokoro TTS voice output." ;
    skos:broader        guide:WhatIsReckonsAI ;
    skos:related        feat:WhisperSTT ;
    skos:related        feat:KokoroTTS .

feat:Reckoning
    rdf:type            ktype:Concept ;
    rdfs:label          "Reckoning (STP)" ;
    skos:definition     "Situation-Target-Proposal: describe your situation, state your goal, and the AI synthesizes options grounded ONLY in your confirmed triples. Every option cites its sources." ;
    skos:broader        guide:WhatIsReckonsAI .


## =============================================================================
## Comparison & Diff
## =============================================================================

feat:Compare
    rdf:type            ktype:Concept ;
    rdfs:label          "Compare / Diff Engine" ;
    skos:definition     "Compare two knowledge bases or snapshots at /compare. Diff engine categorizes changes as Add, Reinforce, Conflict, Merge, Remove. Visual Venn diagram and diff table with bulk accept/reject." ;
    skos:broader        guide:WhatIsReckonsAI ;
    skos:related        feat:DiffSummary .

feat:DiffSummary
    rdf:type            ktype:Concept ;
    rdfs:label          "Diff Summary" ;
    skos:definition     "LLM-generated 3-part summaries of diffs: what is new, what reinforces existing knowledge, and what conflicts. Integrated in /compare, /review, and the browser extension sidepanel." ;
    skos:broader        feat:Compare .


## =============================================================================
## Multi-KB & Navigation
## =============================================================================

feat:MultiKB
    rdf:type            ktype:Concept ;
    rdfs:label          "Multi-KB Management" ;
    skos:definition     "Create, switch, rename, and delete independent knowledge bases. Each KB has its own IndexedDB store, stable UUID, content fingerprint, and optional accent color. Per-tab KB support via URL ?kb= parameter." ;
    skos:broader        guide:WhatIsReckonsAI ;
    skos:related        feat:KBLeap .

feat:KBLeap
    rdf:type            ktype:Concept ;
    rdfs:label          "KB Leap" ;
    skos:definition     "Cross-reference entities between KBs. A leap node stores a target (KB stable ID, app path, or URL) as an ordinary RDF triple. Nodes with leaps show an amber ring. Click to jump to the target KB, navigate within the app, or open an external URL. Docs sub-graphs auto-import on first click." ;
    skos:broader        feat:MultiKB .

feat:KBIdentity
    rdf:type            ktype:Concept ;
    rdfs:label          "KB Identity" ;
    skos:definition     "Each KB has a stable UUID (never changes, used for MCP routing and KB Leap) and a content fingerprint (SHA-256 of sorted N-Quads, changes with every edit). Both visible in Settings." ;
    skos:broader        feat:MultiKB .


## =============================================================================
## Knowledge Management
## =============================================================================

feat:PredicateManager
    rdf:type            ktype:Concept ;
    rdfs:label          "Predicate Manager" ;
    skos:definition     "View all predicates in your KB with usage counts. Rename predicates across all statements or merge two predicates into one. Accessible from the KB page." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:Disambiguation
    rdf:type            ktype:Concept ;
    rdfs:label          "Disambiguation" ;
    skos:definition     "Automatic detection of duplicate or similar entities using text embeddings and cosine similarity. Suggests merges for your review in the Merges tab." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:EntityTypes
    rdf:type            ktype:Concept ;
    rdfs:label          "Entity Type System" ;
    skos:definition     "Categorize entities (Person, Place, Concept, Tool, Document, Organization, Event) with custom colors and 3D shapes. Types assigned via rdf:type statements." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:HistoryMode
    rdf:type            ktype:Concept ;
    rdfs:label          "History Mode" ;
    skos:definition     "Time-travel through your KB at /history. Scrub a timeline to see the graph at any past point. All mutations are logged in the changelog." ;
    skos:broader        guide:WhatIsReckonsAI .


## =============================================================================
## LLM & Voice
## =============================================================================

feat:LLMBackends
    rdf:type            ktype:Concept ;
    rdfs:label          "LLM Backends" ;
    skos:definition     "9 providers: Claude, OpenAI, Gemini, Ollama (local), OpenRouter (free tier), WASM (offline, SmolLM2-360M), Chrome AI (Gemini Nano), Manual paste, Mock. Per-task backend overrides let you use different providers for ingest, chat, analysis, diff summary, and merge analysis." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:WhisperSTT
    rdf:type            ktype:Concept ;
    rdfs:label          "Whisper STT" ;
    skos:definition     "Local speech-to-text via transformers.js using whisper-tiny (42MB). Mic button in the chat tab. Runs entirely in-browser -- no cloud, no API key." ;
    skos:broader        feat:Shelly .

feat:KokoroTTS
    rdf:type            ktype:Concept ;
    rdfs:label          "Kokoro TTS" ;
    skos:definition     "Local text-to-speech for story walkthroughs. 82M model cached in browser. Falls back to browser speech synthesis if unavailable." ;
    skos:broader        feat:Shelly .


## =============================================================================
## Safety & Export
## =============================================================================

feat:ContentSafety
    rdf:type            ktype:Concept ;
    rdfs:label          "Content Safety" ;
    skos:definition     "Ethics preamble injected into ALL LLM system prompts. Content classifier with two levels: blocked (filtered out on ingest) and mature (flagged on export with advisory). Discourse, disagreement, and academic content pass freely." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:PassageGrounding
    rdf:type            ktype:Concept ;
    rdfs:label          "Passage Grounding" ;
    skos:definition     "Verbatim source excerpts attached to extracted triples. LLM prompt rule requests the exact source sentence. Persists via meta:excerpt in TTL reification. Displayed in StatementCard and DiffEntry." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:TTLExport
    rdf:type            ktype:Concept ;
    rdfs:label          "Turtle Export" ;
    skos:definition     "Export your KB as a .ttl file with full reification metadata (status, source, confidence, timestamps, excerpts). Roundtrip-safe. Clean export for interop or full export with all metadata." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:ModelCache
    rdf:type            ktype:Concept ;
    rdfs:label          "Model Cache Management" ;
    skos:definition     "Inspect, sideload, and purge locally cached WASM models. Manifests for SmolLM2-360M (370MB), MiniLM-L6-v2 (22MB), Kokoro 82M (88MB), Whisper Tiny (42MB). Settings > Integrations > local model cache." ;
    skos:broader        feat:LLMBackends .


## =============================================================================
## Cross-KB & Alignment
## =============================================================================

feat:CrossKBAlignment
    rdf:type            ktype:Concept ;
    rdfs:label          "Cross-KB Alignment" ;
    skos:definition     "Align entities across knowledge bases. Entity matching via exact IRI match and embedding similarity. IRI remapping for entities that represent the same concept across KBs. Align tab in review page. KbPicker selects source KB, AlignmentCard shows each match with accept/reject." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:SourceRefresh
    rdf:type            ktype:Concept ;
    rdfs:label          "Source Refresh" ;
    skos:definition     "Generic refresh for url, repository, and calendar sources. Auto-refresh on open and on interval (configurable). KB page refresh button. MCP tools: kb_list_sources and kb_request_refresh. Delta comparison shows what changed since last ingest." ;
    skos:broader        guide:WhatIsReckonsAI .

feat:SourceMonitoring
    rdf:type            ktype:Concept ;
    rdfs:label          "Source Monitoring" ;
    skos:definition     "Watch URLs for content changes. The n8n Source Monitor workflow checks every 6 hours, detects diffs via content hash, and queues pending notes for review. Surfaces via /webhook/reckons-kb-pending endpoint." ;
    skos:broader        feat:SourceRefresh .


## =============================================================================
## Context Compression
## =============================================================================

feat:ContextCompression
    rdf:type            ktype:Concept ;
    rdfs:label          "Context Compression" ;
    skos:definition     "Condense your context. Keep the meaning. Knowledge graphs are dense by nature — a page of prose becomes a handful of triples. Semantic meaning preserved, tokens reduced. Feed compressed KB directly to AI agents via MCP. Structured triples outperform summaries because no relationships are paraphrased away." ;
    skos:broader        guide:WhatIsReckonsAI ;
    kpred:has-tool      "kb_compress" ;
    kpred:has-param     "query (required) — topic to extract context for" ;
    kpred:has-param     "budget (default 2000, max 8000) — approximate token budget" ;
    kpred:has-param     "hops (default 1, max 2) — neighbourhood expansion depth" ;
    kpred:has-param     "kb — target a specific knowledge base" .


## =============================================================================
## Entity Normalisation
## =============================================================================

feat:EntityNormalisation
    rdf:type            ktype:Concept ;
    rdfs:label          "Entity Normalisation" ;
    skos:definition     "Post-extraction normalisation that rewrites incoming IRIs to match existing KB entities and predicates using embedding similarity. Prevents duplicate entities like 'octopus-vulgaris' vs 'common-octopus' from entering the review queue. Two-pass matching: exact label (case-insensitive) then cosine similarity (0.90 entity, 0.88 predicate). Protected standard vocabularies (rdf:, rdfs:, skos:, xsd:) are never remapped." ;
    skos:broader        feat:Ingest ;
    skos:related        feat:Disambiguation .


## =============================================================================
## MCP Workspace (Self-Dogfooding)
## =============================================================================

feat:MCPWorkspace
    rdf:type            ktype:Concept ;
    rdfs:label          "MCP Workspace" ;
    skos:definition     "Reckons.AI uses its own MCP server to track product state. Three internal KBs (Roadmap, Production, Features) are symlinked from static/*.ttl into mcp-workspace/kbs/. Claude Code queries these KBs before planning work. Edit a TTL file and the MCP server auto-reloads. Setup: bash scripts/setup-mcp-workspace.sh." ;
    skos:broader        guide:WhatIsReckonsAI .


## =============================================================================
## Stories & Persona
## =============================================================================

feat:StorySystem
    rdf:type            ktype:Concept ;
    rdfs:label          "Story System" ;
    skos:definition     "Guided walkthroughs defined as triples using the story: vocabulary. Steps can highlight entities, trigger prompts, and pose questions. Playback with countdown timer and TTS. Shareable via .ttl files." ;
    skos:broader        feat:Shelly .

feat:TurtlePersona
    rdf:type            ktype:Concept ;
    rdfs:label          "Persona System" ;
    skos:definition     "Each KB can embed its own AI assistant personality using the shelly: vocabulary. A work KB might have a direct, technical persona while a personal KB has a calm guide. Persona travels with the .ttl file." ;
    skos:broader        feat:Shelly .


## =============================================================================
## Git Analysis (F24)
## =============================================================================

feat:GitAnalysis
    rdf:type            ktype:Feature ;
    rdfs:label          "Git Analysis" ;
    skos:definition     "Git-aware MCP tools for agent plan alignment. Tools: kb_git_status (branch/commits), kb_check_plan (BM25 drift detection), kb_pending (review queue), kb_git_diff_triples (file-to-KB cross-ref), kb_alignment_score (quantitative 0-1 score across 4 dimensions: coverage, status alignment, dependency respect, scope discipline). Enhanced kb_add_note supports type, priority, agent, and commit_sha metadata." ;
    skos:broader        feat:MCPWorkspace .


## =============================================================================
## Persona
## =============================================================================

@prefix shelly: <urn:reckons:shelly/> .

shelly:persona
    shelly:name             "Shelly" ;
    shelly:greeting         "This is the Features documentation! I can explain any Reckons.AI feature in detail -- Ingest, Review, Compare, Multi-KB, Leap, Shelly, Reckonings, Content Safety, and more. What would you like to know?" ;
    shelly:personality      "knowledgeable, enthusiastic, practical" ;
    shelly:responseStyle    "concise" ;
    shelly:systemPrompt     "You are helping someone learn about Reckons.AI features. Explain how each feature works and give practical usage tips. Reference the feature entities in this KB." .
