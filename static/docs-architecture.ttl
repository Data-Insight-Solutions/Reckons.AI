## =============================================================================
## Data & State Architecture
## =============================================================================

arch:LocalFirstArch
    rdf:type            ktype:Concept ;
    rdfs:label          "Local-First Architecture" ;
    skos:definition     "All user data lives in browser IndexedDB (Dexie v4). No server, no accounts, no cloud dependency. The app is a static SvelteKit build. Export to .ttl for portability. Workspace folder sync for disk backup and MCP server access." ;
    skos:broader        guide:WhatIsReckonsAI .

arch:WorkspaceFolderDesign
    rdf:type            ktype:Concept ;
    rdfs:label          "Workspace Folder Design" ;
    skos:definition     "User-selected directory via File System Access API (Chrome/Edge only). Structure: knowledge.ttl (legacy single-KB), kbs/{name}/kb.ttl + meta.json + sources.json (multi-KB), knowledge.pending.jsonl (MCP inbox), settings_profile.json. Auto-exports on every KB mutation (2s debounce)." ;
    skos:broader        arch:LocalFirstArch ;
    skos:related        feat:MultiKB .

arch:PendingJsonlQueue
    rdf:type            ktype:Concept ;
    rdfs:label          "Pending JSONL Queue" ;
    skos:definition     "Append-only JSONL file (pending.jsonl) serves as message queue between MCP server/CLI tools and the web app. Entries carry subject, predicate, object, type, priority, agent, commitSha metadata. Web app drains on load or manual trigger, converts to pending statements for human review, then clears the file. JSONL chosen over TTL for this role because: atomic line-append is safe for concurrent writes, rich metadata is native JSON, parse cost is trivial, drain-and-clear is a queue pattern not a knowledge pattern." ;
    skos:broader        arch:WorkspaceFolderDesign .

arch:StaticDeployment
    rdf:type            ktype:Concept ;
    rdfs:label          "Static Deployment" ;
    skos:definition     "SvelteKit adapter-static produces a pure client-side build. No server-side runtime in production. Deployable to any static host (Netlify, Vercel, GitHub Pages, local file server). Vite dev server provides HMR during development only." ;
    skos:broader        arch:LocalFirstArch .


## =============================================================================
## Standards Alignment (PROV-O, SKOS, RDF)
## =============================================================================

arch:ProvOAlignment
    rdf:type            ktype:Concept ;
    rdfs:label          "PROV-O Alignment" ;
    skos:definition     "Partial alignment with W3C PROV-O ontology. Source provenance tracked via custom urn:kbase:meta/ predicates (source, ingestedAt, confidence, excerpt). Full prov:Activity chains not implemented — unnecessary complexity for a personal KB where the user IS the reviewing agent. Custom namespace chosen for simplicity and smaller TTL output." ;
    skos:broader        arch:LocalFirstArch ;
    skos:related        arch:RdfVocabulary .

arch:RdfVocabulary
    rdf:type            ktype:Concept ;
    rdfs:label          "RDF Vocabulary Decisions" ;
    skos:definition     "Standard: rdf:type, rdfs:label, skos:definition, skos:broader, skos:related, skos:note. Custom: urn:kbase:type/ (entity types), urn:kbase:predicate/ (user predicates), urn:kbase:meta/ (reification metadata: status, source, confidence, excerpt, timestamps). urn:reckons: namespace for product-specific vocab (leap, shelly, feature)." ;
    skos:broader        arch:LocalFirstArch .


## =============================================================================
## Style Conventions (Summary)
## =============================================================================

arch:StyleConventions
    rdf:type            ktype:Concept ;
    rdfs:label          "Style Conventions" ;
    skos:definition     "Brand: dark theme, accent #7dd3fc (sky-300). Fonts: Bespoke Stencil Bold (display), Supreme Regular (body/mono), self-hosted (no Google Fonts). CSS variables: --accent, --accent-soft, --data, --surface, --surface-2, --surface-3, --line, --muted, --font-mono, --font-display, --rad, --rad-sm, --rad-lg. Z-index scale: node-labels=10, panels=300, Shelly=350, SearchBar=390, NavBar=400, MergeReview=500. bits-ui components always use :global(.class) for CSS targeting." ;
    skos:broader        guide:WhatIsReckonsAI .


## =============================================================================
## Deployment Patterns
## =============================================================================

arch:MobileAccess
    rdf:type            ktype:Concept ;
    rdfs:label          "Mobile Access via Local Server" ;
    skos:definition     "Run Reckons.AI on a Linux machine with Ollama, access from mobile via LAN. Requires: Vite dev server bound to 0.0.0.0, Ollama OLLAMA_HOST=0.0.0.0, optional self-signed SSL for HTTPS. QR code generation built into settings page. PWA installable on mobile after first visit." ;
    skos:broader        arch:StaticDeployment .

arch:MobileVoiceCapture
    rdf:type            ktype:Concept ;
    rdfs:label          "Mobile Voice Capture (Design)" ;
    skos:definition     "Planned: async voice memo capture on iOS/Android via n8n webhook. Record memo → n8n receives audio → Whisper transcription → extract triples → write to pending.jsonl → appears in review queue on next app load. No mobile app required — uses native voice recorder + Shortcuts/Tasker to POST to webhook." ;
    kpred:status        "planned" ;
    skos:broader        arch:MobileAccess .


## =============================================================================
## Dependency Health
## =============================================================================

arch:DependencyHealth
    rdf:type            ktype:Concept ;
    rdfs:label          "Dependency Health" ;
    skos:definition     "Core deps: svelte 5, sveltekit 2, dexie 4, n3 1.x, three 0.169, @huggingface/transformers 3.x, bits-ui 2.x, fflate 0.8. Dev deps: vitest 4.x, playwright 1.x, typescript 5.x. All deps actively maintained. No abandoned packages. Browser-only runtime — no server deps in production." ;
    skos:broader        arch:LocalFirstArch .


## =============================================================================
## Confluence Migration Design
## =============================================================================

arch:MigConfluenceDesign
    rdf:type            ktype:Concept ;
    rdfs:label          "Confluence Migration Design" ;
    skos:definition     "Design decisions and implementation details for F26 Confluence Migration. Covers the 6-step migration pipeline, sliding window chunking, local model recommendations, pause/resume checkpointing, and page hierarchy preservation." ;
    skos:broader        arch:MigConfluence .

arch:ConfSlidingWindow
    rdf:type            ktype:Concept ;
    rdfs:label          "Sliding Window Chunking" ;
    skos:definition     "Confluence pages often exceed the 12K char extraction limit. Sliding window with overlap: CHUNK_SIZE 10,000 chars (safe for all model context windows), CHUNK_OVERLAP 2,000 chars (catches facts split across boundaries). Cross-chunk deduplication by exact match on (subject, predicate, object) after slugification. Each chunk gets a context header: source title, page N of M, chunk N of M, parent page, labels." ;
    skos:broader        arch:MigConfluenceDesign .

arch:ConfLocalModels
    rdf:type            ktype:Concept ;
    rdfs:label          "Local Model Recommendations" ;
    skos:definition     "Recommended: gemma3:12b via Ollama for migration. Handles structured extraction well, 128K context, ~15 tokens/sec on consumer GPU. For 500 pages with 3 chunks average, ~1,500 LLM calls, approximately 2-4 hours. Alternatives: gemma3:4b (fast, good for <100 pages), gemma3:27b (excellent quality, slow), qwen3:8b (good alternative), llama3.2:3b (very fast, acceptable quality). WASM fallback (Qwen2.5-0.5B) for small spaces <50 pages where user reviews every triple." ;
    skos:broader        arch:MigConfluenceDesign .

arch:ConfPauseResume
    rdf:type            ktype:Concept ;
    rdfs:label          "Pause/Resume Checkpoint" ;
    skos:definition     "MigrationCheckpoint stored in localStorage: id, spaceName, totalPages, completedPages (IDs already processed), failedPages (IDs that errored), startedAt, lastCheckpoint. On page load, detects incomplete migration and offers to resume. Enables overnight imports for large spaces (500+ pages with gemma3:12b takes ~11 hours). Error retry queue with 3 attempts per page." ;
    skos:broader        arch:MigConfluenceDesign .

arch:ConfPageHierarchy
    rdf:type            ktype:Concept ;
    rdfs:label          "Page Hierarchy Preservation" ;
    skos:definition     "Confluence parent-child page relationships mapped to skos:broader triples. Page tree reconstructed from index.html table of contents links. Labels converted to rdf:type entities. Each page becomes a Source with Confluence metadata (confluencePageId, confluenceSpaceKey, confluenceLabels). Source kind: confluence." ;
    skos:broader        arch:MigConfluenceDesign .

arch:ConfMigrationPipeline
    rdf:type            ktype:Concept ;
    rdfs:label          "6-Step Migration Pipeline" ;
    skos:definition     "Step 1: Upload ZIP — user selects Confluence HTML export ZIP via confluence tab. Step 2: Preview and Configure — shows page count, total text, estimated chunks, estimated time, backend/model selector, options (preserve hierarchy, convert labels, include URLs, extract from attachments). Step 3: Extraction Queue — sequential page processing with progress bar, pause/skip/cancel controls. Step 4: Post-Processing — cross-page entity normalisation, hierarchy injection (skos:broader), label-to-type mapping (rdf:type), source provenance. Step 5: Review — all triples enter review queue as pending with confluence-aware filters (by source page, by label, bulk confirm by page, sort by confidence). Step 6: Optional Cloud Refinement — re-extract only rejected/low-confidence triples with Claude, typically <5% of total." ;
    skos:broader        arch:MigConfluenceDesign .

arch:ConfMemoryManagement
    rdf:type            ktype:Concept ;
    rdfs:label          "Migration Memory Management" ;
    skos:definition     "For large spaces (500+ pages): write each page's triples to IndexedDB immediately after extraction (already done via addStatements). Run normalisation in batches of 50 pages. Throttle queue with configurable delay between pages (default 600ms, same as vault mode)." ;
    skos:broader        arch:MigConfluenceDesign .


## =============================================================================
## Persona
## =============================================================================

@prefix shelly: <urn:reckons:shelly/> .

shelly:persona
    shelly:name             "Shelly" ;
    shelly:greeting         "This is the architecture and design decisions KB. I can explain the local-first approach, TTL-first documentation strategy, standards alignment, deployment patterns, or dependency health. What would you like to know?" ;
    shelly:personality      "architectural, precise, opinionated" ;
    shelly:responseStyle    "concise" ;
    shelly:systemPrompt     "You are helping someone understand Reckons.AI architecture and design decisions. Explain trade-offs clearly. Reference specific entities in this KB." .
