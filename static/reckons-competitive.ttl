@prefix kb:     <urn:kbase:concept/> .
@prefix kpred:  <urn:kbase:predicate/> .
@prefix kmeta:  <urn:kbase:meta/> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix ktype:  <urn:kbase:type/> .
@prefix hnav:   <urn:reckons:nav/> .

# ==============================================================================
# Reckons.AI — Competitive Research KB
# ==============================================================================
# The neighbourhood, mapped. This graph exists to LEARN, not to score points.
#
# Competition here is healthy and open: almost every project below is
# permissively licensed, several are solving our problems better than we are,
# and at least one (codeflow) holds our own local-first thesis more purely than
# we do. A competitive graph that only flatters its owner is not research, it is
# marketing — and per kb:honest-status, marketing written in the present tense is
# a lie with good manners.
#
# The graph records three things about each project:
#   1. WHAT IT IS          — metadata, refreshed deterministically by
#                            scripts/offline/competitor-scan.ts (script tier, zero tokens)
#   2. WHAT WE COULD TAKE  — kpred:worth-adopting, linked to the roadmap entity it serves
#   3. WHAT WE WON'T TAKE  — kpred:we-avoid + kpred:avoid-reason. This is the important
#                            half. A feature we decline is a DESIGN DECISION with a reason,
#                            not an oversight, and writing the reason down is what stops us
#                            drifting into it later by accident.
#
# LICENSE IS A GATE, NOT A FOOTNOTE. kpred:copy-permitted is computed from the
# GitHub license field and is the ONLY thing that authorizes copying code. Ideas
# are not copyrightable and may always be learned from; expression is. A repo with
# NO license is all-rights-reserved by default — read it, learn from it, copy
# nothing.
#
# Metadata scanned: 2026-07-14. Re-run `npm run offline:competitors` to refresh.
# ==============================================================================

kb:competitive-landscape rdf:type ktype:Concept ;
               rdfs:label   "Competitive landscape" ;
               kpred:description  "The open-source neighbourhood around Reckons.AI: code-to-graph tools, local-first analyzers, agent orchestration layers, crawlers, and on-device speech. Mapped to learn from, and to record what we deliberately decline." ;
               kpred:principle    "Competition is healthy and open. Most of this neighbourhood is MIT or Apache-2.0, and several projects do a specific thing better than we do. Say so." ;
               kpred:principle    "The features we AVOID are the ones that define the product. Anyone can add a cloud share button; refusing to is the thesis." ;
               kpred:scanned-at   "2026-07-14"^^xsd:date .

# ── The license gate ──────────────────────────────────────────────────────────
# Deterministic, script-checkable, and load-bearing before a single line is copied.

kb:license-gate rdf:type       ktype:Concept ;
               rdfs:label   "License gate — confirm before any copy" ;
               kpred:part-of      kb:competitive-landscape ;
               kpred:description  "No code, asset, or prose is copied from a competitor until kpred:copy-permitted says so. Computed from the GitHub license field by competitor-scan.ts, never asserted by hand. MIT/Apache-2.0 permit reuse WITH attribution (Apache-2.0 additionally requires a NOTICE and carries an express patent grant). Absent a license file, default copyright applies and the answer is NO — regardless of how public the repo is, or how many stars it has." ;
               kpred:principle    "Ideas are not copyrightable; expression is. You may always learn the concept. You may not always take the code." ;
               kpred:enforced-by  "scripts/offline/competitor-scan.ts" .

# ── Direct adjacency: code/knowledge → interactive graph ──────────────────────

kb:comp-understand-anything rdf:type ktype:Competitor ;
               rdfs:label   "Understand Anything (Egonex-AI)" ;
               kpred:part-of      kb:competitive-landscape ;
               hnav:order   1 ;
               kpred:repo-url     "https://github.com/Egonex-AI/Understand-Anything" ;
               kpred:license      "MIT" ;
               kpred:copy-permitted "yes — MIT, attribution required" ;
               kpred:stars        73993 ;
               kpred:language     "TypeScript" ;
               kpred:last-push    "2026-07-14"^^xsd:date ;
               kpred:description  "Claude Code plugin: analyzes a project with a multi-agent pipeline, builds a knowledge graph of every file/function/class/dependency, and serves an interactive dashboard. Also ingests Karpathy-pattern LLM wikis. Its stated goal — 'a graph that quietly teaches you how every piece fits together', not one that 'wows you with how complex your codebase is' — is very close to our own graph-legibility position (F83)." ;
               kpred:closest-to   kb:repo-ingest ;
               kpred:closest-to   kb:graph-legibility ;
               kpred:honest-note  "73,993 stars against our zero. This is the most successful project in the neighbourhood and it overlaps our Codebase KB directly. Pretending otherwise in our own graph would be exactly the self-serving claim the product exists to reject." ;
               kpred:worth-adopting kb:adopt-blast-radius ;
               kpred:worth-adopting kb:adopt-guided-tours ;
               kpred:validates    "Its pipeline is deterministic-parser-FIRST (wikilinks, categories) and only then LLM agents for implicit relationships — the same ground-then-model harness as F74.3 work tiering. Independent arrival at our architecture is evidence the architecture is right." ;
               kpred:we-avoid     "Hosted dashboard + demo site (understand-anything.com)" ;
               kpred:avoid-reason "Their graph is served from a website. Ours must open with no network, no account, and no operator — a graph you can only see on someone else's server is a graph they can withdraw." .

kb:comp-codeflow rdf:type      ktype:Competitor ;
               rdfs:label   "CodeFlow (braedonsaunders)" ;
               kpred:part-of      kb:competitive-landscape ;
               hnav:order   2 ;
               kpred:repo-url     "https://github.com/braedonsaunders/codeflow" ;
               kpred:license      "NONE" ;
               kpred:copy-permitted "NO — unlicensed, all rights reserved. Ideas only; copy no code, assets, or text." ;
               kpred:stars        4424 ;
               kpred:language     "HTML" ;
               kpred:last-push    "2026-07-14"^^xsd:date ;
               kpred:description  "Paste a GitHub URL, get an interactive architecture map. Single-file, browser-only, no install, no accounts, no data collection, works offline on local files. Features: dependency graph, blast-radius analysis, code ownership from git history, and a security scanner." ;
               kpred:closest-to   kb:repo-ingest ;
               kpred:honest-note  "This project holds the local-first thesis more purely than we do: a single HTML file, no build, no server, offline by default. 4,424 stars with no license at all, which is itself a finding — permissionless popularity is not the same as a permissive license." ;
               kpred:worth-adopting kb:adopt-blast-radius ;
               kpred:worth-adopting kb:adopt-code-ownership ;
               kpred:blocked-by   "kpred:copy-permitted = NO. Any adoption must be a clean-room reimplementation from the CONCEPT, with no reference to their source." .

# ── Agent orchestration: the tier we just built ──────────────────────────────

kb:comp-pilotfish rdf:type     ktype:Competitor ;
               rdfs:label   "pilotfish (Nanako0129)" ;
               kpred:part-of      kb:competitive-landscape ;
               hnav:order   3 ;
               kpred:repo-url     "https://github.com/Nanako0129/pilotfish" ;
               kpred:license      "MIT" ;
               kpred:copy-permitted "yes — MIT, attribution required" ;
               kpred:stars        441 ;
               kpred:language     "Python" ;
               kpred:last-push    "2026-07-14"^^xsd:date ;
               kpred:description  "Multi-model orchestration for Claude Code: the frontier model plans, decides, and reviews; cheaper models execute the volume work through subagents. Three config files, no runtime code. Quality is protected by FRESH-CONTEXT VERIFICATION rather than by using the biggest model everywhere." ;
               kpred:closest-to   kb:work-tiering ;
               kpred:validates    "This is F74.3 arrived at independently, and it carries the benchmark numbers we never gathered: Anthropic's own tests put a frontier orchestrator with Sonnet workers at 96% of all-frontier performance for 46% of the cost, and the docs state that independent fresh-context verifier subagents outperform self-critique." ;
               kpred:worth-adopting kb:adopt-fresh-context-verify ;
               kpred:worth-adopting kb:adopt-sonnet-bucket ;
               kpred:honest-note  "Our tiering doc reasons about local-vs-cloud but says nothing about CLOUD-to-CLOUD tiering (Opus orchestrator, Sonnet/Haiku executors), which is where the measured savings actually are. That is a gap in F74.3, not a difference of opinion." .

