# ── WHAT WE ADOPT ────────────────────────────────────────────────────────────
# Each is a proposal against a roadmap entity, not a decision. Status stays
# speculative until Matt rules on it (kb:honest-status).

kb:adopt-blast-radius rdf:type ktype:Feature ;
               rdfs:label   "Blast radius — what breaks if I change this?" ;
               kpred:part-of      kb:competitive-landscape ;
               kpred:has-status   "speculative" ;
               kpred:seen-in      kb:comp-codeflow ;
               kpred:seen-in      kb:comp-understand-anything ;
               kpred:description  "Select an entity, see everything that transitively depends on it. We already hold the edges this needs — kpred:depends-on in the roadmap, kpred:has-file in the Codebase KB — so this is a TRAVERSAL over data we have, not new data. It is the highest-value/lowest-cost item in this graph." ;
               kpred:serves       kb:repo-ingest ;
               kpred:honest-note  "Concept only. codeflow is unlicensed (kpred:copy-permitted = NO), so any implementation must be clean-room from the idea." .

kb:adopt-code-ownership rdf:type ktype:Feature ;
               rdfs:label   "Code ownership from git history" ;
               kpred:part-of      kb:competitive-landscape ;
               kpred:has-status   "speculative" ;
               kpred:seen-in      kb:comp-codeflow ;
               kpred:description  "Top contributors per file, derived from git log. Script tier: deterministic, zero tokens, no model. Would attach kpred:owned-by to the Codebase KB's has-file links." ;
               kpred:serves       kb:codebase-kb .

kb:adopt-guided-tours rdf:type ktype:Feature ;
               rdfs:label   "Guided tours — walk the graph in dependency order" ;
               kpred:part-of      kb:competitive-landscape ;
               kpred:has-status   "speculative" ;
               kpred:seen-in      kb:comp-understand-anything ;
               kpred:description  "An auto-generated walkthrough that orders entities by dependency so a newcomer meets them in the order that makes them make sense. We already have the ordering primitives (hnav:order, hnav:next/prev, skos:broader) and the leap machinery; this is a reading of the graph we do not currently offer." ;
               kpred:serves       kb:hierarchical-nav .

kb:adopt-fresh-context-verify rdf:type ktype:Feature ;
               rdfs:label   "Fresh-context verification beats self-critique" ;
               kpred:part-of      kb:competitive-landscape ;
               kpred:has-status   "speculative" ;
               kpred:seen-in      kb:comp-pilotfish ;
               kpred:description  "A verifier with a FRESH context outperforms the author re-reading their own work — the author is anchored by the reasoning that produced the error. Applies directly to the agent tier: describe-entities.ts and code-review.ts currently emit proposals with no independent check." ;
               kpred:serves       kb:work-tiering .

kb:adopt-sonnet-bucket rdf:type ktype:Feature ;
               rdfs:label   "Cloud-to-cloud tiering — Opus orchestrates, Sonnet executes" ;
               kpred:part-of      kb:competitive-landscape ;
               kpred:has-status   "speculative" ;
               kpred:seen-in      kb:comp-pilotfish ;
               kpred:description  "F74.3 tiers SCRIPT -> LOCAL AGENT -> OPUS and stops. It has no account of Opus-vs-Sonnet-vs-Haiku, which is where the measured savings actually sit: an orchestrator with Sonnet workers benchmarks at 96% of all-frontier quality for 46% of the cost, and Claude subscriptions carry an ADDITIONAL Sonnet-only weekly bucket, so routing execution to Sonnet draws on headroom the all-models bucket never sees." ;
               kpred:serves       kb:work-tiering ;
               kpred:honest-note  "This is a real hole in our tiering model, found by reading someone else's README. The tier ladder treats 'Opus' as one rung when it is three." .

# ── WHAT WE AVOID, AND WHY ───────────────────────────────────────────────────
# The load-bearing half of this graph. A declined feature is a decision.

kb:avoid-hosted-sync rdf:type  ktype:Decision ;
               rdfs:label   "No OPERATOR-hosted share/sync — the graph is yours, offline, self-controlled" ;
               kpred:part-of      kb:competitive-landscape ;
               kpred:description  "Competitors publish to a URL on infrastructure THEY operate (pagecast -> Cloudflare Pages; Understand Anything -> a hosted dashboard). It is genuinely more convenient, and we decline it. Reckons.AI is local-first with no general backend: sharing is an EXPORT the user performs and controls (TTL/TriG, markdown, a file, a QR code), not an upload to an operator who can rate-limit, deplatform, mine, or shut down." ;
               kpred:reason       "A graph you can only see on someone else's server is a graph they can withdraw. Provenance is an accountability relation: the moment a third party hosts your knowledge, they acquire power over it that you did not grant and cannot revoke." ;
               kpred:reason       "It is the thesis. An unverifiable claim, made by the party it benefits, is not evidence — and a knowledge tool that phones home is asking you to take its word for what it does with your knowledge." ;
               kpred:consistent-with kb:integration-boundaries ;
               kpred:scope        "What is refused is the OPERATOR, not the sync. See kb:adopt-user-owned-sync — this decision was stated too broadly before the scan, and SiYuan is the counter-example that forced the distinction." ;
               kpred:honest-note  "This costs us. One-command share is the most requested affordance in this category and we do not have it. The honest position is 'we refuse the hosted form', not 'we haven't got to it yet'." .

kb:adopt-user-owned-sync rdf:type ktype:Feature ;
               rdfs:label   "User-owned sync — self-hosted, not operator-hosted" ;
               kpred:part-of      kb:competitive-landscape ;
               kpred:has-status   "speculative" ;
               kpred:seen-in      kb:comp-siyuan ;
               kpred:seen-in      kb:comp-rxdb ;
               kpred:description  "SiYuan (45k stars) ships SELF-HOSTED sync and remains privacy-first; RxDB (Apache-2.0) replicates to a backend the USER supplies. Together they show that 'the user controls where their knowledge lives' and 'my knowledge follows me across devices' are not actually in conflict — the conflict is only with an OPERATOR-owned server." ;
               kpred:serves       kb:avoid-hosted-sync ;
               kpred:honest-note  "This is the most consequential finding in the scan, and it is a challenge to our own position rather than a feature request. We wrote 'no sync' when what we meant was 'no sync THROUGH US'. A user pointing Reckons.AI at their own storage is not a betrayal of local-first — it is local-first working across two machines. Whether to build it is Matt's call; the graph should stop implying the question is settled." ;
               kpred:decision-owner "Matt" .

kb:avoid-cloud-only-pipeline rdf:type ktype:Decision ;
               rdfs:label   "No cloud-only analysis pipeline" ;
               kpred:part-of      kb:competitive-landscape ;
               kpred:description  "Understand Anything's multi-agent pipeline assumes a frontier model is available and paid for. Ours must degrade to a local model, and below that to a deterministic script, and below that to manual entry — the graph must still be usable when no model is available at all." ;
               kpred:reason       "A knowledge base that cannot be read without an API key is a rental, not a possession." ;
               kpred:consistent-with kb:work-tiering .

# ── Automated scanning ───────────────────────────────────────────────────────

kb:competitor-scan rdf:type    ktype:Feature ;
               rdfs:label   "Automated competitor scan (script tier)" ;
               kpred:part-of      kb:competitive-landscape ;
               kpred:feature-id   "F86" ;
               kpred:has-status   "functional" ;
               kpred:has-file     "scripts/offline/competitor-scan.ts" ;
               kpred:description  "Refreshes every kb:Competitor's metadata and LICENSE from the GitHub API, and discovers candidate new competitors by topic search. Deterministic, zero tokens, no model: stars, license SPDX, last push and archived status are facts, not judgments. Drift (a license change, a new candidate, an abandoned project) is emitted to knowledge.pending.jsonl as a proposal for human review — the script never edits this TTL." ;
               kpred:principle    "The FETCH is script tier because it is checkable by a rule. The JUDGMENT — is this a competitor, do we want this feature, why do we decline it — stays with a human. Automating the judgment would fill the graph with confident nonsense." ;
