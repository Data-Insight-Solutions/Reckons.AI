## =============================================================================
## Integrations and Workflows
## =============================================================================

int:Integrations
    rdf:type            ktype:Concept ;
    rdfs:label          "Integrations" ;
    skos:definition     "Reckons.AI connects to external tools and data sources while keeping your KB local. Every integration is optional -- the core app works with zero external dependencies." ;
    skos:related        guide:WhatIsReckonsAI .

int:GoogleCalendar
    rdf:type            ktype:Concept ;
    rdfs:label          "Google Calendar" ;
    skos:definition     "Import events as triples via OAuth. Dates, times, attendees, descriptions, and recurrence patterns become structured, queryable knowledge. Recurring events expanded with safety limits." ;
    skos:broader        int:Integrations .

int:iCalFeed
    rdf:type            ktype:Concept ;
    rdfs:label          "iCal (.ics) Import" ;
    skos:definition     "Import any iCal feed -- Outlook, Apple Calendar, university schedules, conference programs. Events become triples with datetime extraction, recurrence detection, and conflict identification." ;
    skos:broader        int:Integrations .

int:IndicoEvents
    rdf:type            ktype:Concept ;
    rdfs:label          "Indico Events" ;
    skos:definition     "Import scientific conference programs from Indico (CERN's event management system). Sessions, contributions, and speakers become structured triples." ;
    skos:broader        int:Integrations .

int:MCPServer
    rdf:type            ktype:Concept ;
    rdfs:label          "MCP Server" ;
    skos:definition     "Standalone Node.js MCP server exposing your graph to AI agents (Claude Desktop, Cursor, Claude Code). 20 tools over JSON-RPC stdio: search and read (kb_search, kb_get_entity, kb_list_entities, kb_stats, kb_subgraph, kb_list_kbs, kb_compress), write proposals (kb_add_note), reasoning (kb_reckoning), source management (kb_list_sources, kb_request_refresh), git-aware alignment (kb_git_status, kb_check_plan, kb_pending, kb_git_diff_triples, kb_alignment_score), and the local Ollama bridge (kb_local_extract, kb_local_summarize, kb_generate_page, kb_entity_markdown). Reads workspace TTL files (kbs/<name>/<name>.ttl), with multi-KB support via MultiKBReader." ;
    skos:broader        int:Integrations ;
    skos:related        int:WorkspaceSync ;
    skos:related        int:Ollama .

int:Ollama
    rdf:type            ktype:Tool ;
    rdfs:label          "Ollama (Local LLM Offload)" ;
    skos:definition     "Local model server used two ways: as an in-app LLM backend (schema-constrained structured extraction, and prefer-local routing for chat/diff-summary/merge-analysis when reachable), and as an opt-in MCP bridge (kb_local_extract, kb_local_summarize, kb_generate_page) gated by OLLAMA_BASE_URL so the MCP server never depends on a local model unless you configure one. All Ollama-backed output is proposal-only -- nothing is written to a graph without review." ;
    skos:broader        int:Integrations ;
    skos:related        int:MCPServer .

int:WorkspaceSync
    rdf:type            ktype:Concept ;
    rdfs:label          "Workspace Folder Sync" ;
    skos:definition     "Auto-exports knowledge.ttl to a local folder on each mutation. The MCP server reads this file. Pending notes arrive via knowledge.pending.jsonl. Can sync settings via save/load from folder." ;
    skos:broader        int:Integrations .

int:BrowserExtension
    rdf:type            ktype:Concept ;
    rdfs:label          "Browser Extension" ;
    skos:definition     "Manifest V3 extension with three tabs: Compare (page vs KB with at-a-glance bar), Session (multi-page research accumulation with aggregate summaries), Ingest (batch send to app). Supports Chrome, Firefox desktop, and Firefox for Android with mobile-optimized UI." ;
    skos:broader        int:Integrations .

int:WebScraping
    rdf:type            ktype:Concept ;
    rdfs:label          "Web Scraping (Jina / Firecrawl)" ;
    skos:definition     "Extract content from URLs. Jina Reader for simple pages, Firecrawl for JavaScript-rendered sites. Content parsed into clean text, then LLM-extracted into triples." ;
    skos:broader        int:Integrations .

int:PDFImport
    rdf:type            ktype:Concept ;
    rdfs:label          "PDF / Image Import (Mistral OCR)" ;
    skos:definition     "Upload PDFs or images. Mistral OCR extracts text, then the LLM extracts triples. Contracts, invoices, academic papers -- all become structured knowledge." ;
    skos:broader        int:Integrations .

int:WhisperSTT
    rdf:type            ktype:Tool ;
    rdfs:label          "Whisper STT" ;
    skos:definition     "Local speech-to-text via @huggingface/transformers using onnx-community/whisper-tiny (42MB quantized). Mic button in the chat tab. Runs entirely in-browser -- no cloud required." ;
    skos:broader        int:Integrations .

int:KokoroTTS
    rdf:type            ktype:Tool ;
    rdfs:label          "Kokoro TTS" ;
    skos:definition     "Local text-to-speech using a cached 82MB model. Used for story walkthrough narration. Falls back to browser window.speechSynthesis. Voices cached in 'kokoro-voices' Cache API store." ;
    skos:broader        int:Integrations .

int:NemoSpeech
    rdf:type            ktype:Tool ;
    rdfs:label          "NVIDIA NeMo Speech (Planned)" ;
    skos:definition     "GPU-accelerated STT and TTS via NVIDIA NeMo (Apache 2.0, open source, free). Python sidecar or Docker container running alongside the app. STT: Nemotron-3.5-ASR-Streaming-0.6B (40 languages, controllable latency 80ms-1s, 5.63% WER). TTS: MagpieTTS v2602 (9 languages). Requires NVIDIA GPU + CUDA + Python 3.12+. Separate dev setup from the main SvelteKit app. HTTP API at localhost with /transcribe and /synthesize endpoints. Falls back to existing Whisper+Kokoro WASM for users without NVIDIA hardware." ;
    skos:broader        int:Integrations ;
    skos:related        int:WhisperSTT ;
    skos:related        int:KokoroTTS .

int:Cosmos3Nano
    rdf:type            ktype:Tool ;
    rdfs:label          "NVIDIA Cosmos3-Nano (Speculative)" ;
    skos:definition     "16B-parameter omnimodal world foundation model for Physical AI by NVIDIA. Generates and reasons over video, images, audio, and robot actions. OpenMDW 1.1 licence (commercial use). Requires NVIDIA GPU (Ampere/Hopper/Blackwell) with BF16 precision, Linux only. Potential uses: generate preview animations from entity descriptions, multimodal KB ingest (video/image/audio sources), 3D scene understanding. Shares NVIDIA GPU sidecar infrastructure with NeMo Speech." ;
    skos:broader        int:Integrations ;
    skos:related        int:NemoSpeech ;
    skos:related        int:Meshy3D .

int:Meshy3D
    rdf:type            ktype:Tool ;
    rdfs:label          "Meshy 3D Generation" ;
    skos:definition     "Generate 3D GLB models for entities via the Meshy.ai API. Models are displayed as custom node shapes in the 3D graph view. Task status tracked via urn:kbase:meta/meshyTaskId statements." ;
    skos:broader        int:Integrations .

int:GoogleDrive
    rdf:type            ktype:Concept ;
    rdfs:label          "Google Drive" ;
    skos:definition     "KB backup to Google Drive. Export .ttl to a dedicated Drive folder. OAuth-authenticated. Privacy note: Google can access the stored file." ;
    skos:broader        int:Integrations .

int:ModelCache
    rdf:type            ktype:Concept ;
    rdfs:label          "Model Cache Management" ;
    skos:definition     "Inspect, sideload, and purge locally cached WASM models via Cache API. Manifests track SmolLM2-360M (370MB), MiniLM-L6-v2 (22MB), Kokoro 82M (88MB), Whisper Tiny (42MB). Service worker caches HuggingFace downloads with CacheFirst strategy." ;
    skos:broader        int:Integrations .


int:N8nCloudSync
    rdf:type            ktype:Concept ;
    rdfs:label          "n8n Cloud Sync" ;
    skos:definition     "Private, self-hosted cloud sync via n8n workflow automation on a self-hosted VPS. Two workflows: KB Sync Hub (workflow gzL6AXn9iWo4GZxN — upload/download/status/pending via webhooks with SHA-256 content-hash deduplication) and Source Monitor (workflow CvbUNSZkZVf4hJFG — watches URLs every 6 hours, detects content changes via hash comparison, queues pending notes). Three data tables: reckons_kb_store (snapshots), reckons_watched_urls (monitored URLs), reckons_pending_notes (change notifications). Security via n8n Header Auth on webhook trigger nodes. No SaaS dependency — your n8n VPS is the cloud backend. Air-gapped operation supported." ;
    skos:broader        int:Integrations .

int:N8nSyncHub
    rdf:type            ktype:Concept ;
    rdfs:label          "KB Sync Hub (n8n)" ;
    skos:definition     "n8n workflow gzL6AXn9iWo4GZxN with 4 webhook endpoints: POST /webhook/reckons-kb-upload (accepts JSON with kb_name and ttl_content, SHA-256 content-hash deduplication via upsert into reckons_kb_store data table), GET /webhook/reckons-kb-download?kb=name (serves text/turtle Content-Type), GET /webhook/reckons-kb-status (JSON summary of all stored KBs with names, hashes, and content lengths), GET /webhook/reckons-kb-pending?kb=name (pending notes from source monitors). Security: Header Auth credential on each webhook trigger node, pass token via Authorization header." ;
    skos:broader        int:N8nCloudSync .

int:N8nSourceMonitor
    rdf:type            ktype:Concept ;
    rdfs:label          "Source Monitor (n8n)" ;
    skos:definition     "n8n workflow CvbUNSZkZVf4hJFG running on a 6-hour schedule trigger. Reads watched URLs from reckons_watched_urls data table, fetches each URL, computes SHA-256 content hash, compares against stored hash. Changed URLs produce pending notes written to reckons_pending_notes data table with subject (URN from URL), predicate (source-content-changed), object (byte count and new hash), and review note. Add URLs to watch via POST /webhook/reckons-watch-url with JSON body containing url and kb_name. Pending notes surface via the Sync Hub GET /webhook/reckons-kb-pending endpoint." ;
    skos:broader        int:N8nCloudSync .

int:N8nCurrentsMonitor
    rdf:type            ktype:Concept ;
    rdfs:label          "Currents Monitor (n8n)" ;
    skos:definition     "n8n workflow (workflow-id qb9uPZ8GScAmuUOX) extending the Source Monitor pattern for Currents: fetches enabled currents on a 30-minute schedule, respecting each current's own cadence via a due-check against its last-fetched time. RSS/Atom currents use the RSS Read node; URL-kind currents fetch-and-hash like Source Monitor. Items are deduplicated per (url, graph) before insert, so re-running the sweep never creates duplicate arrivals. Exposes a register webhook (upsert current definitions) and an items webhook (pull new rows for a graph, optionally since a timestamp) that the app polls to populate pod-view arrivals." ;
    skos:broader        int:N8nCloudSync ;
    skos:related        int:N8nSourceMonitor .

int:N8nDataTables
    rdf:type            ktype:Concept ;
    rdfs:label          "n8n Data Tables" ;
    skos:definition     "Three n8n data tables back the cloud sync system. reckons_kb_store (ID: JgzUd876HO7ZAHNY) — KB snapshots with columns: kb_name, content_hash (SHA-256), ttl_content (full Turtle text), uploaded_at (timestamp); uses content-hash upsert for deduplication. reckons_watched_urls (ID: JIsQ1QfsKkUAvMCh) — monitored URLs with columns: url, kb_name, content_hash (last known SHA-256), last_checked (timestamp). reckons_pending_notes (ID: irPqWecUHYIppq04) — change notifications with columns: kb_name, subject (URN derived from URL), predicate (e.g. source-content-changed), object_value (description with byte count and new hash), note (review instruction), status (pending/processed)." ;
    skos:broader        int:N8nCloudSync .

int:VSCodeExtension
    rdf:type            ktype:Concept ;
    rdfs:label          "VS Code Extension (Planned)" ;
    skos:definition     "Auto-inject KB into coding sessions via MCP bridge. Wraps reckons-ai-mcp as child process with stdio transport. Phase 1: MCP bridge + auto-inject. Phase 2: live updates from editor actions. Phase 3: sidebar KB browser with webview graph. Zero config — activates when it detects kbs/*/*.ttl in workspace (legacy kbs/*/kb.ttl also recognised)." ;
    skos:broader        int:Integrations ;
    skos:related        int:MCPServer .


## =============================================================================
## Architecture and Technology
## =============================================================================

tech:Architecture
    rdf:type            ktype:Concept ;
    rdfs:label          "Technology Stack" ;
    skos:definition     "Static SvelteKit 2 app with Svelte 5 runes. Threlte/Three.js for 3D, N3.js for RDF parsing, @huggingface/transformers for embeddings and local LLM, Dexie for IndexedDB storage. No server required." ;
    skos:broader        guide:WhatIsReckonsAI .

tech:SvelteKit
    rdf:type            ktype:Tool ;
    rdfs:label          "SvelteKit 2 + Svelte 5" ;
    skos:definition     "Web framework with adapter-static for fully client-side deployment. Svelte 5 runes ($state, $derived, $effect) for reactive state management." ;
    skos:broader        tech:Architecture .

tech:Threlte
    rdf:type            ktype:Tool ;
    rdfs:label          "Threlte 8 + Three.js" ;
    skos:definition     "Svelte bindings for Three.js. Declarative 3D scene graph for the knowledge graph visualization. Canvas 2D fallback for low-end devices." ;
    skos:broader        tech:Architecture .

tech:N3js
    rdf:type            ktype:Tool ;
    rdfs:label          "N3.js" ;
    skos:definition     "JavaScript library for parsing and writing RDF (Turtle, N-Triples, N-Quads, TriG). Used for all .ttl import and export." ;
    skos:broader        tech:Architecture .

tech:TransformersJS
    rdf:type            ktype:Tool ;
    rdfs:label          "@huggingface/transformers v3" ;
    skos:definition     "Runs ML models in the browser via ONNX Runtime WebAssembly. Powers local LLM inference (Qwen2.5-0.5B-Instruct, q4 quantized), text embeddings (BGE-small-en-v1.5, q8, 384d, configurable), speech-to-text (Whisper Tiny), and text-to-speech (Kokoro 82M)." ;
    skos:broader        tech:Architecture .

tech:TailwindCSS
    rdf:type            ktype:Tool ;
    rdfs:label          "Tailwind CSS v4" ;
    skos:definition     "Utility CSS engine, added as the foundation for shadcn-svelte components. Preflight (the base-element reset) is disabled so it layers onto the existing hand-rolled Liquid CSS instead of replacing it." ;
    skos:broader        tech:Architecture ;
    skos:related        tech:ShadcnSvelte .

tech:ShadcnSvelte
    rdf:type            ktype:Tool ;
    rdfs:label          "shadcn-svelte" ;
    skos:definition     "Copy-in component foundation (button, badge, card, separator, skeleton) generated by the shadcn-svelte CLI and mapped onto the existing Liquid design tokens (--accent, --surface, --rad, etc.)." ;
    skos:broader        tech:Architecture ;
    skos:related        tech:TailwindCSS .

tech:Dexie
    rdf:type            ktype:Tool ;
    rdfs:label          "Dexie.js + IndexedDB" ;
    skos:definition     "Promise-based wrapper around IndexedDB. All KB data (statements, sources, changelog, settings) stored locally. Each KB is a separate Dexie database instance." ;
    skos:broader        tech:Architecture .

tech:MCP
    rdf:type            ktype:Tool ;
    rdfs:label          "Model Context Protocol" ;
    skos:definition     "An open protocol by Anthropic for connecting AI models to external data sources. Reckons.AI implements a standalone MCP server (Node.js) with 11 tools that reads workspace TTL files. Multi-KB support via MultiKBReader." ;
    skos:broader        tech:Architecture ;
    skos:related        int:MCPServer .

tech:PWA
    rdf:type            ktype:Concept ;
    rdfs:label          "Progressive Web App" ;
    skos:definition     "Service worker (via @vite-pwa/sveltekit) enables offline access after first load. HuggingFace model downloads cached with CacheFirst strategy. Installable on desktop and mobile." ;
    skos:broader        tech:Architecture .


## =============================================================================
## Persona
## =============================================================================

@prefix shelly: <urn:reckons:shelly/> .

shelly:persona
    shelly:name             "Shelly" ;
    shelly:greeting         "This covers integrations and the tech stack! I can explain MCP, the browser extension, calendar import, Whisper STT, Kokoro TTS, model caching, or any technology under the hood. What interests you?" ;
    shelly:personality      "technical, thorough, helpful" ;
    shelly:responseStyle    "concise" ;
    shelly:systemPrompt     "You are helping someone learn about Reckons.AI integrations and technology. Explain how each piece connects. Be specific about what data flows where." .
