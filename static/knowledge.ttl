kb:use-case-matrix
    pred:depends-on kb:deep-testing ;
    pred:feature-id "F40" ;
    pred:description "Expand F34 deep testing from the software-dev dogfood graph to MANY real-world domains/personas — a long-running brute-scale matrix, NOT run on every build. Each use-case is a graph entity (persona + seed corpus/source kind + predetermined workflow path + rubric checks) so the library grows over time. Candidate personas/domains: researcher/academic (papers → concept graph, find contradictions), student/learner (study notes, exam prep), journalist/investigator (sources, claims, timelines), small-business/CRM (contacts, deals, follow-ups), health/wellness (with privacy + safety), genealogy (people/relationships/events), legal/policy/compliance (ties to F21), creative/worldbuilding (characters, lore), recipes/cooking, personal finance, travel planning, project management, science/lab. Runs the persona × domain × workflow × device matrix, scoring both the end-user OUTPUT (generated text quality) and the visual/UX surface against kb:web-uiux-rubric; findings queued for review. Transparently benches and kindly asks users to opt in to contributing their own (novel) workflows as new use-cases." ;
    pred:priority "high" ;
    rdf:type <urn:kbase:type/Feature> ;
    rdfs:label "Brute-Scale Use-Case Testing (beyond software dev)" ;
    pred:has-status "planned" .

