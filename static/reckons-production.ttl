                    kpred:has-tab  "session" ;
                    kpred:has-tab  "ingest" .

# ══════════════════════════════════════════════════════════════════════════════
# Story: Production Health Tour
# ══════════════════════════════════════════════════════════════════════════════

story:production-tour  rdf:type         story:Story ;
                       rdfs:label       "Production Health Tour" ;
                       story:description "Walk through the key production tests and verify Reckons.AI health." ;
                       story:autoplay   "false" ;
                       story:pace       "10" .

# Step 1: Overview
story:prod-step-1  rdf:type         story:Step ;
                   story:partOf     story:production-tour ;
                   story:order      "1"^^xsd:integer ;
                   story:title      "Welcome to Production Status" ;
                   story:content    "This graph tracks the production health of Reckons.AI. It has two live sources: the website URL and the GitHub repository. Both can be refreshed to pull in the latest state. Let me walk you through the key test categories." ;
                   story:highlight  kb:reckons-ai .

# Step 2: Unit Tests
story:prod-step-2  rdf:type         story:Step ;
                   story:partOf     story:production-tour ;
                   story:order      "2"^^xsd:integer ;
                   story:title      "Unit Tests" ;
                   story:content    "The unit test suite runs with `npx vitest run` and covers triple parsing, diff computation, content safety, entity types, ghost graph / graph leap, diff summary, source refresh, RDF types, W3C Turtle conformance, hierarchy navigation, graph registry, TTL serialization round-trip, currents, Ollama offload, and graph publishing. 643 passing tests across 35 files with zero failures." ;
                   story:highlight  kb:test-unit ;
                   story:highlight  kb:test-suite ;
                   story:question   "Want to see the latest test results?" .

# Step 3: Visual Tests
story:prod-step-3  rdf:type         story:Step ;
                   story:partOf     story:production-tour ;
                   story:order      "3"^^xsd:integer ;
                   story:title      "Visual & Playwright Tests" ;
                   story:content    "Visual tests use Playwright to capture screenshots and analyze them with a layered approach: pixel statistics detect solid fills and blank screens, DOM analysis catches element overlaps and off-screen content, and text extraction verifies labels are visible. The visual bench achieves 95%+ accuracy with zero API cost." ;
                   story:highlight  kb:test-visual ;
                   story:highlight  kb:visual-testing ;
                   story:highlight  kb:test-visual-bench .

# Step 4: MCP Server
story:prod-step-4  rdf:type         story:Step ;
                   story:partOf     story:production-tour ;
                   story:order      "4"^^xsd:integer ;
                   story:title      "MCP Server" ;
                   story:content    "The MCP server exposes 20 tools over JSON-RPC stdio. Claude Code and other AI agents can search the graph, get entity details, extract subgraphs, add notes, list sources, request refreshes, run git-aware alignment checks, and — opt-in via OLLAMA_BASE_URL — offload extraction, summarization, and page drafting to a local Ollama model. The server supports multi-Graph workspaces." ;
                   story:highlight  kb:mcp-server ;
                   story:question   "Should I verify the MCP server tools are responding?" .

# Step 5: Ingest Pipeline
story:prod-step-5  rdf:type         story:Step ;
                   story:partOf     story:production-tour ;
                   story:order      "5"^^xsd:integer ;
                   story:title      "Ingest & Source Refresh" ;
                   story:content    "The ingest pipeline supports 10 source types including the new GitHub repo ingest. URL, repository, and calendar sources can be refreshed to pull in updates. Auto-refresh can be configured to run on graph open or on a schedule. The repo ingest uses the GitHub REST API for tree walking and delta comparison." ;
                   story:highlight  kb:ingest-pipeline ;
                   story:highlight  kb:repo-ingest ;
                   story:highlight  kb:source-refresh .

# Step 6: Self-Improvement Loop
story:prod-step-6  rdf:type         story:Step ;
                   story:partOf     story:production-tour ;
                   story:order      "6"^^xsd:integer ;
                   story:title      "The Self-Improvement Loop" ;
                   story:content    "This is the key insight: Reckons.AI can analyze its own codebase, extract architectural knowledge into triples, and then use those triples (via the MCP server) to guide Claude Code in making improvements. Refresh the repo source, review the updated triples, and use them as context for your next development session." ;
                   story:highlight  kb:reckons-ai ;
                   story:highlight  kb:mcp-server ;
                   story:highlight  kb:repo-ingest ;
                   story:question   "Ready to refresh sources and see what has changed?" .

# ── Release Pipeline: environment status (F33) ─────────────────────────────────
# Three review gates. Branch alignment (scripts/branch-align.ts) checks these
# claims against real git branch state.

kb:env-dev a ktype:Environment ;
    rdfs:label        "Development" ;
    kpred:git-branch  "dev" ;
    kpred:deploy-url  "https://dev.reckons-ai.pages.dev" ;
    kpred:review-gate "developer" ;
    kpred:reviews-graph "codebase" ;
    kpred:description "Integration branch. Changes land here for DEVELOPER (technical) review — unit tests, build, svelte-check, code review — before promotion to staging. A feature carries kpred:in-dev once merged, and kpred:dev-approved once the developer signs off (which unblocks promotion to staging)." .

kb:env-staging a ktype:Environment ;
    rdfs:label        "Staging" ;
    kpred:git-branch  "staging" ;
    kpred:deploy-url  "https://staging.reckons-ai.pages.dev" ;
    kpred:review-gate "stakeholder" ;
    kpred:reviews-graph "roadmap" ;
    kpred:description "Stakeholder (business) review environment; serves a preview build for sign-off. A feature carries kpred:in-staging on promotion from dev, and kpred:stakeholder-approved once the business side signs off (which unblocks promotion to production)." .

kb:env-production a ktype:Environment ;
    rdfs:label        "Production" ;
    kpred:git-branch  "main" ;
    kpred:deploy-url  "https://reckons.ai" ;
    kpred:review-gate "both" ;
    kpred:reviews-graph "roadmap+codebase" ;
    kpred:requires-documentation "true" ;
    kpred:description "Live site; deploys from main on every push. Requires BOTH developer and stakeholder approval. A feature reaching production carries kpred:in-production; has-status 'production' implies it." .
