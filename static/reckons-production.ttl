                    kpred:tested-by    "src/lib/rdf/__tests__/diff.test.ts" ;
                    kpred:tested-by    "src/lib/rdf/__tests__/semantic-diff.test.ts" ;
                    kpred:tested-by    "src/lib/rdf/__tests__/diff-summary.test.ts" .

kb:rdf-core         rdf:type     ktype:Feature ;
                    rdfs:label   "RDF Core (Types & Serialization)" ;
                    kpred:has-status   "production" ;
                    kpred:description  "Term constructors, type guards, N-Quads round-trip, Turtle export/import, W3C conformance." ;
                    kpred:tested-by    "src/lib/rdf/__tests__/types-helpers.test.ts" ;
                    kpred:tested-by    "src/lib/rdf/__tests__/serialize.test.ts" ;
                    kpred:tested-by    "src/lib/rdf/__tests__/turtle-w3c.test.ts" .

kb:content-safety   rdf:type     ktype:Feature ;
                    rdfs:label   "Content Safety" ;
                    kpred:has-status   "production" ;
                    kpred:description  "Pattern-based content classifier (blocked/mature/none) and ETHICS_PREAMBLE injection." ;
                    kpred:tested-by    "src/lib/safety/__tests__/content-policy.test.ts" .

kb:hierarchy-nav    rdf:type     ktype:Feature ;
                    rdfs:label   "Hierarchy Navigation" ;
                    kpred:has-status   "production" ;
                    kpred:description  "HNSW-inspired hierarchical layout. skos:broader trees, nav:order, nav:layer, sibling links." ;
                    kpred:tested-by    "src/lib/rdf/__tests__/hierarchy.test.ts" .

kb:workspace-export rdf:type     ktype:Feature ;
                    rdfs:label   "Workspace Export" ;
                    kpred:data-egress  "user-export" ;
                    kpred:has-status   "production" ;
                    kpred:description  "Semantic TTL export with backup scheduling. Graph asset round-trip. EXPORT IS A RIGHT (kb:data-egress-model): plain-text TTL of the user's own graph to the user's own disk is never blocked, whatever it contains — withholding it would be data lock-in, and it would be futile besides, since the graph is readable straight out of IndexedDB. A content ADVISORY header may be attached (scanForExportAdvisory); a blocking gate here would be a bug." ;
                    kpred:tested-by    "src/lib/storage/__tests__/semantic-export.test.ts" ;
                    kpred:tested-by    "src/lib/storage/__tests__/backup.test.ts" .

kb:graph-publishing rdf:type     ktype:Feature ;
                    rdfs:label   "Graph Publishing" ;
                    kpred:has-status   "functional" ;
                    kpred:description  "F27 — exports WebPage-typed graph entities to a static-site bundle (frontmatter + markdown) at /docs, and re-imports edits back into graph statements. scripts/docs-pages.ts regenerates content/ from the docs knowledge graphs; scripts/md-align.ts checks the two stay in lockstep. Sveltia CMS (static/admin/) edits content/*.md through a GitHub-backed admin UI." ;
                    kpred:uses         kb:sveltia-cms ;
                    kpred:tested-by    "src/lib/publish/__tests__/site-export.test.ts" ;
                    kpred:tested-by    "src/lib/publish/__tests__/site-import.test.ts" .

kb:sveltia-cms      rdf:type     ktype:Library ;
                    rdfs:label   "Sveltia CMS" ;
                    kpred:purpose "Git-backed admin UI at static/admin/ for editing published docs content." .

kb:local-offload    rdf:type     ktype:Feature ;
                    rdfs:label   "Local (Ollama) Offload" ;
                    kpred:has-status   "functional" ;
                    kpred:description  "Offload A: schema-constrained Ollama structured extraction (src/lib/integrations/llm/ollama-extract.ts) with a compact small-model prompt. Offload B: prefer-local routing (src/lib/integrations/llm/prefer-local.ts) — when settings.preferLocal is on and Ollama is reachable, chat/diff-summary/merge-analysis default to the ollama backend, probed via GET /api/tags with a short timeout and cache. MCP-side mirror: kb_local_extract, kb_local_summarize (opt-in via OLLAMA_BASE_URL, proposal-only)." ;
                    kpred:tested-by    "src/lib/integrations/llm/__tests__/ollama-extract.test.ts" ;
                    kpred:tested-by    "src/lib/integrations/llm/__tests__/prefer-local.test.ts" ;
                    kpred:tested-by    "mcp-server/src/__tests__/ollama-client.test.ts" ;
                    kpred:tested-by    "mcp-server/src/__tests__/local-llm.test.ts" .

kb:currents         rdf:type     ktype:Feature ;
                    rdfs:label   "Currents" ;
                    kpred:has-status   "functional" ;
                    kpred:description  "F29 — streamed-ingest arrival model with an entity-type gate and per-graph meta-triple settings. Items arrive via the n8n Currents Monitor (workflow qb9uPZ8GScAmuUOX; direct in-browser RSS/Atom fetch as fallback), ranked by embedding affinity to the graph's top-degree entities with near-duplicate collapse and content-policy filtering (src/lib/rdf/current-ranking.ts, src/lib/integrations/n8n/currents-sync.ts). Arrivals drift as translucent 'pod view' nodes (KnowledgeGraph2D and the home view) behind a toggle until accepted or dismissed from the graph-level Currents settings on /kb." ;
                    kpred:tested-by    "src/lib/rdf/__tests__/currents.test.ts" ;
                    kpred:tested-by    "src/lib/rdf/__tests__/currents-persist.test.ts" ;
                    kpred:tested-by    "src/lib/rdf/__tests__/current-ranking.test.ts" ;
                    kpred:tested-by    "src/lib/integrations/n8n/__tests__/currents-sync.test.ts" .

kb:review-workbench rdf:type     ktype:Feature ;
                    rdfs:label   "Review Workbench" ;
                    kpred:has-status   "functional" ;
                    kpred:description  "F30 — /review browse controls, node-details + chat pane, per-item focus (clicking a review item flies the preview graph to its node), and edge highlighting." ;
                    kpred:has-tab      "incoming" ;
                    kpred:has-tab      "deletions" ;
                    kpred:has-tab      "merges" ;
                    kpred:has-tab      "align" .

# ── Production Tests ─────────────────────────────────────────────────────────

kb:test-suite       rdf:type     ktype:TestSuite ;
                    rdfs:label   "Production Test Suite" ;
                    kpred:has-test kb:test-unit ;
                    kpred:has-test kb:test-e2e ;
                    kpred:has-test kb:test-typecheck ;
                    kpred:has-test kb:test-visual ;
                    kpred:has-test kb:test-visual-bench ;
                    kpred:has-test kb:test-mcp .

kb:test-unit        rdf:type     ktype:TestCategory ;
                    rdfs:label   "Unit Tests" ;
                    kpred:command  "npx vitest run" ;
                    kpred:checks   "triple parsing" ;
                    kpred:checks   "diff computation" ;
                    kpred:checks   "content safety" ;
                    kpred:checks   "repo URL parsing" ;
                    kpred:checks   "vision scoring" ;
                    kpred:checks   "semantic diff" ;
                    kpred:checks   "entity normalization" ;
                    kpred:checks   "entity types" ;
                    kpred:checks   "ghost graph / graph leap" ;
                    kpred:checks   "diff summary" ;
                    kpred:checks   "source refresh" ;
                    kpred:checks   "RDF types & helpers" ;
                    kpred:checks   "W3C Turtle conformance" ;
                    kpred:checks   "hierarchy navigation" ;
                    kpred:checks   "Graph registry" ;
                    kpred:checks   "TTL serialization round-trip" ;
                    kpred:checks   "currents (streamed-ingest arrivals)" ;
                    kpred:checks   "Ollama structured extraction" ;
                    kpred:checks   "prefer-local routing" ;
                    kpred:checks   "graph publishing (site export/import)" ;
                    kpred:checks   "web-page model" ;
                    kpred:expected-result "643 tests pass across 35 files (web app); mcp-server adds 44 vitest + 6 node:test tests." .

kb:test-e2e         rdf:type     ktype:TestCategory ;
                    rdfs:label   "E2E Tests" ;
                    kpred:command  "npx playwright test --project=desktop-chrome" ;
                    kpred:checks   "ingest flow" ;
                    kpred:checks   "review queue" ;
                    kpred:checks   "resilience fallbacks" ;
                    kpred:checks   "settings persistence" ;
                    kpred:expected-result "42+ tests pass" .

kb:test-typecheck   rdf:type     ktype:TestCategory ;
                    rdfs:label   "Type Check" ;
                    kpred:command  "npx svelte-check --threshold error" ;
                    kpred:checks   "TypeScript errors" ;
                    kpred:checks   "Svelte component types" ;
                    kpred:expected-result "0 errors" .

kb:test-visual      rdf:type     ktype:TestCategory ;
                    rdfs:label   "Visual/Playwright Tests" ;
                    kpred:command  "npx playwright test --config=playwright.visual.config.ts" ;
                    kpred:checks   "graph rendering" ;
                    kpred:checks   "nav bar presence" ;
                    kpred:checks   "page screenshots" ;
                    kpred:checks   "mobile touch targets" ;
                    kpred:checks   "panel overlap detection" ;
                    kpred:expected-result "all visual checks pass, no solid-fill artifacts" .

kb:test-visual-bench rdf:type    ktype:TestCategory ;
                    rdfs:label   "Visual Bench" ;
                    kpred:command  "npm run bench:visual" ;
                    kpred:checks   "pixel analysis accuracy" ;
                    kpred:checks   "DOM overlap detection" ;
                    kpred:checks   "text presence verification" ;
                    kpred:checks   "touch target WCAG compliance" ;
                    kpred:expected-result "local-combined >= 95% accuracy" .

kb:test-mcp         rdf:type     ktype:TestCategory ;
                    rdfs:label   "MCP Server Build" ;
                    kpred:command  "cd mcp-server && npm test" ;
                    kpred:checks   "TypeScript compilation" ;
                    kpred:checks   "20 tool handlers" ;
                    kpred:checks   "Ollama client + local LLM bridge" ;
                    kpred:checks   "page/entity markdown generation" ;
                    kpred:expected-result "build succeeds, 0 errors; 44 vitest + 6 node:test tests pass" .

