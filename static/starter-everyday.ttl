## ---------------------------------------------------------------------------
## Reckons.AI — "This Weekend" starter graph (two friends meet in the middle)
## ---------------------------------------------------------------------------
## The soft-landing first experience: an everyday decision anyone recognizes —
## two old friends who live apart want a weekend camping trip, so they look for
## somewhere roughly HALFWAY between them and each drive ~5 hours to meet.
##
## Alex lives in San Francisco; Jordan lives in Los Angeles. The natural meeting
## ground is the Eastern Sierra — about the same drive from either city. They
## have narrowed it to TWO real campgrounds a few miles apart:
##
##   • Lake George (Mammoth Lakes basin, ~9,000 ft) — iconic alpine lakes,
##     colder nights, a little pricier, and it books out fast.
##   • Oh! Ridge (June Lake Loop, ~7,600 ft) — lakeside, warmer, cheaper, and
##     it still has the whole weekend open.
##
## Every branch of the decision is modelled as its own node so the graph tells
## the story visually:
##   - TWO people, each with a home city, an icon, and a lean. They deliberately have
##     NO portrait: the two that used to be here were base64 photographs of real,
##     identifiable people with no creator, licence or source recorded, on a graph the
##     public landing page serves. Every other image here carries p:photo-credit and
##     p:photo-source, so those two were the one unverifiable claim in a demo whose
##     whole subject is verifiable claims. Removing them also took the file from 83 KB
##     to 16 KB. Real portraits can return whenever their provenance can be stated.
##   - TWO options (campgrounds) with a nightly PRICE, elevation and reservation link.
##   - TWO weather FORECASTS (one per option — they differ by elevation).
##   - FOUR routes: each person's DRIVE to each option (two distances per person),
##     so you can see the trip is genuinely "meet in the middle".
##   - A calendar WINDOW (Fri–Sun, Jul 10–12 2026); each option carries a
##     check-in / check-out date, so the "time" force layout shows which stay
##     actually fits the weekend.
##
## The tension by design: Jordan wants the alpine lakes at Lake George, but it
## only has Saturday night open and the nights are near-freezing; Oh! Ridge is
## cheaper, warmer, fits the whole window, and is almost exactly equidistant.
## Preference vs. price vs. calendar-fit vs. a fair drive — exactly what a
## Reckon resolves.
## ---------------------------------------------------------------------------

@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix ktype: <urn:kbase:type/> .
@prefix kb:    <urn:kbase:concept/> .
@prefix p:     <urn:kbase:predicate/> .

## == Custom entity types =====================================================
ktype:Campground
    rdf:type        ktype:EntityType ;
    rdfs:label      "Campground" ;
    p:icon          "cone" ;
    p:color         "#3a9d5c" .

ktype:Forecast
    rdf:type        ktype:EntityType ;
    rdfs:label      "Forecast" ;
    p:icon          "torus" ;
    p:color         "#4f9bd9" .

ktype:TripLeg
    rdf:type        ktype:EntityType ;
    rdfs:label      "Drive" ;
    p:icon          "tetrahedron" ;
    p:color         "#e0a13c" .

## == People ==================================================================
kb:alex
    rdf:type        ktype:Person ;
    rdfs:label      "Alex" ;
    rdfs:comment    "Drives up from San Francisco. Wants a fair, even meet-up point and would rather not spend the whole weekend behind the wheel." ;
    p:icon2d        "🥾" ;
    p:lives-in      kb:san-francisco ;
    p:deciding      kb:the-weekend ;
    p:considering   kb:lake-george ;
    p:considering   kb:oh-ridge ;
    p:leans-toward  kb:oh-ridge .

kb:jordan
    rdf:type        ktype:Person ;
    rdfs:label      "Jordan" ;
    rdfs:comment    "Drives up from Los Angeles. Has wanted to shoot the Mammoth Lakes basin at sunrise for years and is happy to pay a little more for it." ;
    p:icon2d        "📷" ;
    p:lives-in      kb:los-angeles ;
    p:coming-along  kb:the-weekend ;
    p:considering   kb:lake-george ;
    p:considering   kb:oh-ridge ;
    p:leans-toward  kb:lake-george .

## == A "set" grouping the two friends (demos entity sets, F65) ==============
## Select this node and its members (Alex, Jordan) light up — a reusable group.
kb:trip-crew
    rdf:type        ktype:EntitySet ;
    rdfs:label      "Trip crew" ;
    p:has-member    kb:alex ;
    p:has-member    kb:jordan .

## == Home cities =============================================================
kb:san-francisco
    rdf:type        ktype:Place ;
    rdfs:label      "San Francisco, CA" ;
    p:home-of       kb:alex ;
    p:photo         "/png/starter/san-francisco.jpg" ;
    p:photo-credit  "Ryan Schwark · CC0 1.0" ;
    p:photo-source  "https://commons.wikimedia.org/w/index.php?curid=161349162" ;
    p:map           "https://www.google.com/maps/place/San+Francisco,+CA" .

kb:los-angeles
    rdf:type        ktype:Place ;
    rdfs:label      "Los Angeles, CA" ;
    p:home-of       kb:jordan ;
    p:photo         "/png/starter/los-angeles.jpg" ;
    p:photo-credit  "ItzAPotato2009 · CC0 1.0" ;
    p:photo-source  "https://commons.wikimedia.org/w/index.php?curid=157019541" ;
    p:map           "https://www.google.com/maps/place/Los+Angeles,+CA" .

## == Option 1 — Lake George (Mammoth Lakes basin) ============================
kb:lake-george
    rdf:type        ktype:Campground ;
    rdfs:label      "Lake George" ;
    rdfs:comment    "Walk-to-the-water sites in the Mammoth Lakes basin at ~9,000 ft. Granite, pines and glassy alpine lakes — the postcard Eastern Sierra. Popular and small, so it books out within minutes of the 6-month window opening." ;
    p:region        kb:eastern-sierra ;
    p:elevation     "9,008 ft" ;
    p:nightly-rate  "$28" ;
    p:sites         "16 sites" ;
    p:availability  "only Saturday night open" ;
    p:reservation   "https://www.recreation.gov/search?q=Lake%20George%20Campground%20Mammoth%20Lakes" ;
    p:coordinates   "37.6485, -118.9721" ;
    p:forecast      kb:wx-mammoth ;
    p:photo         "/png/starter/lake-george.jpg" ;
    p:photo-credit  "The Fun Chronicles · CC0 1.0" ;
    p:photo-source  "https://www.flickr.com/photos/196406308@N04/54642164587" ;
    p:scheduled-at  "2026-07-11"^^xsd:date ;
    p:ends-at       "2026-07-12"^^xsd:date .

## == Option 2 — Oh! Ridge (June Lake Loop) ===================================
kb:oh-ridge
    rdf:type        ktype:Campground ;
    rdfs:label      "Oh! Ridge" ;
    rdfs:comment    "The big June Lake Loop campground on a rise above June Lake at ~7,600 ft — warmer nights, a swim beach, and far more availability than the Mammoth basin. Almost exactly halfway between the two friends by drive time." ;
    p:region        kb:eastern-sierra ;
    p:elevation     "7,644 ft" ;
    p:nightly-rate  "$23" ;
    p:sites         "148 sites" ;
    p:availability  "full weekend open" ;
    p:reservation   "https://www.recreation.gov/search?q=Oh%20Ridge%20Campground%20June%20Lake" ;
    p:coordinates   "37.7716, -119.0715" ;
    p:forecast      kb:wx-june-lake ;
    p:photo         "/png/starter/oh-ridge.jpg" ;
    p:photo-credit  "The Fun Chronicles · CC0 1.0" ;
    p:photo-source  "https://www.flickr.com/photos/196406308@N04/52972474892" ;
    p:scheduled-at  "2026-07-10"^^xsd:date ;
    p:ends-at       "2026-07-12"^^xsd:date .

kb:eastern-sierra
    rdf:type        ktype:Place ;
    rdfs:label      "Eastern Sierra" ;
    rdfs:comment    "The high country east of the Sierra crest — the natural midpoint for friends coming from the Bay Area and Southern California." ;
    p:photo         "/png/starter/eastern-sierra.jpg" ;
    p:photo-credit  "Z3lvs · CC0 1.0" ;
    p:photo-source  "https://commons.wikimedia.org/w/index.php?curid=142713117" .

## == Weather — one forecast per option (mid-July, differ by elevation) =======
kb:wx-mammoth
    rdf:type        ktype:Forecast ;
    rdfs:label      "Mammoth basin — Fri–Sun" ;
    rdfs:comment    "Sunny days, cold clear nights at altitude. Bring a real sleeping bag." ;
    p:icon2d        "🥶" ;
    p:high          "70°F" ;
    p:low           "38°F" ;
    p:summary       "Sunny · breezy afternoons · near-freezing nights" ;
    p:source        "https://forecast.weather.gov/MapClick.php?lat=37.6485&lon=-118.9721" .

kb:wx-june-lake
    rdf:type        ktype:Forecast ;
    rdfs:label      "June Lake — Fri–Sun" ;
    rdfs:comment    "A touch lower and noticeably milder overnight — easier first night out." ;
    p:icon2d        "☀️" ;
    p:high          "78°F" ;
    p:low           "43°F" ;
    p:summary       "Clear · light wind · mild nights" ;
    p:source        "https://forecast.weather.gov/MapClick.php?lat=37.7716&lon=-119.0715" .

## == Routes — each person's drive to each option (two distances per person) ===
kb:drive-alex-lake-george
    rdf:type        ktype:TripLeg ;
    rdfs:label      "Alex → Lake George" ;
    p:from          kb:alex ;
    p:to            kb:lake-george ;
    p:drive-distance "327 mi" ;
    p:drive-time    "5h 40m" ;
    p:directions    "https://www.google.com/maps/dir/San+Francisco,+CA/Lake+George,+Mammoth+Lakes,+CA" .

kb:drive-alex-oh-ridge
    rdf:type        ktype:TripLeg ;
    rdfs:label      "Alex → Oh! Ridge" ;
    p:from          kb:alex ;
    p:to            kb:oh-ridge ;
    p:drive-distance "313 mi" ;
    p:drive-time    "5h 25m" ;
    p:directions    "https://www.google.com/maps/dir/San+Francisco,+CA/June+Lake,+CA" .

kb:drive-jordan-lake-george
    rdf:type        ktype:TripLeg ;
    rdfs:label      "Jordan → Lake George" ;
    p:from          kb:jordan ;
    p:to            kb:lake-george ;
    p:drive-distance "305 mi" ;
    p:drive-time    "5h 05m" ;
    p:directions    "https://www.google.com/maps/dir/Los+Angeles,+CA/Mammoth+Lakes,+CA" .

kb:drive-jordan-oh-ridge
    rdf:type        ktype:TripLeg ;
    rdfs:label      "Jordan → Oh! Ridge" ;
    p:from          kb:jordan ;
    p:to            kb:oh-ridge ;
    p:drive-distance "319 mi" ;
    p:drive-time    "5h 20m" ;
    p:directions    "https://www.google.com/maps/dir/Los+Angeles,+CA/June+Lake,+CA" .

## == The calendar window we're filling =======================================
kb:the-weekend
    rdf:type        ktype:CalendarEvent ;
    rdfs:label      "Free Weekend" ;
    rdfs:comment    "The one weekend both friends are free this month. Two nights, checkout Sunday so nobody drives home in the dark." ;
    p:icon2d        "🗓" ;
    p:budget        "about $60 for two nights" ;
    p:nights        "2 nights" ;
    p:scheduled-at  "2026-07-10"^^xsd:date ;
    p:ends-at       "2026-07-12"^^xsd:date .


## == The weekend, hour by hour ===============================================
## The two campgrounds are dated, but a DATE RANGE does not show you a trip. These
## are the actual happenings inside the window, each with a real start time, so the
## "time" force layout lays the weekend out left-to-right instead of stacking two
## identical Fri–Sun blobs.
##
## They also carry the decision, which the price and elevation facts alone cannot:
## Lake George has ONLY Saturday night free, so choosing it DELETES Friday — the
## drive up in daylight, pitching camp, the first fire. Those three events are
## marked `p:ruled-out-by kb:lake-george`. Choosing Oh! Ridge instead costs Jordan
## the one thing he came for, the sunrise over the Mammoth basin, marked
## `p:ruled-out-by kb:oh-ridge`. Neither option is free; the graph shows the price
## of each in events rather than asserting a winner.

kb:ev-booking-deadline
    rdf:type        ktype:Event ;
    rdfs:label      "Book by Wednesday" ;
    rdfs:comment    "Lake George's remaining Saturday site is the last one on the loop and will not survive the week. Whatever they choose, it has to be chosen before this passes — the deadline is what turns a preference into a decision." ;
    p:icon2d        "⏳" ;
    p:decides       kb:the-weekend ;
    p:at            kb:lake-george ;
    p:scheduled-at  "2026-07-08T23:59"^^xsd:dateTime .

kb:ev-alex-client-call
    rdf:type        ktype:CalendarEvent ;
    rdfs:label      "Alex: client call (Friday)" ;
    rdfs:comment    "Already in Alex's calendar and not movable. It is the reason the drive north cannot start before early afternoon, which is the reason arriving in daylight is tight." ;
    p:icon2d        "📞" ;
    p:for           kb:alex ;
    p:scheduled-at  "2026-07-10T11:00"^^xsd:dateTime ;
    p:ends-at       "2026-07-10T12:30"^^xsd:dateTime .

kb:ev-alex-drive
    rdf:type        ktype:Event ;
    rdfs:label      "Alex drives up (SF → Eastern Sierra)" ;
    rdfs:comment    "Out of the Bay Area after the call, over Tioga or down 395 depending on the pass, arriving with just enough light left to find the site." ;
    p:icon2d        "🚗" ;
    p:for           kb:alex ;
    p:part-of       kb:the-weekend ;
    p:photo         "/png/starter/drive-395.jpg" ;
    p:photo-credit  "The Fun Chronicles · CC0 1.0" ;
    p:photo-source  "https://www.flickr.com/photos/196406308@N04/52977261205" ;
    p:ruled-out-by  kb:lake-george ;
    p:scheduled-at  "2026-07-10T13:00"^^xsd:dateTime ;
    p:ends-at       "2026-07-10T18:40"^^xsd:dateTime .

kb:ev-jordan-drive
    rdf:type        ktype:Event ;
    rdfs:label      "Jordan drives up (LA → Eastern Sierra)" ;
    rdfs:comment    "Straight up 395 out of Los Angeles. Leaves later than Alex and still arrives later — the two drives are within twenty minutes of each other, which is the whole point of meeting here." ;
    p:icon2d        "🚙" ;
    p:for           kb:jordan ;
    p:part-of       kb:the-weekend ;
    p:ruled-out-by  kb:lake-george ;
    p:scheduled-at  "2026-07-10T14:00"^^xsd:dateTime ;
    p:ends-at       "2026-07-10T19:05"^^xsd:dateTime .

kb:ev-pitch-camp
    rdf:type        ktype:Event ;
    rdfs:label      "Pitch camp before dark" ;
    rdfs:comment    "Tents up, bear box loaded, fire ring cleared — the half hour that decides whether the first night is pleasant or fumbled by headlamp." ;
    p:icon2d        "⛺" ;
    p:part-of       kb:the-weekend ;
    p:photo         "/png/starter/pitch-camp.jpg" ;
    p:photo-credit  "Bureau of Land Management California · Public domain" ;
    p:photo-source  "https://commons.wikimedia.org/wiki/File:Crowley_Lake_campground_site_(48061851118).jpg" ;
    p:ruled-out-by  kb:lake-george ;
    p:scheduled-at  "2026-07-10T19:30"^^xsd:dateTime ;
    p:ends-at       "2026-07-10T20:30"^^xsd:dateTime .

kb:ev-campfire
    rdf:type        ktype:Event ;
    rdfs:label      "First night, fire and catching up" ;
    rdfs:comment    "The reason for the trip, and the first casualty of the alpine option — at Lake George there is no Friday night to have it on." ;
    p:icon2d        "🔥" ;
    p:part-of       kb:the-weekend ;
    p:photo         "/png/starter/campfire.jpg" ;
    p:photo-credit  "U.S. Forest Service, Pacific Northwest Region · Public Domain Mark 1.0" ;
    p:photo-source  "https://www.flickr.com/photos/135886671@N08/45365195765" ;
    p:ruled-out-by  kb:lake-george ;
    p:scheduled-at  "2026-07-10T21:00"^^xsd:dateTime ;
    p:ends-at       "2026-07-10T23:30"^^xsd:dateTime .

kb:ev-sunrise-shoot
    rdf:type        ktype:Event ;
    rdfs:label      "Jordan's sunrise shoot" ;
    rdfs:comment    "The thing Jordan has wanted for years and the reason he leans alpine: first light on the Mammoth basin, which you can only shoot from up there. Choosing the cheaper, warmer, better-fitting option is choosing to give this up." ;
    p:icon2d        "🌄" ;
    p:for           kb:jordan ;
    p:at            kb:lake-george ;
    p:part-of       kb:the-weekend ;
    p:photo         "/png/starter/sunrise-shoot.jpg" ;
    p:photo-credit  "Andrew D Cox / U.S. Forest Service · Public Domain Mark 1.0" ;
    p:photo-source  "https://www.flickr.com/photos/140082569@N07/24809580078" ;
    p:ruled-out-by  kb:oh-ridge ;
    p:scheduled-at  "2026-07-11T05:32"^^xsd:dateTime ;
    p:ends-at       "2026-07-11T07:00"^^xsd:dateTime .

kb:ev-checkout
    rdf:type        ktype:Event ;
    rdfs:label      "Checkout and drive home" ;
    rdfs:comment    "Eleven o'clock checkout, then five hours in opposite directions. Late enough for a slow morning, early enough that neither of them finishes in the dark." ;
    p:icon2d        "🏁" ;
    p:part-of       kb:the-weekend ;
    p:scheduled-at  "2026-07-12T11:00"^^xsd:dateTime ;
    p:ends-at       "2026-07-12T16:30"^^xsd:dateTime .

kb:ev-jordan-monday
    rdf:type        ktype:CalendarEvent ;
    rdfs:label      "Jordan: Monday review (09:00)" ;
    rdfs:comment    "The commitment on the far side of the weekend. It is what makes an eleven o'clock checkout the latest workable one — leave any later and Sunday's drive runs into Monday's obligation." ;
    p:icon2d        "📋" ;
    p:for           kb:jordan ;
    p:scheduled-at  "2026-07-13T09:00"^^xsd:dateTime .
