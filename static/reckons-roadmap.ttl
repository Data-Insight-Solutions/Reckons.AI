               kpred:relates-to   kb:visual-testing .

# -- Content Orchestrator (F71) ------------------------------------------------
# Reframe: Reckons.AI is a CONTENT ORCHESTRATOR, not just a context manager. It
# doesn't only manage input context — it COMPOSES digital-asset OUTPUTS from the
# graph. Raised 2026-07-11.

kb:content-orchestrator rdf:type ktype:Feature ;
               rdfs:label    "Content Orchestrator" ;
               kpred:feature-id   "F71" ;
               kpred:has-status   "speculative" ;
               kpred:priority     "high" ;
               kpred:principle    "Content Orchestrator, not just Context manager: the graph is a SOURCE for composed outputs (a combined PDF, a doc, a set of images/3D), not only a store of reviewed context. Orchestration = clean, clear composition of digital assets FROM the graph." ;
               kpred:principle    "Scope by SELECTION, not the whole graph. Generate/compose from a chosen SET (F65 entity sets) or a set-selection menu — or the whole graph — the user picks the scope. 'Maybe both': a scope switch (this set / these sets / everything)." ;
               kpred:description  "Compose digital-asset outputs cleanly: COMBINE PDFs (merge several PDFs, or compose one PDF from selected graph content/WebPages), and other outputs (image collage, doc, 3D scene). Driven by set-selection menus that bound the output to a subgraph, so you're not forced to render the entire graph. Sits atop F58 meta-visual generation (output types PNG/PDF/GLB, F58.4), F58.5 asset+fact assembly (now scoped by a set), F58.7 file conversion (PDF composition), and F58.8 orchestration; F65 entity sets provide the selection scope. PDF composition is one of the most FEASIBLE near-term outputs (deterministic, OSS libs) — a good first Content-Orchestrator deliverable." ;
               kpred:depends-on   kb:entity-sets ;
               kpred:relates-to   kb:meta-visual-generation ;
               kpred:relates-to   kb:mvg-asset-assembly ;
               kpred:relates-to   kb:gen-orchestration ;
               kpred:relates-to   kb:review-anchored-generation .

# -- Infrastructure entities (completeness) -------------------------------------
# Defined here because features depend-on them (F22 -> embedding-model,
# local-offload -> llm-providers) but they had no entity — the graph pointed at
# nothing. Shipped/production infrastructure.

kb:embedding-model rdf:type ktype:Feature ;
               rdfs:label    "Embedding Model" ;
               kpred:has-status   "production" ;
               kpred:description  "In-browser semantic embeddings via BGE-small-en-v1.5 (33MB, 384d, q8) through @huggingface/transformers (src/lib/embed.ts). Runtime-switchable via VITE_EMBEDDING_MODEL (MODEL_SIZES table); powers similarity, entity normalization (F22), disambiguation, and search. Cached after first load — fully offline." ;
               kpred:relates-to   kb:knowledge-graph .

kb:llm-providers rdf:type ktype:Feature ;
               rdfs:label    "LLM Providers" ;
               kpred:has-status   "production" ;
               kpred:description  "Pluggable LLM backends (src/lib/integrations/llm/): claude, openai, gemini, ollama, wasm (in-browser via @huggingface/transformers), reckons (hosted proxy), openrouter, chrome-ai, plus mock/manual. Per-task selection (ingest / analyze / chat / diffSummary / mergeAnalysis); wasm auto-fallback when a chosen cloud backend has no key. ETHICS_PREAMBLE is injected into every provider's system prompt." ;
               kpred:relates-to   kb:knowledge-graph .
