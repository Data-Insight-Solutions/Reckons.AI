kb:model-training rdf:type  ktype:Feature ;
               rdfs:label   "Model Training" ;
               kpred:has-status   "planned" ;
               kpred:feature-id   "F13" ;
               kpred:description  "Fine-tune local models on KB data. Personalised assistant that reasons natively over domain vocabulary and relationships. Three phases: training data export, cloud fine-tuning, local LoRA." ;
               kpred:has-phase    train:phase-1 ;
               kpred:has-phase    train:phase-2 ;
               kpred:has-phase    train:phase-3 ;
               kpred:target-model "Granite 3.1 2B" ;
               kpred:target-model "SmolLM2-360M" ;
               kpred:target-model "Phi-3-mini" ;
               kpred:open-question "Quality threshold: how many triples needed for useful fine-tuning? Likely 200+." ;
               kpred:open-question "Evaluation: how to measure if fine-tuned model is better than RAG alone?" ;
               kpred:open-question "Incremental training: update adapter when new triples added without full retraining?" ;
               kpred:open-question "Multi-KB: adapters per-KB or trained on all user KBs combined?" .

train:phase-1  rdf:type     ktype:Concept ;
               rdfs:label   "Training Phase 1: Training Data Export" ;
               kpred:has-status   "planned" ;
               kpred:description  "Convert KB triples into instruction-tuning pairs. Entity QA, relationship QA, multi-hop reasoning, and subgraph summarisation generation strategies. Augmentation with paraphrases and negative examples." ;
               kpred:has-file     "src/lib/training/generate-pairs.ts" ;
               kpred:has-file     "src/lib/training/export.ts" ;
               kpred:export-format "JSONL (instruction/response pairs)" ;
               kpred:export-format "Alpaca (instruction/input/output)" ;
               kpred:export-format "ShareGPT (multi-turn conversations)" ;
               kpred:has-ui       "Settings > Training tab" ;
               kpred:has-tool     "kb_export_training" .

train:phase-2  rdf:type     ktype:Concept ;
               rdfs:label   "Training Phase 2: Cloud Fine-Tuning" ;
               kpred:has-status   "planned" ;
               kpred:description  "Export training data for cloud LoRA fine-tuning platforms. Reckons.AI generates and exports JSONL; user handles training externally. Model download back to local cache after training." ;
               kpred:depends-on   train:phase-1 ;
               kpred:has-platform "AWS Bedrock (Granite, custom models)" ;
               kpred:has-platform "Together.ai / Fireworks (open models)" ;
               kpred:has-platform "Hugging Face AutoTrain" ;
               kpred:pro          "No local GPU needed, production-quality training" ;
               kpred:con          "Data leaves the device, requires cloud account + cost" .

train:phase-3  rdf:type     ktype:Concept ;
               rdfs:label   "Training Phase 3: Local LoRA" ;
               kpred:has-status   "planned" ;
               kpred:description  "On-device LoRA adapter training. Base model SmolLM2-360M (already cached locally). Generate adapter weights from KB data (10-50MB, portable). Multiple KB adapters coexist with one base model." ;
               kpred:depends-on   train:phase-2 ;
               kpred:has-approach "WebGPU-accelerated LoRA training (when browser support matures)" ;
               kpred:has-approach "Python sidecar fallback (reckons train --local)" ;
               kpred:has-capability "adapter management (load/unload per KB)" ;
               kpred:pro          "Data stays local, no cloud costs" ;
               kpred:con          "Requires GPU or long CPU training time, quality limited by base model size" .

