# -- Entity Normalisation (F22) -------------------------------------------------

kb:entity-normalisation rdf:type ktype:Feature ;
               rdfs:label   "Entity Normalisation" ;
               kpred:has-status   "production" ;
               kpred:feature-id   "F22" ;
               kpred:description  "Post-extraction, pre-review IRI rewriting using embedding similarity. Two-pass: exact label match then cosine (0.90 entity, 0.88 predicate). Prevents duplicate entities from entering review queue. Protects standard vocabularies. Perf guard at 500 entities." ;
               kpred:depends-on   kb:embedding-model ;
               kpred:related      kb:cross-kb-alignment .

