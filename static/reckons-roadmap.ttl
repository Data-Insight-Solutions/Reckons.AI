# -- Enterprise: People · Policy · Procedure (F21) ------------------------------

kb:enterprise-3ps rdf:type ktype:Feature ;
               rdfs:label   "Enterprise: People · Policy · Procedure" ;
               kpred:has-status   "planned" ;
               kpred:feature-id   "F21" ;
               kpred:description  "Structure organisational knowledge around the 3 Ps framework: People (who knows what — RBAC, teams, ownership, delegation, audit trails, trust scores), Policy (what governs it — legal constraints, cultural norms, compliance rules, data classification, retention policies), Procedure (how it gets done — SOPs, decision trees, process graphs, checklists, runbooks). Each dimension maps naturally to RDF triples. Key design decisions: file-based TTL delivery (portable W3C format, diffable via git, no proprietary lock-in), Bring Your Own Auth (organisations plug in existing SSO/LDAP/OIDC/SAML — no built-in identity provider), graph-native RBAC (permissions are triples, queryable and time-bounded), and self-hosted operation (n8n cloud sync on the organisation's infrastructure, air-gapped first-class). Personal Reckons.AI remains unchanged; enterprise is an opt-in layer." ;
               kpred:has-dimension kb:ent-people ;
               kpred:has-dimension kb:ent-policy ;
               kpred:has-dimension kb:ent-procedure ;
               kpred:has-phase    kb:ent-phase-1 ;
               kpred:has-phase    kb:ent-phase-2 ;
               kpred:has-phase    kb:ent-phase-3 ;
               kpred:has-phase    kb:ent-phase-4 .

kb:ent-people  rdf:type     ktype:Concept ;
               rdfs:label   "People (Enterprise)" ;
               kpred:description  "Role-based access controls. Team KBs with ownership, delegation, and audit trails. Graph-native RBAC — permissions are triples, queryable and time-bounded." .

kb:ent-policy  rdf:type     ktype:Concept ;
               rdfs:label   "Policy (Enterprise)" ;
               kpred:description  "Legal, cultural, and compliance constraints as first-class graph entities. Temporal bounds, provenance, governed-by relationships. Policies travel with the knowledge they govern." .

kb:ent-procedure rdf:type   ktype:Concept ;
               rdfs:label   "Procedure (Enterprise)" ;
               kpred:description  "Depth of specifics — SOPs, decision trees, process graphs. Step ordering, decision points, SLAs. From high-level intent to step-by-step execution." .

kb:ent-byoa    rdf:type     ktype:Concept ;
               rdfs:label   "Bring Your Own Auth" ;
               kpred:description  "No built-in identity provider. Organisations plug in SSO, LDAP, OIDC, or SAML. Auth gateway validates tokens and maps to RBAC roles from the graph." ;
               kpred:related      kb:enterprise-3ps .

kb:ent-ttl-delivery rdf:type ktype:Concept ;
               rdfs:label   "File-Based TTL Delivery" ;
               kpred:description  "Enterprise KBs distributed as .ttl files. Portable W3C standard. Diffable via git. Offline-first. No proprietary format, no database dependency." ;
               kpred:related      kb:enterprise-3ps .

kb:ent-phase-1 rdf:type   ktype:Concept ;
               rdfs:label   "Enterprise Phase 1: Graph-Native RBAC" ;
               kpred:description  "Define role/permission vocabulary as RDF predicates. Four roles (Viewer, Contributor, Reviewer, Admin) with scoping at KB, graph, and entity levels. RBAC evaluation engine (client-side, reads permission triples). Admin UI for role assignment. Audit trail logging — every mutation records actor, action, target, and timestamp as triples." ;
               kpred:has-status   "planned" .

kb:ent-phase-2 rdf:type   ktype:Concept ;
               rdfs:label   "Enterprise Phase 2: BYOA Auth Gateway" ;
               kpred:description  "Bring Your Own Auth — thin middleware that validates tokens from the organisation's identity provider and maps identities to RBAC roles defined in the graph. Supported protocols: OIDC (Okta, Auth0, Entra ID), LDAP (on-premise Active Directory), SAML (legacy enterprise SSO), API Key (machine-to-machine for MCP, n8n, CI/CD). No stored credentials, no sessions — stateless token validation only." ;
               kpred:has-status   "planned" ;
               kpred:depends-on   kb:ent-phase-1 .

kb:ent-phase-3 rdf:type   ktype:Concept ;
               rdfs:label   "Enterprise Phase 3: Policy & Procedure Modelling" ;
               kpred:description  "Policy entity type with temporal bounds (effective-date, superseded-by), provenance, and governed-by relationships. Procedure entity type with step ordering, decision points, SLAs, on-failure branches. Policies travel with the knowledge they govern. Procedures become navigable process graphs in the 3D view. Reckoning becomes policy-aware. Diff/review shows governed-by relationships." ;
               kpred:has-status   "planned" ;
               kpred:depends-on   kb:ent-phase-1 .

kb:ent-phase-4 rdf:type   ktype:Concept ;
               rdfs:label   "Enterprise Phase 4: Team Workflows" ;
               kpred:description  "Shared KB registry backed by n8n data tables. Merge request workflow: propose, review, accept — with multi-reviewer support. Conflict resolution across concurrent edits. Activity feed and notification via n8n webhooks (Slack, email, ntfy). Team members export TTL, submit via n8n sync hub or git PR, reviewer imports and curates." ;
               kpred:has-status   "planned" ;
               kpred:depends-on   kb:ent-phase-2 ;
               kpred:depends-on   kb:ent-phase-3 .

# -- Confluence Migration (F26) -------------------------------------------------

kb:confluence-migration rdf:type ktype:Feature ;
               rdfs:label   "Confluence Migration" ;
               kpred:has-status   "planned" ;
               kpred:feature-id   "F26" ;
               kpred:description  "Bulk import from Confluence spaces into Reckons.AI. Upload HTML export ZIP, parse page tree, chunk large pages, extract triples with local models. Pause/resume checkpoint, progress persistence, label-to-type mapping, page hierarchy as skos:broader." ;
               kpred:depends-on   kb:wf-ingest ;
               kpred:depends-on   kb:entity-normalisation ;
               kpred:has-phase    kb:conf-phase-1 ;
               kpred:has-phase    kb:conf-phase-2 ;
               kpred:has-phase    kb:conf-phase-3 ;
               kpred:has-phase    kb:conf-phase-4 .

kb:conf-phase-1 rdf:type   ktype:Concept ;
               rdfs:label   "Confluence Phase 1: HTML Parser" ;
               kpred:description  "New confluence tab on Add page. ZIP upload, HTML parsing, page tree reconstruction from index.html. Sequential extraction using existing pipeline." ;
               kpred:has-status   "planned" .

kb:conf-phase-2 rdf:type   ktype:Concept ;
               rdfs:label   "Confluence Phase 2: Chunking + Queue" ;
               kpred:description  "Sliding window chunking (10K chars, 2K overlap) for large pages. Per-chunk extraction with deduplication. Pause/resume with localStorage checkpoint. Error retry queue." ;
               kpred:has-status   "planned" ;
               kpred:depends-on   kb:conf-phase-1 .

kb:conf-phase-3 rdf:type   ktype:Concept ;
               rdfs:label   "Confluence Phase 3: Rename Ingest to Add" ;
               kpred:description  "Route /ingest → /add with redirect. NavBar label change. Vault → Batch tab rename. Less technical terminology for non-developer users." ;
               kpred:has-status   "planned" .

kb:conf-phase-4 rdf:type   ktype:Concept ;
               rdfs:label   "Confluence Phase 4: API Connector" ;
               kpred:description  "REST API client for Confluence Cloud. Incremental sync (pages modified since last import). Label and space metadata via API. Optional — HTML export covers most use cases." ;
               kpred:has-status   "planned" ;
               kpred:depends-on   kb:conf-phase-1 .

# -- Text Chunking (F27) -------------------------------------------------------

kb:text-chunking rdf:type ktype:Feature ;
               rdfs:label   "Text Chunking" ;
               kpred:has-status   "planned" ;
               kpred:feature-id   "F27" ;
               kpred:description  "Sliding window chunking for sources exceeding the 12K char extraction limit. Context header per chunk (source title, chunk N of M). Cross-chunk deduplication by (subject, predicate, object). Benefits all source types, not just Confluence." ;
               kpred:depends-on   kb:wf-ingest .

# -- Entity Normalisation (F22) -------------------------------------------------

kb:entity-normalisation rdf:type ktype:Feature ;
               rdfs:label   "Entity Normalisation" ;
               kpred:has-status   "production" ;
               kpred:feature-id   "F22" ;
               kpred:description  "Post-extraction, pre-review IRI rewriting using embedding similarity. Two-pass: exact label match then cosine (0.90 entity, 0.88 predicate). Prevents duplicate entities from entering review queue. Protects standard vocabularies. Perf guard at 500 entities." ;
               kpred:depends-on   kb:embedding-model ;
               kpred:related      kb:cross-kb-alignment .

