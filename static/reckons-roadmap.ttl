# -- n8n Currents Monitor (F29.2) ------------------------------------------------

kb:n8n-currents-monitor rdf:type ktype:Concept ;
               rdfs:label   "Currents Monitor" ;
               kpred:description  "n8n workflow (extends the Source Monitor pattern) that fetches enabled Currents on a 30-minute schedule, respecting each current's own cadenceMinutes via a lastFetchedAt due-check. RSS/Atom currents use the RSS Read node; url-kind currents fetch-and-hash like Source Monitor, keyed by a content-hash-suffixed URL so a changed page produces a new item row. Dedupes items by (url, graphStableId) via the data table rowNotExists operation before insert, so re-running the sweep never creates duplicates. Exposes a register webhook (upsert current definitions) and an items webhook (pull new rows for a graph, optionally since a timestamp) for the Reckons.AI app." ;
               kpred:has-status   "functional" ;
               kpred:workflow-id  "qb9uPZ8GScAmuUOX" ;
               kpred:has-endpoint "/webhook/reckons-currents-register" ;
               kpred:has-endpoint "/webhook/reckons-currents-items" ;
               kpred:relates-to   kb:n8n-source-monitor ;
               kpred:relates-to   kb:currents .

