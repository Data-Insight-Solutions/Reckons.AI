# -- Graph Publishing / Sveltia CMS (F27) ---------------------------------------
# Model a website directly in the graph — pages as connected nodes — and publish
# a static, graph-powered site. Competes with markdown docs tools (Docusaurus/
# MkDocs/GitBook) but powered by the triple framework and offline for authoring.
# Graph-first: graph is source of truth -> export markdown+frontmatter to content/
# in THIS repo -> Sveltia CMS (external, un-forked) edits -> a /docs route group in
# the main app renders the pages (prerendered via adapter-static) -> Cloudflare
# Pages. Hosting: served alongside the app at Reckons.AI/docs now; a docs.reckons.ai
# subdomain can point at the same /docs build later. See plan "Sveltia CMS Publishing".

kb:graph-publishing rdf:type ktype:Feature ;
               rdfs:label   "Graph Publishing (Sveltia CMS)" ;
               kpred:data-egress  "mediated-distribution" ;
               kpred:gated-by     kb:publish-safety-gate ;
               kpred:has-status   "in-progress" ;
               kpred:feature-id   "F27" ;
               kpred:description  "Publish WebPage graph nodes as a static, graph-powered docs site served at Reckons.AI/docs (self-contained, in the main app — not a separate repo). Graph-first: nodes export to content/<section>/<slug>.md (frontmatter + body) plus graph.json; Sveltia CMS (external bundle, un-forked) edits the files; a prerendered /docs route group renders them via mdsvex; Cloudflare Pages deploys. Hybrid body: excerpt in graph, long-form markdown in Git. Offline-capable authoring and .zip export. Future: docs.reckons.ai subdomain over the same build." ;
               kpred:has-phase    kb:gp-phase-1 ;
               kpred:has-phase    kb:gp-phase-2 ;
               kpred:has-phase    kb:gp-phase-3 ;
               kpred:has-phase    kb:gp-phase-4 ;
               kpred:depends-on   kb:knowledge-graph ;
               kpred:depends-on   kb:repo-ingest ;
               kpred:hosting      "Served at Reckons.AI/docs (route group in the main app, prerendered via adapter-static). Future: docs.reckons.ai subdomain over the same /docs build." ;
               kpred:principle    "Graph/TTL + Reckoning is the PRIMARY authoring surface. AI-generated page content is directly editable in the graph; content/*.md is a generated, trailing by-product. Sveltia editing is a secondary convenience (round-trips back into the graph)." ;
               kpred:principle    "A markdown alignment check keeps content/*.md honest against the graph: CI regenerates markdown from the WebPage nodes and flags any committed .md that drifts (edited outside the graph, or graph changed without re-publish) — mirroring the Reckons.AI Graph Alignment Check." ;
               kpred:principle    "The docs knowledge graphs (static/starter-guide.ttl + static/docs-*.ttl) are the source of truth for the 'generated' /docs sections; Sveltia CMS is for the OTHER content (releases) and for capturing refinements back into the graph, not for hand-editing generated pages — see kb:docs-pipeline." ;
               kpred:supports     "Embeddable images (Sveltia media_folder) and the rest of Sveltia's CMS widgets remain available for hand-editing." ;
               kpred:credits      "Sveltia CMS — github.com/sveltia/sveltia-cms (MIT). Used as an external dependency; consider sponsoring." .

## -- Published-graph exchange: publish → discover → zero-LLM re-ingest → subscribe --
## The loop: a Reckons.AI page already IS a graph, so anything it publishes carries
## its own TTL. Readers can Add it straight to their own graph as pending facts with
## no LLM extraction, and can subscribe so pods surface the publisher's new facts.
kb:published-graph-exchange rdf:type ktype:Feature ;
               rdfs:label   "Published-Graph Exchange (F72)" ;
               kpred:data-egress  "mediated-distribution" ;
               kpred:gated-by     kb:publish-safety-gate ;
               kpred:feature-id   "F72" ;
               kpred:has-status   "planned" ;
               kpred:relates-to   kb:graph-publishing ;
               kpred:relates-to   kb:currents ;
               kpred:description  "Close the loop so Reckons.AI publishers and subscribers exchange GRAPHS, not scraped prose. Four parts: self-describing TTL on every published page (kb:published-ttl), zero-LLM Add-from-URL when the target is a Reckons graph (kb:ttl-aware-ingest), publisher subscriptions polled by pods (kb:publisher-subscriptions), and richer calendar management (kb:calendar-management)." ;
               kpred:has-part     kb:published-ttl ;
               kpred:has-part     kb:ttl-aware-ingest ;
               kpred:has-part     kb:publisher-subscriptions ;
               kpred:has-part     kb:calendar-management .

kb:published-ttl rdf:type    ktype:Feature ;
               rdfs:label   "Self-describing published TTL" ;
               kpred:data-egress  "mediated-distribution" ;
               kpred:gated-by     kb:publish-safety-gate ;
               kpred:has-status   "functional" ;
               kpred:relates-to   kb:graph-publishing ;
               kpred:description  "Publishing now emits a self-describing knowledge.ttl (publish-safety-filtered, confirmed facts) at the site root alongside graph.json, and every published /docs page advertises it via <link rel=\"alternate\" type=\"text/turtle\" href=\"/knowledge.ttl\">. A reader's Add-from-URL (kb:ttl-aware-ingest) discovers and imports it with no LLM. Remaining: permissive CORS headers on the deploy so another Reckons.AI can fetch cross-origin (a Cloudflare/host config, not app code), and optional per-page <slug>.ttl subgraphs." ;
               kpred:done         "site-export.ts buildSiteFiles → knowledge.ttl (toTurtle + filterBlockedStatements); docs/+layout.svelte rel=alternate link." ;
               kpred:depends-on   kb:graph-publishing .

kb:facebook-groups-ingest rdf:type ktype:Feature ;
               rdfs:label   "Facebook Groups ingest" ;
               kpred:has-status   "speculative" ;
               kpred:relates-to   kb:ingest ;
               kpred:description  "Import facts from Facebook Groups a user organizes in — a common real-world coordination surface. NOT a scrape: Meta's Groups API was largely deprecated in 2020 and the remaining endpoints need a Meta app + App Review with restricted permissions (e.g. groups_access_member_info), tied to a group admin's consent; unsanctioned scraping violates Meta ToS and risks blocks. Treat as an optional, per-user INTEGRATION behind settings (like n8n), not a core dependency: a user connects their own Meta app / an n8n or Zapier flow that has group access and posts events into their Reckons.AI (contact-form pattern). Feasible path: n8n Facebook node or Graph API with the user's approved app; surface imported posts/events as pending facts for review." ;
               kpred:open-question "Which is the realistic first path — user's own approved Meta app, or an n8n/Zapier flow that already has group access? What group data is actually available post-2020 API deprecation (posts? events? member info)?" ;
               kpred:depends-on   kb:n8n-integration .

kb:ttl-aware-ingest rdf:type ktype:Feature ;
               rdfs:label   "Zero-LLM Add-from-URL (TTL)" ;
               kpred:has-status   "planned" ;
               kpred:relates-to   kb:ingest ;
               kpred:description  "When Add-from-URL points at a Reckons.AI graph, import it DIRECTLY as pending facts with no LLM extraction. Detection: try a direct fetch and check content-type text/turtle, a .ttl extension, or an HTML <link rel=alternate type=text/turtle>; on hit, route the TTL through the existing importTurtleFull → pending statements (reuses the file/Drive import path). Falls back to the current firecrawl/jina + LLM flow when the URL is not a graph or is CORS-blocked. Cheaper, exact, and lossless vs. re-extracting prose the publisher already modelled." ;
               kpred:depends-on   kb:published-ttl .

kb:publisher-subscriptions rdf:type ktype:Feature ;
               rdfs:label   "Publisher subscriptions + pod polling" ;
               kpred:has-status   "planned" ;
               kpred:relates-to   kb:currents ;
               kpred:description  "Subscribe to a publisher (their published-graph URL / a small manifest). With pods enabled, poll each subscription on the currents cadence (like the workspace folder poll + loop-guard hashes), fetch new/changed TTL via kb:ttl-aware-ingest, and drift the new facts in as translucent pod arrivals for review. Seamless: subscribe once, new published facts appear in your pod without re-adding." ;
               kpred:depends-on   kb:ttl-aware-ingest .

kb:calendar-management rdf:type ktype:Feature ;
               rdfs:label   "Calendar management UI/UX" ;
               kpred:has-status   "planned" ;
               kpred:description  "Beyond add/incoming calendar events: a management surface for calendars themselves — list connected/subscribed calendars, enable/disable, choose which sync into the graph, and treat a published calendar as a subscription (kb:publisher-subscriptions) so new events flow in via pods. Builds on the existing calendar ingest source." ;
               kpred:relates-to   kb:publisher-subscriptions .

## -- F73: Grant discovery via scheduled currents + n8n review notifications ------
## Real use-case (two nonprofits): the graph holds each org's grant-seeker profile;
## a scheduled n8n scrape uses it to find eligible grant CALLS online and posts them
## back as pending facts; you only open the graph when there's something to review,
## because n8n emails you. n8n owns the scrape + schedule + email (side effects); the
## app owns the profile, the review queue, and firing the "review me" signal.
kb:grant-discovery-currents rdf:type ktype:Feature ;
               rdfs:label   "Grant discovery (scheduled scrape → currents)" ;
               kpred:feature-id   "F73" ;
               kpred:has-status   "planned" ;
               kpred:relates-to   kb:currents ;
               kpred:relates-to   kb:n8n-integration ;
               kpred:description  "Automatic web scraping for eligible grant CALLS, targeted by the org's own graph. n8n runs a scheduled workflow (cron) that reads the grant-seeker profile (kb:grant-seeker-profile) — mission, focus areas, populations, geography, budget band, org type/501c3, deadlines-watch — turns it into searches across grant sources (grants.gov, foundation/RFP pages, funder lists), filters to eligible calls, and posts each match back into Reckons.AI as PENDING facts (knowledge.pending.jsonl in the synced folder/Drive, or a webhook). They arrive as translucent pod currents for review. Two live examples exist (two nonprofits the operator works with) — each is its own graph with its own profile, so the same workflow serves both. Respects the Integration Boundaries: the scrape/schedule live in the user's n8n, never in the core app." ;
               kpred:has-part     kb:grant-seeker-profile ;
               kpred:depends-on   kb:n8n-review-notifications ;
               kpred:template     "static/n8n/grant-scrape.workflow.json — importable n8n workflow: schedule → fetch profile TTL → profile→query → Grants.gov search → matches→pending.jsonl → append. Placeholders for profile URL, Drive/file, schedule." ;
               kpred:open-question "Which grant sources first (grants.gov API vs. HTML RFP pages)? How much eligibility filtering in n8n vs. surfaced for human review? One shared n8n workflow parameterised per-graph, or one per nonprofit?" .

kb:grant-seeker-profile rdf:type ktype:Feature ;
               rdfs:label   "Grant-seeker profile (graph shape)" ;
               kpred:has-status   "planned" ;
               kpred:relates-to   kb:grant-discovery-currents ;
               kpred:description  "A small, standard subgraph describing what an org is eligible for and seeking: focus areas, served populations, geography, funding need, org type (501c3 etc.). The scheduled scrape reads it (via synced TTL / kb:published-ttl) to target searches. Real profiles are PER-USER PRIVATE DATA — kept in the user's own graph / Google Drive, never bundled as a public app asset. The workflow template (static/n8n/grant-scrape.workflow.json) reads a placeholder profile URL the user points at their private graph." ;
               kpred:relates-to   kb:partial-facts .

kb:growing-filter-set rdf:type ktype:Feature ;
               rdfs:label   "Growing filter set (requirements → questions → sharper profile)" ;
               kpred:has-status   "planned" ;
               kpred:relates-to   kb:grant-seeker-profile ;
               kpred:relates-to   kb:partial-facts ;
               kpred:description  "The profile need not be complete up front — it grows one real requirement at a time. When a scraped grant CALL raises a requirement the profile can't yet answer (annual budget? 501c3 status? equipment new/used? residents served?), the scrape posts it as a PARTIAL fact (F32: object '?' + a question) on the profile. Answering it in Review both unblocks that call and permanently sharpens every future search — a filter that accretes from the funders' own asks. Mechanic: knowledge.pending.jsonl question entries (drainWorkspacePending) → partial facts → answer-flow-back." ;
               kpred:depends-on   kb:partial-facts .

kb:n8n-review-notifications rdf:type ktype:Feature ;
               rdfs:label   "n8n review notifications (email me when there's something to review)" ;
               kpred:feature-id   "F73.1" ;
               kpred:has-status   "functional" ;
               kpred:relates-to   kb:n8n-integration ;
               kpred:description  "One unified signal: whenever new PENDING facts land via addStatements — a scheduled grant scrape (currents), a subscribed publisher's pod (kb:publisher-subscriptions), or any ingest — the app fires a best-effort POST to the user's n8n review webhook (/webhook/reckons-review) with a small summary (count, kind, sample labels). n8n turns it into an email/Slack/digest however the user likes, so they don't have to keep opening the graph. Opt-in via settings.n8nNotifyOnReview + n8nBaseUrl; fire-and-forget so a slow/absent n8n never blocks an edit. Two n8n email automations round out the loop: this review notifier and the existing contact form (kb:n8n-integration). Pods reuse this exact hook." ;
               kpred:done         "src/lib/integrations/n8n/notify.ts (notifyReview); wired in kb.svelte addStatements; settings.n8nNotifyOnReview; unit-tested." ;
               kpred:template     "static/n8n/review-notify-email.workflow.json — importable n8n workflow: webhook /webhook/reckons-review → format → email." ;
               kpred:depends-on   kb:n8n-integration .

