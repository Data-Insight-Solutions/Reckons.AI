## =============================================================================
## Tips and Tricks
## =============================================================================

tip:Tips
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Tips and Tricks" ;
    skos:definition     "Practical advice for getting the most out of Reckons.AI." ;
    skos:related        guide:WhatIsReckonsAI .

tip:StartSmall
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Start Small" ;
    skos:definition     "Begin with one document or topic you care about. Ingest it, review the triples, confirm the accurate ones. Your KB grows naturally with each source you add. Over time, connections emerge that you never would have seen reading documents linearly." ;
    skos:broader        tip:Tips .

tip:ReviewCarefully
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Review Carefully" ;
    skos:definition     "The quality of your KB depends entirely on the quality of your review. Reject inaccurate triples. Refine ambiguous ones. A smaller KB of confirmed facts is far more valuable than a large KB of unreviewed noise." ;
    skos:broader        tip:Tips .

tip:UseSourceTrust
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Use Source Trust" ;
    skos:definition     "Mark reliable sources as trusted to auto-confirm future imports from them. But start conservative -- trust is earned through consistent accuracy." ;
    skos:broader        tip:Tips .

tip:ExportOften
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Export Often" ;
    skos:definition     "Your .ttl export is your insurance policy. Export regularly. Keep backups. The file is plain text -- it will outlast any app, any platform, any company." ;
    skos:broader        tip:Tips .

tip:NameEntitiesWell
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Name Entities Well" ;
    skos:definition     "Use clear, specific entity names. 'Q3 2025 Revenue Report' is better than 'Report'. Good names make the graph navigable and Shelly's answers more precise." ;
    skos:broader        tip:Tips .

tip:UseOllamaOffline
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Use Ollama for Offline" ;
    skos:definition     "Install Ollama on your machine for fully local, fully offline LLM inference. Zero data leaves your device. Good models: llama3.2, mistral, phi3." ;
    skos:broader        tip:Tips ;
    skos:related        feat:LLMBackends .

tip:ShareTTL
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Share Your .ttl" ;
    skos:definition     "Export your KB and share the .ttl file. Recipients can import it and see a semantic diff against their own KB. Collaboration through structured knowledge exchange -- no real-time sync needed." ;
    skos:broader        tip:Tips ;
    skos:related        feat:Compare .


## =============================================================================
## Security and Privacy
## =============================================================================

guide:Security
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Security and Privacy" ;
    skos:definition     "Reckons.AI is designed so that your data cannot leak by accident. The architecture makes security the default, not an afterthought." ;
    skos:related        guide:WhatIsReckonsAI .

guide:NoServer
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "No Server = No Breach" ;
    skos:definition     "There is no server to hack. Your data lives in your browser's IndexedDB. The app is a static file served from a CDN or your own machine. No database, no API endpoint, no attack surface." ;
    skos:broader        guide:Security .

guide:APIKeySafety
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "API Key Safety" ;
    skos:definition     "API keys are sent directly from your browser to the provider (Claude, OpenAI, etc.). They never pass through any Reckons.AI infrastructure. Keys are excluded from .ttl exports and settings exports." ;
    skos:broader        guide:Security .

guide:CSP
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Content Security Policy" ;
    skos:definition     "The app enforces a strict CSP: no inline scripts beyond what SvelteKit requires, object-src none, form-action self. connect-src explicitly lists each allowed AI provider domain." ;
    skos:broader        guide:Security .

guide:OfflineCapable
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Offline Capable" ;
    skos:definition     "After first load, the app works without internet. Use Ollama or the WASM model and zero inference traffic leaves your machine. Your KB is fully usable offline." ;
    skos:broader        guide:Security .

guide:ContentSafety
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Content Safety System" ;
    skos:definition     "All LLM prompts include an ethics preamble (hardcoded, not configurable). A content classifier filters blocked content on ingest and flags mature content on export with an advisory triple. Discourse, disagreement, and academic content pass freely." ;
    skos:broader        guide:Security .


## =============================================================================
## Vulnerability Response and Dependency Audit
## =============================================================================

tip:VulnerabilityResponse
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Vulnerability Response Process" ;
    skos:definition     "When a new vulnerability is reported (via npm audit, Dependabot alert, or public advisory): 1) Assess impact — is the vulnerable code path reachable? Consider SSR-only vs static, lazy-loaded vs always-bundled, user-supplied input vs fixed sources. 2) Document in SECURITY.md with severity, CVE, risk assessment, and fix path. 3) If high/critical and exploitable: open GitHub issue tagged security, disable the feature by default, begin research into replacement, apply npm audit fix. 4) If moderate/low and not exploitable: document and apply on next routine upgrade. 5) When fixed: move to Resolved section with date." ;
    skos:broader        guide:Security .

tip:DependencyAudit
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Dependency Audit Process" ;
    skos:definition     "Three free tools in use: npm audit (known CVEs in dependency tree), GitHub Dependabot (automated PRs for vulnerable deps — enable via Settings > Security > Dependabot), and GitHub Code Scanning via CodeQL (static analysis of source code). CI gate: npm audit --audit-level=high blocks merges on high/critical findings." ;
    skos:broader        guide:Security .

tip:DataClassification
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Data Classification Levels" ;
    skos:definition     "All KB data stored in browser IndexedDB (origin-locked). API keys stored in IndexedDB settings table (origin-locked, not in localStorage). sessionStorage for per-tab KB selection (not shared across origins). localStorage for KB registry (names and IDs only, no secrets). No cookies used. Keys sent directly from browser to provider APIs — never transit through Reckons.AI infrastructure. Keys excluded from TTL exports and settings profile exports." ;
    skos:broader        guide:Security .

tip:NoTelemetry
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "No Telemetry Constraint" ;
    skos:definition     "Reckons.AI collects zero telemetry, zero analytics, and performs zero third-party tracking. No server exists to receive telemetry. No analytics scripts are loaded. No tracking pixels. No usage data leaves the browser. This is an architectural constraint, not a policy — there is no server-side code in production (adapter-static). Fonts are self-hosted (no Google Fonts CDN). CSP connect-src explicitly lists only AI provider domains." ;
    skos:broader        guide:Security .

tip:RiskWarnings
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "Risk Warnings for Integrations" ;
    skos:definition     "Features with inherent risk are disabled by default and display a warning in Settings. Voice (Hume.AI): audio sent to cloud, warning shown. QR Mobile Access: token-based auth with expiry, warning shown. Cloud LLM backends: note text sent to third-party API, warning shown in backend selector. WASM local inference: transitive protobufjs CVE in dependency chain — models loaded only from HuggingFace CDN, no user data affected." ;
    skos:broader        guide:Security .

tip:XSSProtection
    rdf:type            ktype:Concept ;
    rdf:type            skos:Concept ;
    rdfs:label          "XSS Protection" ;
    skos:definition     "All {@html} usages are safe: TurtleChatPanel uses escHtml() before markdown, SearchBar uses escHtml() on all segments, NavBar renders hardcoded SVG, extension popup/sidepanel use template literals with no user input. Input validation: Turtle files parsed by N3.js, user text sent to LLMs for extraction has prompt injection mitigated by mandatory review step (all triples must be confirmed by user), file uploads handled by browser File API (no server upload)." ;
    skos:broader        guide:Security .


