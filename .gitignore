# Environment variables
.env
.env.local
.env.*.local

# Node dependencies
node_modules/
yarn.lock

# Build output
dist/
build/
.svelte-kit/
*.tsbuildinfo
storybook-static/

# Test output
test-results/
playwright-report/
playwright-report-smoke/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Claude Code sessions
.claude/
# …but the slash commands ARE project files. CLAUDE.md lists them as project docs, and
# reckons-codebase.ttl claims them with kpred:has-file — a claim that was TRUE on the author's
# laptop and FALSE in every other checkout, which is the worst shape a claim can have.
# Track them; keep the local/private .claude state ignored.
!.claude/commands/
!.claude/commands/*.md

# Local data / workspace
mnt/
*.pending.jsonl

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Local development
.cache/
temp/

# Bench results (generated)
tests/bench/results/

# MCP workspace (legacy symlinks)
mcp-workspace/

# Reckons workspace (transient files)
reckons-workspace/kbs/*/pending.jsonl
reckons-workspace/kbs/*/sources.json
reckons-workspace/knowledge.ttl
reckons-workspace/knowledge.pending.jsonl
static/docs-all.ttl

# F34 button-crawl generated artifacts (regenerate: npm run test:crawl)
tests/visual/button-crawl.ttl
tests/visual/screenshots/button-crawl/

# tesseract.js OCR language data (downloaded at runtime)
eng.traineddata
*.traineddata

# Runner state — DERIVED, not authored. The queue (reckons-workspace/tasks.ttl) is the truth;
# this is only the machine's record of what it claimed and what came of it. Delete to reset.
reckons-workspace/*.state.ttl
reckons-workspace/runner.log.jsonl

reckons-workspace/schedules.state.ttl
reckons-workspace/schedule.log.jsonl
reckons-workspace/task-drafts.ttl

# Local app workspace — the folder-sync target writes copies of every graph here.
# Only default-kb is a real repo asset; the rest are duplicates of static/*.ttl and
# were once swept into a commit by `git add -A static/` (15,093 lines, 2026-07-19).
static/kbs/*
!static/kbs/default-kb/
