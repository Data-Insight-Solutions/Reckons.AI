# Runner state — DERIVED, not authored. The queue (reckons-workspace/tasks.ttl) is the truth;
# this is only the machine's record of what it claimed and what came of it. Delete to reset.
reckons-workspace/*.state.ttl
reckons-workspace/runner.log.jsonl
