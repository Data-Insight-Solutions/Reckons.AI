# ─── Reckons.AI — Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in values for local development.
#
# VITE_ prefix  → baked into the browser bundle at build time (Vite static build).
#                 These become the DEFAULT values loaded into IndexedDB on first
#                 launch.  Users can override them at runtime via Settings.
# Non-VITE_     → server/dev-tooling only (NODE_ENV, PORT, etc.) — never shipped.
#
# API keys are stored ONLY in IndexedDB on the user's device and are never sent
# anywhere except the respective AI provider endpoint you explicitly call.

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  LLM PROVIDERS — at least one key or local runtime required                ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Claude (Anthropic) — best reasoning quality ───────────────────────────────
# Key from: console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=
VITE_CLAUDE_MODEL=claude-haiku-4-5-20251001

# ─── OpenAI ────────────────────────────────────────────────────────────────────
# Key from: platform.openai.com/api-keys
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini

# ─── Google Gemini — free tier: 1 500 req/day ──────────────────────────────────
# Key from: aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.0-flash

# ─── OpenRouter — one key, many models (free models available) ─────────────────
# Key from: openrouter.ai/keys  (no credit card required for free-tier models)
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# ─── Ollama — fully local, no API key needed ───────────────────────────────────
# Install: https://ollama.com  then: ollama serve && ollama pull llama3.2
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama3.2

# ─── WebAssembly (in-browser, 100 % offline) ───────────────────────────────────
# Model is downloaded once from Hugging Face and cached in the browser.
VITE_WASM_MODEL=onnx-community/Qwen2.5-0.5B-Instruct

# ─── Reckons hosted inference (Cloudflare Workers AI proxy) ────────────────────
# Optional hosted backend at api.reckons.ai — leave blank unless you have a key.
VITE_RECKONS_API_KEY=
VITE_RECKONS_MODEL=@cf/meta/llama-3.1-8b-instruct
VITE_RECKONS_BASE_URL=https://api.reckons.ai

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  DEFAULT BACKENDS — which provider to use for each task                    ║
# ║  Options: claude | openai | gemini | ollama | openrouter | wasm | mock     ║
# ║           | chrome-ai | reckons                                            ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Overall fallback when no per-task override is set (app default: claude;
# silently falls back to wasm at runtime when the chosen cloud backend has no key)
VITE_PREFERRED_BACKEND=ollama

# Per-task overrides (leave blank to inherit VITE_PREFERRED_BACKEND)
# ingest  — text → RDF triples extraction
VITE_INGEST_BACKEND=
# analyze — KB re-analysis (type / relation / merge suggestions) — no mock
VITE_ANALYZE_BACKEND=
# chat    — Shelly assistant conversations
VITE_CHAT_BACKEND=

# Prefer local: when true and Ollama is reachable, chat, diff summaries, and
# merge analysis route to Ollama automatically. Explicit per-task overrides
# above still win. Toggleable at runtime in Settings > AI backends per task.
VITE_PREFER_LOCAL=

# Embedding model for semantic similarity (in-browser, cached after first load)
# Default: Xenova/bge-small-en-v1.5 (33 MB, 384d). Alternative: Xenova/all-MiniLM-L6-v2
VITE_EMBEDDING_MODEL=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  KNOWLEDGE BASE IDENTITY                                                   ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Human-readable name shown in the header and used by AI prompts
VITE_KB_TITLE=
# One-sentence description of what this KB is about (guides analysis prompts)
VITE_KB_DESCRIPTION=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  SHELLY ASSISTANT                                                          ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Shelly persona ────────────────────────────────────────────────────────────
# Each KB can have its own turtle personality. These env vars set the defaults.
# Users can override everything at runtime via the Turtle settings panel.

# Display name (default: "Shelly")
VITE_SHELLY_NAME=
# First greeting message (leave blank for default)
VITE_SHELLY_GREETING=
# Personality: helpful | witty | laid-back | sarcastic
VITE_SHELLY_PERSONALITY=
# Custom system prompt prepended to Shelly's default instructions (optional)
VITE_SHELLY_PROMPT=
# Response style: concise | detailed | conversational
VITE_SHELLY_RESPONSE_STYLE=
# Soft word cap for responses (0 = no limit)
VITE_SHELLY_MAX_WORDS=

# ─── Hume.AI (optional — voice interface) ──────────────────────────────────────
# API key + Secret key: platform.hume.ai → API Keys
# Config ID: platform.hume.ai → EVI → Configs (create a custom voice persona)
VITE_HUME_API_KEY=
VITE_HUME_SECRET_KEY=
VITE_HUME_CONFIG_ID=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  PARSING & SCRAPING                                                        ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Mistral OCR — PDF and image → markdown ────────────────────────────────────
# Key from: console.mistral.ai → API Keys
# Used in Ingest → document tab to parse PDFs and images before triple extraction
VITE_MISTRAL_API_KEY=

# ─── Firecrawl — JS-rendered web scraping ──────────────────────────────────────
# Key from: firecrawl.dev → Dashboard → API Keys
# Replaces Jina Reader when set; handles JavaScript-heavy pages (SPAs, paywalls)
VITE_FIRECRAWL_API_KEY=

# ─── n8n cloud sync (optional, self-hosted) ────────────────────────────────────
# Base URL of your n8n instance running the Reckons sync workflows
# (see docs/N8N_INTEGRATION.md). Leave blank to disable cloud sync defaults.
# This is the USER'S OWN automation instance — their currents sync, their review
# notifications, firing into their systems.
VITE_N8N_BASE_URL=

# Where the in-app contact/feedback form submits. This is the PRODUCT's endpoint and is
# deliberately NOT derived from VITE_N8N_BASE_URL above: feedback travels the other way
# (a message to the maintainers), so routing it through the user's own instance meant
# anyone running their own n8n POSTed feedback to their own server, 404'd, and it was lost.
#
# Full webhook URL including the path, e.g. https://n8n.example.com/webhook/reckons-contact
# Import static/n8n/contact-feedback.workflow.json into that instance to receive it.
# LEAVE BLANK to disable direct submit — the form then falls back to a mailto link, which
# always works. A fork or self-hoster points this at their own desk.
VITE_FEEDBACK_WEBHOOK_URL=

# ─── Indico (CERN conference system — calendar/event ingest) ──────────────────
# Optional, per-user. The ingest tab's "calendar" source imports events from a
# self-hosted Indico instance. All three can also be set in-app under
# Settings -> Integrations (and the server URL via the ?indico= query param),
# which OVERRIDES these — these only seed the defaults for a fresh install.
#
# Server URL is REQUIRED for any of this to do anything: a token on its own
# configures nothing, because createIndicoClient() returns null without a URL.
VITE_INDICO_SERVER_URL=
# API token ("ak" key) for authenticated access to protected events. Public
# Indico instances need no token. Get one from your Indico profile -> API tokens.
VITE_INDICO_API_TOKEN=
# Restrict the sync to one category id. Blank = the root category (all events).
VITE_INDICO_CATEGORY_ID=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  3D / VISUAL                                                               ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Meshy.AI API key for text-to-3D node icon generation
# Key from: app.meshy.ai/api (paid service)
VITE_MESHY_API_KEY=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  DEV / DEPLOYMENT                                                          ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

NODE_ENV=development
HOST=localhost
PORT=5173

# ─── Cloudflare (CI/CD tooling — never shipped; used by wrangler, not the app) ──
# Least-privilege API token for managing Workers/Pages deploys, env vars, and
# (optionally) the admin.reckons.ai DNS. Scopes: Workers Scripts:Edit,
# Pages:Edit, and Zone DNS:Edit only if you want DNS managed too.
# Create at: Cloudflare dashboard → My Profile → API Tokens → Create Token.
# wrangler reads these from the environment; run e.g.:
#   set -a; . ./.env; set +a; npx wrangler whoami
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ─── Sveltia CMS — GitHub OAuth (worker secrets) — never shipped ───────────────
# The /admin content manager (F27 Graph Publishing) logs in via GitHub OAuth,
# brokered by the already-deployed Cloudflare Worker `reckons-sveltia-cms-auth`
# at admin.reckons.ai. These vars are NOT baked into the app build — they exist
# only so scripts/sveltia-auth-secrets.sh can push them to the worker as secrets.
#
# 1. Create the OAuth App: GitHub → Settings → Developer settings → OAuth Apps
#    → New OAuth App. Homepage URL: https://reckons.ai
#    Authorization callback URL: https://admin.reckons.ai/callback
# 2. Paste the generated Client ID / Client Secret below, then run:
#      bash scripts/sveltia-auth-secrets.sh
#    which pushes them to the worker as GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET /
#    ALLOWED_DOMAINS via `wrangler secret put` (requires CLOUDFLARE_API_TOKEN
#    and CLOUDFLARE_ACCOUNT_ID above).
# Prefer to skip OAuth entirely for local editing? Run a local proxy instead:
#   npx @sveltia/cms-proxy-server
# then set local_backend: true in static/admin/config.yml.
SVELTIA_GITHUB_CLIENT_ID=
SVELTIA_GITHUB_CLIENT_SECRET=
# Comma-separated; `*` matches one subdomain level. The wildcard covers the dev
# branch alias (dev.reckons-ai.pages.dev) and hashed preview deploys.
SVELTIA_ALLOWED_DOMAINS=reckons.ai,*.reckons-ai.pages.dev

# ─── Notes for self-hosted deployments ─────────────────────────────────────────
# 1. Copy this file to .env and fill in the values you need.
# 2. Run: npm run build  (or: vite build)  — keys are embedded at build time.
# 3. The built output in dist/ is a fully static site — serve with any web server.
# 4. To share a configured experience without exposing API keys, use the
#    "Settings Profile" export in the app (Settings → My Defaults → export .json).
#    The profile contains model preferences and UI settings but NO API keys.
