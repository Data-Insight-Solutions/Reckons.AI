@prefix kb: <urn:kbase:concept/> .
@prefix src: <urn:kbase:source/> .
@prefix pred: <urn:kbase:predicate/> .
@prefix meta: <urn:kbase:meta/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
